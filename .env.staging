DIRECT_URL=postgresql://postgres:STAGING_PASSWORD@staging-postgres.railway.internal:5432/staging_db

# Staging URLs
NEXTAUTH_URL=https://staging.bdgenai.com
NEXT_PUBLIC_APP_URL=https://staging.bdgenai.com

# Staging Auth Secret (different from production)
