  🎓 Three Ways to Integrate Forms

  Method 1: FormSyncWrapper (For New Forms)

  <FormSyncWrapper formId="course-creation" formName="Create Course">
    <input name="title" value={title} onChange={setTitle} />
  </FormSyncWrapper>

  Method 2: useSAMFormSync (For React Hook Form)

  const { watch } = useForm();
  useSAMFormSync('my-form', watch);  // One line!

  Method 3: useSyncExistingForm (For Legacy Forms)

  const formRef = useRef<HTMLFormElement>(null);
  useSyncExistingForm('legacy-form', formRef.current);

