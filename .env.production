# Production Environment Variables
NODE_ENV=production
NEXT_PUBLIC_APP_URL=https://taxomind.railway.app
NEXTAUTH_URL=https://taxomind.railway.app

# Database (automatically provided by Railway)
# DATABASE_URL will be injected by Railway

# Feature Flags
ENABLE_DEBUG_MODE=false
ENABLE_TEST_FEATURES=false
STRICT_ENV_MODE=true

# Performance
ENABLE_CACHE=true
CACHE_TTL=3600

# Monitoring
LOG_LEVEL=error
# Security
CSP_REPORT_URI=https://taxomind.railway.app/api/security/csp-report
SECURITY_WEBHOOK_URL=
