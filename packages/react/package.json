{
  "name": "@sam-ai/react",
  "version": "0.1.0",
  "description": "React hooks, providers, and components for SAM AI Tutor - build context-aware educational interfaces",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --tsconfig tsconfig.build.json --clean",
    "dev": "tsup src/index.ts --format cjs,esm --dts --tsconfig tsconfig.build.json --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "dependencies": {
    "@sam-ai/core": "workspace:*",
    "@sam-ai/educational": "workspace:*"
  },
  "devDependencies": {
    "@testing-library/react": "^16.1.0",
    "@types/node": "^22.5.5",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitest/coverage-v8": "^4.0.0",
    "jsdom": "^26.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsup": "^8.2.4",
    "typescript": "^5.6.2",
    "vitest": "^4.0.0"
  },
  "keywords": [
    "sam",
    "ai",
    "tutor",
    "react",
    "hooks",
    "education",
    "provider",
    "context",
    "adaptive-learning"
  ],
  "author": "Taxomind <dev@taxomind.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/taxomind/sam-ai.git",
    "directory": "packages/react"
  },
  "bugs": {
    "url": "https://github.com/taxomind/sam-ai/issues"
  },
  "homepage": "https://github.com/taxomind/sam-ai/tree/main/packages/react#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
