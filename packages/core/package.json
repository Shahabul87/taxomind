{
  "name": "@sam-ai/core",
  "version": "0.1.0",
  "description": "Core engine orchestration, state machine, and types for SAM AI Tutor - a context-aware educational assistant with Bloom's Taxonomy support",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --tsconfig tsconfig.build.json --clean",
    "dev": "tsup src/index.ts --format cjs,esm --dts --tsconfig tsconfig.build.json --watch",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.5.5",
    "tsup": "^8.2.4",
    "typescript": "^5.6.2",
    "vitest": "^2.0.0"
  },
  "peerDependencies": {
    "@anthropic-ai/sdk": ">=0.27.3"
  },
  "peerDependenciesMeta": {
    "@anthropic-ai/sdk": {
      "optional": true
    }
  },
  "keywords": [
    "ai",
    "tutor",
    "education",
    "lms",
    "anthropic",
    "claude",
    "openai",
    "sam",
    "blooms-taxonomy",
    "adaptive-learning",
    "context-aware"
  ],
  "author": "Taxomind <dev@taxomind.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/taxomind/sam-ai.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/taxomind/sam-ai/issues"
  },
  "homepage": "https://github.com/taxomind/sam-ai/tree/main/packages/core#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
