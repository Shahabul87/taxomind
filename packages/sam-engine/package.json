{
  "name": "@taxomind/sam-engine",
  "version": "1.0.0",
  "description": "SAM (Smart Adaptive Mentor) - Modular AI Educational Assistant Engine",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "types"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "ai",
    "education",
    "assistant",
    "lms",
    "adaptive-learning",
    "educational-technology",
    "chatbot",
    "mentor"
  ],
  "author": "Taxomind Team",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.27.3",
    "openai": "^4.65.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.5.5",
    "@typescript-eslint/eslint-plugin": "^8.5.0",
    "@typescript-eslint/parser": "^8.5.0",
    "@vitest/coverage-v8": "^4.0.0",
    "eslint": "^8.57.1",
    "tsup": "^8.2.4",
    "typescript": "^5.6.2",
    "vitest": "^4.0.0"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/taxomind/sam-engine.git"
  },
  "bugs": {
    "url": "https://github.com/taxomind/sam-engine/issues"
  },
  "homepage": "https://github.com/taxomind/sam-engine#readme",
  "engines": {
    "node": ">=18.0.0"
  }
}