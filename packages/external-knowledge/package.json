{
  "name": "@sam-ai/external-knowledge",
  "version": "0.1.0",
  "description": "External knowledge integration for SAM AI Mentor - news, research, and web content",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.5.5",
    "tsup": "^8.2.4",
    "typescript": "^5.6.2",
    "vitest": "^2.0.0"
  },
  "keywords": [
    "ai",
    "external-knowledge",
    "news",
    "research",
    "web-content",
    "sam",
    "education",
    "mentor"
  ],
  "author": "Taxomind <dev@taxomind.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/taxomind/sam-ai.git",
    "directory": "packages/external-knowledge"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
