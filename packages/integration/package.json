{
  "name": "@sam-ai/integration",
  "version": "0.1.0",
  "description": "Integration profile, capability registry, and adapter abstractions for SAM AI - enables portability across host systems",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./adapters": {
      "types": "./dist/adapters/index.d.ts",
      "import": "./dist/adapters/index.mjs",
      "require": "./dist/adapters/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@sam-ai/core": "workspace:*",
    "@sam-ai/agentic": "workspace:*",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.5.5",
    "tsup": "^8.2.4",
    "typescript": "^5.6.2",
    "vitest": "^2.0.0"
  },
  "keywords": [
    "sam-ai",
    "integration",
    "portability",
    "adapters",
    "lms",
    "education",
    "ai-tutor"
  ],
  "author": "Taxomind <dev@taxomind.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/taxomind/sam-ai.git",
    "directory": "packages/integration"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
