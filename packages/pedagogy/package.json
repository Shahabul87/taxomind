{
  "name": "@sam-ai/pedagogy",
  "version": "0.1.0",
  "description": "Pedagogical evaluators for SAM AI Tutor - Bloom's taxonomy alignment, scaffolding, and ZPD analysis",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --tsconfig tsconfig.build.json --clean",
    "dev": "tsup src/index.ts --format cjs,esm --dts --tsconfig tsconfig.build.json --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@types/node": "^22.5.5",
    "@vitest/coverage-v8": "^2.1.9",
    "tsup": "^8.2.4",
    "typescript": "^5.6.2",
    "vitest": "^2.1.9"
  },
  "keywords": [
    "sam",
    "ai",
    "tutor",
    "pedagogy",
    "blooms-taxonomy",
    "scaffolding",
    "zpd",
    "zone-of-proximal-development",
    "education",
    "evaluation"
  ],
  "author": "Taxomind <dev@taxomind.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/taxomind/sam-ai.git",
    "directory": "packages/pedagogy"
  },
  "bugs": {
    "url": "https://github.com/taxomind/sam-ai/issues"
  },
  "homepage": "https://github.com/taxomind/sam-ai/tree/main/packages/pedagogy#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
