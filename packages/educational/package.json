{
  "name": "@sam-ai/educational",
  "version": "0.1.0",
  "description": "Advanced educational engines for SAM AI Tutor - exam generation, evaluation, and Bloom's taxonomy analysis",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./depth-analysis": {
      "types": "./dist/depth-analysis.d.ts",
      "import": "./dist/depth-analysis.mjs",
      "require": "./dist/depth-analysis.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/depth-analysis.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts src/depth-analysis.ts --format cjs,esm --dts --watch",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@sam-ai/core": "workspace:*",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.5.5",
    "tsup": "^8.2.4",
    "typescript": "^5.6.2"
  },
  "peerDependencies": {
    "@anthropic-ai/sdk": ">=0.27.3"
  },
  "peerDependenciesMeta": {
    "@anthropic-ai/sdk": {
      "optional": true
    }
  },
  "keywords": [
    "sam",
    "ai",
    "tutor",
    "education",
    "exam",
    "evaluation",
    "blooms-taxonomy",
    "assessment",
    "grading",
    "adaptive-learning"
  ],
  "author": "Taxomind <dev@taxomind.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/taxomind/sam-ai.git",
    "directory": "packages/educational"
  },
  "bugs": {
    "url": "https://github.com/taxomind/sam-ai/issues"
  },
  "homepage": "https://github.com/taxomind/sam-ai/tree/main/packages/educational#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
