{
  "name": "@sam-ai/vanilla",
  "version": "0.1.0",
  "description": "Framework-agnostic SAM AI client SDK. Works in browser, Node.js, Deno, and Bun.",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "typecheck": "tsc --noEmit"
  },
  "keywords": ["sam", "ai", "sdk", "vanilla", "education"],
  "license": "MIT",
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.3.0"
  }
}
