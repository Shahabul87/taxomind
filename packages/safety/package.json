{
  "name": "@sam-ai/safety",
  "version": "0.1.0",
  "description": "Safety validation for SAM AI Tutor - bias detection, fairness validation, accessibility checking",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {},
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.6.2"
  },
  "peerDependencies": {},
  "keywords": [
    "sam-ai",
    "safety",
    "bias-detection",
    "fairness",
    "accessibility",
    "education",
    "ai-tutor"
  ],
  "author": "Taxomind",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/taxomind/sam-ai.git",
    "directory": "packages/safety"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
