#!/bin/sh

# Skip in CI environment
if [ "$CI" = "true" ]; then
  echo "Skipping pre-commit hooks in CI"
  exit 0
fi

echo "🔍 Running ESLint checks..."

# Run ESLint with increased memory allocation
NODE_OPTIONS='--max-old-space-size=12288' npm run lint

# Capture exit code
LINT_EXIT_CODE=$?

if [ $LINT_EXIT_CODE -ne 0 ]; then
  echo "❌ ESLint check failed! Please fix the errors before committing."
  exit 1
fi

echo "✅ ESLint check passed!"
exit 0
