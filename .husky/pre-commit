#!/bin/sh
. "$(dirname "$0")/_/husky.sh"

# Skip in CI environment
if [ "$CI" = "true" ]; then
  echo "Skipping pre-commit hooks in CI"
  exit 0
fi

# Temporarily skip linting due to memory issues
echo "⚠️ ESLint temporarily disabled in pre-commit due to memory constraints"
echo "📝 To run linting manually: NODE_OPTIONS='--max-old-space-size=12288' npm run lint"
exit 0