{
  "name": "taxomind",
  "version": "1.0.0",
  "private": true,
  "description": "Taxomind - Intelligent Learning Platform with AI-powered education and adaptive courses",
  "workspaces": [
    "packages/*"
  ],
  "keywords": [
    "education",
    "AI",
    "learning",
    "LMS",
    "adaptive learning",
    "intelligent tutoring"
  ],
  "author": "Taxomind Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Shahabul87/taxomind.git"
  },
  "bugs": {
    "url": "https://github.com/Shahabul87/taxomind/issues"
  },
  "homepage": "https://github.com/Shahabul87/taxomind#readme",
  "engines": {
    "node": ">=22.12.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "dev": "node scripts/load-env.js && next dev --turbo",
    "dev:clean": "node scripts/fix-css-dev.js && node scripts/load-env.js && next dev --turbo",
    "fix-css": "node scripts/fix-css-dev.js",
    "socket:dev": "NODE_OPTIONS='--max-old-space-size=4096' npx tsx server/index.ts",
    "socket:start": "NODE_OPTIONS='--max-old-space-size=4096' npx tsx server/index.ts",
    "build": "SKIP_ENV_VALIDATION=true NODE_OPTIONS='--max-old-space-size=8192' node scripts/load-env.js && SKIP_ENV_VALIDATION=true NODE_OPTIONS='--max-old-space-size=8192' next build",
    "build:clean:basic": "./scripts/clean-before-build.sh && npm run build",
    "build:turbo": "SKIP_ENV_VALIDATION=true NODE_OPTIONS='--max-old-space-size=8192' node scripts/load-env.js && SKIP_ENV_VALIDATION=true NODE_OPTIONS='--max-old-space-size=8192' next build --turbopack",
    "build:local:fast": "SKIP_ENV_VALIDATION=true NEXT_TELEMETRY_DISABLED=1 SKIP_SENTRY=true SKIP_LINT=true SKIP_TYPE_CHECK=true NODE_OPTIONS='--max-old-space-size=8192' next build --no-lint",
    "build:optimized": "bash scripts/build-optimized.sh",
    "build:validate": "node scripts/build-with-validation.js",
    "build:fast": "SKIP_ENV_VALIDATION=true NEXT_TELEMETRY_DISABLED=1 CI=true SKIP_SENTRY=true NODE_OPTIONS='--max-old-space-size=8192' next build",
    "build:local": "bash scripts/fast-build.sh",
    "build:ci": "SKIP_ENV_VALIDATION=true NODE_OPTIONS='--max-old-space-size=8192' next build --no-lint",
    "build:clean": "bash scripts/build-clean.sh",
    "build:ignore-errors": "SKIP_ENV_VALIDATION=true NODE_OPTIONS='--max-old-space-size=8192' SKIP_TYPE_CHECK=true SKIP_LINT=true next build",
    "optimize:analyze": "npx ts-node scripts/optimize-build.ts",
    "performance:check": "node scripts/performance-check.js",
    "build:analyze": "SKIP_ENV_VALIDATION=true ANALYZE=true SKIP_LINT=true SKIP_TYPE_CHECK=true NODE_OPTIONS='--max-old-space-size=8192' next build --no-lint",
    "bundle:analyze": "npm run build:analyze",
    "bundle:track": "node scripts/bundle-size-tracker.js",
    "start": "next start",
    "start:local": "node scripts/load-env.js && next start",
    "validate:env": "node scripts/validate-env.js",
    "validate:env:production": "NODE_ENV=production node scripts/validate-env.js",
    "validate:env:staging": "NODE_ENV=staging node scripts/validate-env.js",
    "validate:startup": "NODE_OPTIONS='--max-old-space-size=8192' npx ts-node -e \"require('./lib/startup-validation').validateApplicationStartup()\"",
    "validate:csp": "node scripts/validate-csp.js",
    "validate:security": "node scripts/validate-csp.js",
    "validate:railway": "bash scripts/pre-push-validation.sh",
    "validate:railway:full": "bash scripts/pre-push-validation.sh --full",
    "prebuild": "node scripts/validate-env.js",
    "lint": "NODE_OPTIONS='--max-old-space-size=8192' eslint . --cache --cache-location .next/cache/eslint/",
    "lint:fast": "NODE_OPTIONS='--max-old-space-size=8192' eslint . --ext .js,.jsx,.ts,.tsx --cache --cache-location .next/cache/eslint/ --max-warnings 0",
    "lint:fix": "NODE_OPTIONS='--max-old-space-size=8192' eslint . --ext .js,.jsx,.ts,.tsx --fix --cache --cache-location .next/cache/eslint/",
    "lint:production": "NODE_OPTIONS='--max-old-space-size=8192' eslint . --config .eslintrc.production.js --ext .js,.jsx,.ts,.tsx --max-warnings 0",
    "lint:clear-cache": "rm -rf .next/cache/eslint/",
    "lint:optimized": "node scripts/optimize-lint.js",
    "lint:optimized:fix": "node scripts/optimize-lint.js --fix",
    "lint:changed": "NODE_OPTIONS='--max-old-space-size=8192' eslint $(git diff --name-only --diff-filter=ACMR HEAD | grep -E '\\.(js|jsx|ts|tsx)$' | xargs) --cache --cache-location .next/cache/eslint/",
    "typecheck": "bash scripts/typecheck.sh",
    "typecheck:fast": "node scripts/typecheck-optimized.js fast",
    "typecheck:standard": "node scripts/typecheck-optimized.js standard",
    "typecheck:full": "node scripts/typecheck-optimized.js full",
    "typecheck:watch": "node scripts/typecheck-optimized.js watch",
    "typecheck:clean": "node scripts/typecheck-optimized.js clean",
    "tsc": "NODE_OPTIONS='--max-old-space-size=16384' tsc",
    "tsc:noEmit": "NODE_OPTIONS='--max-old-space-size=16384' tsc --noEmit",
    "check:quick": "bash scripts/quick-check.sh",
    "check:files": "NODE_OPTIONS='--max-old-space-size=4096' npx eslint",
    "check:cloudinary": "node scripts/check-cloudinary-config.js",
    "postinstall": "node -e \"if (process.env.SKIP_POSTINSTALL !== 'true') { require('child_process').execSync('npm run schema:merge && NODE_OPTIONS=\\\"--max-old-space-size=8192\\\" npx prisma generate', {stdio: 'inherit'}) }\" || echo 'Skipping postinstall'",
    "schema:analyze": "npx tsx scripts/categorize-schema-domains.ts",
    "schema:split": "npx tsx scripts/split-schema.ts",
    "schema:merge": "npx tsx scripts/merge-schema.ts",
    "schema:validate": "npm run schema:merge && npx prisma validate",
    "check-env": "node scripts/load-env.js",
    "env:production": "NODE_ENV=production node scripts/load-env.js",
    "env:development": "NODE_ENV=development node scripts/load-env.js",
    "build:production": "NODE_ENV=production npm run build",
    "build:railway": "bash scripts/migrate-production.sh && NODE_ENV=production npm run build",
    "migrate:production": "bash scripts/migrate-production.sh",
    "migrate:check": "npx prisma migrate status",
    "start:production": "NODE_ENV=production npm run start",
    "start:railway": "NODE_ENV=production node scripts/load-env.js && next start",
    "check-production": "node scripts/check-production-config.js",
    "test-dynamic-routes": "node scripts/test-dynamic-routes.js",
    "enterprise:validate": "node scripts/enterprise-deploy.js development",
    "enterprise:deploy:staging": "NODE_ENV=staging node scripts/enterprise-deploy.js staging",
    "enterprise:deploy:production": "NODE_ENV=production node scripts/enterprise-deploy.js production",
    "enterprise:health": "node -e \"require('./lib/enterprise-db').EnterpriseDB.healthCheck().then(console.log)\"",
    "enterprise:audit": "node -e \"require('./lib/enterprise-db').EnterpriseDB.getAuditInfo().then(console.log)\"",
    "db:init": "node scripts/init-db.js",
    "db:migrate": "npx prisma migrate deploy",
    "db:migrate:dev": "npx prisma migrate dev",
    "db:migrate:dry-run": "npx prisma migrate diff",
    "db:migrate:create": "npx prisma migrate dev --create-only",
    "db:migrate:railway": "node scripts/railway-migration-handler.js",
    "db:migrate:safe": "node scripts/railway-migration-handler.js --skip-backup",
    "db:fix:bio": "node scripts/fix-bio-location-fields.js",
    "db:fix:migrations": "node scripts/fix-failed-migrations.js",
    "db:push": "npx prisma db push",
    "db:push:safe": "npx prisma db push --skip-generate",
    "db:reset:production": "npx prisma migrate reset --force --skip-seed",
    "db:backup": "echo 'Database backup would be created here'",
    "db:rollback": "echo 'Database rollback would be executed here'",
    "analyze": "ANALYZE=true next build",
    "analyze:server": "BUNDLE_ANALYZE=server next build",
    "analyze:browser": "BUNDLE_ANALYZE=browser next build",
    "test": "jest --config jest.config.working.js",
    "test:watch": "jest --config jest.config.working.js --watch",
    "test:coverage": "jest --config jest.config.working.js --coverage",
    "test:ci": "NODE_OPTIONS='--max-old-space-size=8192 --expose-gc' jest --config jest.config.working.js --ci --runInBand",
    "test:unit": "NODE_OPTIONS='--max-old-space-size=4096' jest --config jest.config.unit.js --ci",
    "test:integration": "NODE_OPTIONS='--max-old-space-size=4096' jest --config jest.config.integration.js --ci",
    "test:all": "NODE_OPTIONS='--max-old-space-size=8192 --expose-gc' jest --config jest.config.working.js --ci --runInBand",
    "test:ci:verbose": "NODE_OPTIONS='--max-old-space-size=8192 --expose-gc' jest --config jest.config.working.js --ci --runInBand --logHeapUsage",
    "test:memory-safe": "node scripts/test-memory-safe.js",
    "test:diagnose": "node scripts/diagnose-memory.js",
    "test:debug": "jest --debug",
    "test:update-snapshots": "jest --updateSnapshot",
    "coverage:track": "node scripts/test-coverage-tracker.js",
    "test:fix": "npm test -- __tests__/components/course-card.test.tsx __tests__/components/ui/button.test.tsx",
    "dev:db:reset": "npx prisma db push --force-reset",
    "dev:db:seed": "npx tsx scripts/dev-seed.ts",
    "dev:db:studio": "npx prisma studio",
    "dev:setup": "npm run dev:db:reset && npm run dev:db:seed",
    "dev:setup:original": "bash scripts/setup-taxomind-original.sh",
    "dev:docker:start": "docker start taxomind-dev-db",
    "dev:docker:stop": "docker stop taxomind-dev-db",
    "dev:docker:reset": "docker stop taxomind-dev-db || true && docker rm taxomind-dev-db || true && docker run --name taxomind-dev-db -e POSTGRES_PASSWORD=dev_password_123 -e POSTGRES_DB=taxomind_dev -p 5433:5432 -d pgvector/pgvector:pg15",
    "security:audit": "node scripts/security-audit.js",
    "security:scan": "npm run security:audit && npm run pentest",
    "pentest": "node scripts/pentest-framework.js",
    "compliance:check": "npm run security:audit && npm run compliance:gdpr && npm run compliance:soc2",
    "compliance:gdpr": "curl -X GET http://localhost:3000/api/compliance/gdpr?action=compliance-report",
    "compliance:soc2": "curl -X GET http://localhost:3000/api/compliance/soc2/report?startDate=2024-01-01&endDate=2024-12-31",
    "owasp:scan": "npx @cyclonedx/cyclonedx-npm --output-file sbom.json && npx better-npm-audit audit",
    "audit:fix": "npm audit fix",
    "audit:fix:force": "npm audit fix --force",
    "prepare": "node -e \"if (process.env.NODE_ENV !== 'production' && process.env.CI !== 'true') { require('child_process').execSync('husky', {stdio: 'inherit'}) }\" || echo 'Skipping husky in production'",
    "observability:start": "docker-compose -f docker-compose.observability.yml up -d",
    "observability:stop": "docker-compose -f docker-compose.observability.yml down",
    "observability:logs": "docker-compose -f docker-compose.observability.yml logs -f",
    "observability:reset": "docker-compose -f docker-compose.observability.yml down -v && docker-compose -f docker-compose.observability.yml up -d",
    "gateway:health": "curl -X GET http://localhost:3000/api/health/gateway",
    "gateway:metrics": "curl -X GET http://localhost:3000/api/health/gateway/metrics",
    "sentry:setup": "node scripts/setup-sentry.js",
    "sentry:test": "echo 'Visit http://localhost:3000/sentry-test to test Sentry integration'",
    "queues:status": "node -e \"require('./lib/queue/queue-manager').QueueManager.getSystemHealth().then(console.log)\"",
    "queues:dashboard": "open http://localhost:3000/api/queues/dashboard",
    "circuit-breakers:status": "curl -X GET http://localhost:3000/api/health/circuit-breakers",
    "messaging:health": "node -e \"require('./lib/messaging/event-bus').EventBus.getHealth().then(console.log)\"",
    "db:replicas:status": "node -e \"require('./lib/db/db-replicas').DatabaseReplicaManager.getDatabaseStatus().then(console.log)\"",
    "architecture:health": "npm run gateway:health && npm run queues:status && npm run circuit-breakers:status && npm run messaging:health && npm run db:replicas:status",
    "admin:init": "tsx scripts/admin-cli.ts init",
    "admin:create": "tsx scripts/admin-cli.ts create",
    "admin:promote": "tsx scripts/admin-cli.ts promote",
    "admin:demote": "tsx scripts/admin-cli.ts demote",
    "admin:list": "tsx scripts/admin-cli.ts list",
    "capability:grant": "tsx scripts/capability-cli.ts grant",
    "capability:revoke": "tsx scripts/capability-cli.ts revoke",
    "capability:list": "tsx scripts/capability-cli.ts list",
    "sam:build": "bash scripts/sam-build-all.sh build",
    "sam:build:clean": "bash scripts/sam-build-all.sh rebuild",
    "sam:typecheck": "bash scripts/sam-build-all.sh typecheck",
    "sam:cron": "node scripts/sam-cron-runner.js",
    "sam:publish": "bash scripts/publish-sam-packages.sh",
    "sam:publish:dry": "bash scripts/publish-sam-packages.sh --dry-run",
    "sam:publish:patch": "bash scripts/publish-sam-packages.sh --version patch",
    "sam:publish:minor": "bash scripts/publish-sam-packages.sh --version minor",
    "sam:publish:beta": "bash scripts/publish-sam-packages.sh --tag beta"
  },
