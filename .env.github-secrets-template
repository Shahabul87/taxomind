# 🔐 GitHub Secrets Configuration Template
# Copy these values to your GitHub repository secrets

# ======================
# STAGING ENVIRONMENT
# ======================

# STAGING_DATABASE_URL
# Format: postgresql://username:password@host:port/database
# Example: postgresql://staging_user:staging_password@your-staging-db.com:5432/taxomind_staging
STAGING_DATABASE_URL=postgresql://staging_user:staging_password@your-staging-db-host:5432/taxomind_staging

# STAGING_NEXTAUTH_SECRET  
# Generate with: openssl rand -base64 32
STAGING_NEXTAUTH_SECRET=your-staging-nextauth-secret-here

# STAGING_NEXTAUTH_URL
# Your staging application URL
STAGING_NEXTAUTH_URL=https://your-staging-app.vercel.app

# ======================
# PRODUCTION ENVIRONMENT  
# ======================

# PROD_DATABASE_URL
# Format: postgresql://username:password@host:port/database
# Example: postgresql://prod_user:prod_password@your-prod-db.com:5432/taxomind_production
PROD_DATABASE_URL=postgresql://prod_user:prod_password@your-prod-db-host:5432/taxomind_production

# PROD_NEXTAUTH_SECRET
# Generate with: openssl rand -base64 32 (DIFFERENT from staging)
PROD_NEXTAUTH_SECRET=your-production-nextauth-secret-here

# PROD_NEXTAUTH_URL
# Your production application URL
PROD_NEXTAUTH_URL=https://your-production-app.com

# ======================
# ADDITIONAL SECRETS (Optional but Recommended)
# ======================

# Deployment tokens (if using Vercel/Railway/etc)
VERCEL_TOKEN=your-vercel-token
RAILWAY_TOKEN=your-railway-token

# External API keys for CI/CD
ANTHROPIC_API_KEY=your-anthropic-key-for-ci
OPENAI_API_KEY=your-openai-key-for-ci

# Monitoring and alerts
SENTRY_DSN=your-sentry-dsn
SLACK_WEBHOOK_URL=your-slack-webhook-for-alerts