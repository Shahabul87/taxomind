# ===========================================
# TAXOMIND LMS - Environment Variables
# ===========================================
# Complete configuration template for all environments
# Copy this file to .env.local and fill in your values

# ===========================================
# CORE APPLICATION SETTINGS (REQUIRED)
# ===========================================

# Application environment - controls security features and validation
NODE_ENV=development

# Database connection (REQUIRED)
# Development: Use local PostgreSQL on port 5433 (Docker container)
# Production: Use managed PostgreSQL service
DATABASE_URL="postgresql://user:password@localhost:5433/taxomind_dev"

# Public application URL (REQUIRED)
# Development: http://localhost:3000
# Production: https://your-domain.com
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Socket.io Server URL (REQUIRED for real-time features)
# Development: http://localhost:3001
# Production: wss://your-socket-server.com
NEXT_PUBLIC_SOCKET_URL=http://localhost:3001
SOCKET_PORT=3001

# ===========================================
# AUTHENTICATION (NextAuth.js) - REQUIRED IN PRODUCTION
# ===========================================

# NextAuth.js URL - should match NEXT_PUBLIC_APP_URL
NEXTAUTH_URL=http://localhost:3000

# JWT signing secrets (REQUIRED in production, min 32 characters)
# Generate with: openssl rand -base64 32
AUTH_SECRET=your-32-character-secret-key-here
NEXTAUTH_SECRET=your-32-character-secret-key-here

# Encryption master key for TOTP secrets and sensitive data (REQUIRED for MFA)
# Generate with: openssl rand -hex 32
# Must be exactly 64 characters (32 bytes in hex)
ENCRYPTION_MASTER_KEY=your-64-character-hex-key-for-totp-encryption-here

# ===========================================
# ADMIN MFA ENFORCEMENT SETTINGS (OPTIONAL)
# ===========================================

# Admin MFA enforcement configuration
# These settings control how MFA is enforced for admin users

# Enable/disable MFA enforcement for admin users (default: true)
ADMIN_MFA_ENFORCEMENT_ENABLED=true

# Grace period in days for new admin accounts to set up MFA (default: 7)
ADMIN_MFA_GRACE_PERIOD_DAYS=7

# Warning period in days before enforcement begins (default: 3)
ADMIN_MFA_WARNING_PERIOD_DAYS=3

# Require MFA immediately for new admin accounts (default: false)
# If true, new admin accounts must set up MFA before accessing admin features
ADMIN_MFA_IMMEDIATE_ENFORCEMENT=false

# ===========================================
# OAUTH PROVIDERS (OPTIONAL)
# ===========================================

# Google OAuth 2.0 (optional but both required if using Google auth)
# Get from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# GitHub OAuth App (optional but both required if using GitHub auth)
# Get from: https://github.com/settings/applications/new
GITHUB_CLIENT_ID=your_github_client_id_here
GITHUB_CLIENT_SECRET=your_github_client_secret_here

# ===========================================
# AI SERVICES (OPTIONAL)
# ===========================================

# OpenAI API (for GPT models and content generation)
# Get from: https://platform.openai.com/api-keys
# Format: sk-...
OPENAI_API_KEY=sk-your-openai-api-key-here
# Available models: gpt-4o (default), gpt-4o-mini, gpt-4-turbo, o1, o1-mini
OPENAI_MODEL=gpt-4o

# Anthropic API (for Claude AI models)
# Get from: https://console.anthropic.com/
# Format: sk-ant-...
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here

# DeepSeek API (for DeepSeek AI models - alternative provider)
# Get from: https://platform.deepseek.com/
# Format: sk-...
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here
# Available models: deepseek-chat, deepseek-reasoner (default)
DEEPSEEK_MODEL=deepseek-reasoner

# Google Gemini API (coming soon)
# Get from: https://ai.google.dev/
# GOOGLE_AI_API_KEY=your-google-ai-api-key-here

# Mistral API (coming soon)
# Get from: https://console.mistral.ai/
# MISTRAL_API_KEY=your-mistral-api-key-here

# ===========================================
# MEDIA STORAGE (CLOUDINARY) - OPTIONAL
# ===========================================
# All three variables required if using Cloudinary for image uploads

# Cloudinary cloud name (found in your dashboard)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloud_name_here

# Cloudinary API credentials (found in your dashboard)
CLOUDINARY_API_KEY=your_api_key_here
CLOUDINARY_API_SECRET=your_api_secret_here

# ===========================================
# CACHING & PERFORMANCE (REDIS) - REQUIRED IN PRODUCTION
# ===========================================

# Upstash Redis for caching and rate limiting
# Get from: https://console.upstash.com/redis
UPSTASH_REDIS_REST_URL=https://your-redis-url.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_redis_token_here

# Disable Redis in development (optional)
DISABLE_REDIS=true

# ===========================================
# EMAIL SERVICE (OPTIONAL)
# ===========================================

# Resend API for transactional emails
# Get from: https://resend.com/api-keys
# Format: re_...
RESEND_API_KEY=re_your_resend_api_key_here

# ===========================================
# PAYMENT PROCESSING (STRIPE) - OPTIONAL
# ===========================================
# Both keys required if enabling payments

# Stripe secret key (server-side)
# Development: sk_test_... | Production: sk_live_...
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here

# Stripe publishable key (client-side)
# Development: pk_test_... | Production: pk_live_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here

# Stripe webhook secret (for webhook endpoints)
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# ===========================================
# MONITORING & OBSERVABILITY (OPTIONAL)
# ===========================================

# Sentry Error Tracking & Performance Monitoring
# Get from: https://sentry.io/settings/[org]/projects/[project]/keys/
SENTRY_DSN=https://your_key@o0.ingest.sentry.io/your_project_id
NEXT_PUBLIC_SENTRY_DSN=https://your_key@o0.ingest.sentry.io/your_project_id

# Sentry organization and project (for source map uploads)
SENTRY_ORG=your_sentry_org_slug
SENTRY_PROJECT=taxomind-lms

# Sentry auth token (for CI/CD source map uploads)
# Generate at: https://sentry.io/settings/account/api/auth-tokens/
SENTRY_AUTH_TOKEN=sntrys_your_auth_token_here

# ===========================================
# NEWS & SEARCH APIS (OPTIONAL)
# ===========================================

# Enable real news fetching (auto-enabled in production)
USE_REAL_NEWS=false

# NewsAPI.org (free tier available)
# Get from: https://newsapi.org/register
NEWS_API_KEY=your_newsapi_key_here

# Microsoft Bing News Search API
# Get from: https://www.microsoft.com/en-us/bing/apis/bing-news-search-api
BING_API_KEY=your_bing_api_key_here

# Google Custom Search API
# Get from: https://developers.google.com/custom-search/v1/overview
GOOGLE_SEARCH_API_KEY=your_google_search_api_key_here
GOOGLE_SEARCH_ENGINE_ID=your_google_search_engine_id_here

# ===========================================
# SECURITY & CSP CONFIGURATION
# ===========================================

# Content Security Policy report endpoint
# Where CSP violations will be reported
# Development: http://localhost:3000/api/security/csp-report
# Production: https://your-domain.com/api/security/csp-report
CSP_REPORT_URI=http://localhost:3000/api/security/csp-report

# Security webhook for critical CSP violations (optional)
# Slack webhook or other monitoring service URL
SECURITY_WEBHOOK_URL=

# ===========================================
# ENTERPRISE & PRODUCTION FEATURES
# ===========================================

# Enable strict environment mode (REQUIRED in production/staging)
# Enables additional security checks and production data protection
STRICT_ENV_MODE=false

# Block cross-environment operations (staging/production)
BLOCK_CROSS_ENV=false

# Enable audit logging (enterprise feature)
AUDIT_ENABLED=false

# ===========================================
# DEVELOPMENT & DEBUGGING
# ===========================================

# OpenTelemetry tracing (optional)
OTEL_SERVICE_NAME=taxomind-lms
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318/v1/traces
OTEL_EXPORTER_OTLP_HEADERS={}
ENABLE_OTEL=false

# Prometheus metrics authentication
METRICS_AUTH_TOKEN=your_metrics_token_here

# ===========================================
# DEPLOYMENT ENVIRONMENT DETECTION
# ===========================================
# These are automatically set by hosting providers

# Railway deployment (auto-detected)
# RAILWAY_ENVIRONMENT=production
# RAILWAY_PUBLIC_DOMAIN=your-app.railway.app
# RAILWAY_PROJECT_ID=automatically_set_by_railway

# Vercel deployment (auto-detected)
# VERCEL=1
# VERCEL_ENV=production
# VERCEL_URL=your-app.vercel.app

# ===========================================
# VALIDATION NOTES
# ===========================================
# - Run "npm run validate:env" to check your configuration
# - Production requires: DATABASE_URL, AUTH_SECRET, NEXTAUTH_URL, STRICT_ENV_MODE=true
# - OAuth providers: If CLIENT_ID is set, CLIENT_SECRET is required
# - Cloudinary: All three variables required if any is set
# - Stripe: Both keys required if either is set
# - URLs must not contain localhost in production/staging environments
# - API keys must match expected formats (validation applied)
# ===========================================
# EMAIL CONFIGURATION (SMTP)
# ===========================================
# SMTP email service for sending verification emails, password resets, etc.
# Configure with your preferred SMTP provider (Gmail, SendGrid, Mailgun, etc.)
# See SMTP_SETUP_GUIDE.md for detailed configuration instructions

# SMTP Server Configuration
SMTP_HOST=smtp.gmail.com                    # SMTP server hostname
SMTP_PORT=587                                # SMTP port (587 for TLS, 465 for SSL)
SMTP_SECURE=false                            # true for SSL (port 465), false for TLS (port 587)

# SMTP Authentication
SMTP_USER=your-email@gmail.com               # SMTP username (usually your email)
SMTP_PASSWORD=your-app-password              # SMTP password or app-specific password
SMTP_FROM=your-email@gmail.com               # Sender email address (optional, defaults to SMTP_USER)

# Provider-Specific Examples:
# Gmail:     SMTP_HOST=smtp.gmail.com, PORT=587, Use App Password
# Outlook:   SMTP_HOST=smtp-mail.outlook.com, PORT=587
# SendGrid:  SMTP_HOST=smtp.sendgrid.net, PORT=587, USER=apikey
# Mailgun:   SMTP_HOST=smtp.mailgun.org, PORT=587
# AWS SES:   SMTP_HOST=email-smtp.REGION.amazonaws.com, PORT=587

# ===========================================
# SAM AI AGENTIC FEATURES
# ===========================================
# SAM AI is an intelligent tutoring system with agentic capabilities.
# These feature flags control which SAM features are enabled.
#
# NOTE: In development mode, core features (ORCHESTRATION, INTERVENTIONS,
# OBSERVABILITY) are ENABLED by default even without these env vars.
# In production, ALL features are DISABLED by default for safety.

# --- CORE FEATURES (Recommended to enable) ---

# Plan-driven tutoring with step execution and session resumption
# Enables: Active learning plans, step tracking, "welcome back" context
SAM_ORCHESTRATION_ACTIVE=true

# Proactive check-ins and behavior monitoring
# Enables: Scheduled check-ins, anomaly detection, personalized interventions
SAM_INTERVENTIONS_ENABLED=true

# Telemetry, metrics, and quality tracking
# Enables: Tool execution logging, confidence calibration, Prometheus export
SAM_OBSERVABILITY=true

# --- ADVANCED FEATURES (Optional, require additional setup) ---

# Real-time WebSocket communication (requires socket server)
# Enables: Live presence tracking, real-time intervention delivery
# Setup: Run `npm run socket:dev` alongside `npm run dev`
SAM_WEBSOCKET_ENABLED=false
# WebSocket server URL (required if SAM_WEBSOCKET_ENABLED=true)
# Development: ws://localhost:3001/ws/sam
# Production: wss://your-domain.com/ws/sam
NEXT_PUBLIC_WS_URL=

# Role-based access control for tool execution
# Enables: Permission checks, admin tool management, audit logging
SAM_TOOL_PERMISSIONS=false

# Automatic memory refresh on content changes
# Enables: Auto-reindex embeddings, knowledge graph refresh, memory decay
SAM_MEMORY_LIFECYCLE=false
