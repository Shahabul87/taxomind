  deepseekGenerations   Int           @default(0)
  deepseekCost          Float         @default(0)
  openaiGenerations     Int           @default(0)
  openaiCost            Float         @default(0)
  geminiGenerations     Int           @default(0)
  geminiCost            Float         @default(0)
  mistralGenerations    Int           @default(0)
  mistralCost           Float         @default(0)

  // Usage by Type
  courseGenerations     Int           @default(0)
  chatGenerations       Int           @default(0)
  analysisGenerations   Int           @default(0)
