enum SAMJobStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

enum SAMJobType {
  REINDEX
  KG_REFRESH
  MEMORY_CLEANUP
  EMBEDDING_GENERATION
}

model SAMBackgroundJob {
  id             String        @id @default(cuid())
