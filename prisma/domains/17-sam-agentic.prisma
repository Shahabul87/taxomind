  // Relations
  user                User                       @relation("SAMConfidenceScores", fields: [userId], references: [id], onDelete: Cascade)

  @@index([responseType, predictedAt])
  @@index([userId, predictedAt])
  @@index([accurate, predictedAt])
  @@map("sam_confidence_scores")
}

// Memory retrieval telemetry
