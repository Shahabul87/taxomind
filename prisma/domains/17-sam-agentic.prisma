// ==========================================
// SAM Agentic AI Mentor Domain
// ==========================================
// Autonomous goal planning, execution, behavior
// monitoring, and proactive interventions
//
// Total Models: 26
// Priority: 9
// ==========================================

// ==========================================
// GOAL PLANNING MODELS
// ==========================================

model SAMLearningGoal {
  id           String               @id @default(cuid())
  userId       String
  title        String
  description  String?
  targetDate   DateTime?
  priority     SAMGoalPriority      @default(MEDIUM)
  status       SAMGoalStatus        @default(DRAFT)

  // Context
  courseId     String?
  chapterId    String?
  sectionId    String?
  topicIds     String[]             @default([])
  skillIds     String[]             @default([])

  // Mastery
  currentMastery SAMMasteryLevel?
  targetMastery  SAMMasteryLevel?

  // Metadata
  tags         String[]             @default([])
  metadata     Json?

  // Timestamps
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  completedAt  DateTime?

  // Relations
  user         User                 @relation("SAMLearningGoals", fields: [userId], references: [id], onDelete: Cascade)
  course       Course?              @relation("SAMGoalCourses", fields: [courseId], references: [id], onDelete: Cascade)
  chapter      Chapter?             @relation("SAMGoalChapters", fields: [chapterId], references: [id], onDelete: Cascade)
  section      Section?             @relation("SAMGoalSections", fields: [sectionId], references: [id], onDelete: Cascade)
  subGoals     SAMSubGoal[]
  plans        SAMExecutionPlan[]

  @@index([userId, status])
  @@index([userId, priority])
  @@index([courseId])
  @@map("sam_learning_goals")
}

model SAMSubGoal {
  id               String          @id @default(cuid())
  goalId           String
  title            String
  description      String?
  type             SAMSubGoalType  @default(LEARN)
  order            Int             @default(0)

  // Effort estimation
  estimatedMinutes Int             @default(30)
  difficulty       SAMDifficulty   @default(MEDIUM)

  // Dependencies
  prerequisites    String[]        @default([])
  successCriteria  String[]        @default([])

  // Status
  status           SAMStepStatus   @default(PENDING)
  completedAt      DateTime?

  // Metadata
  metadata         Json?

  // Relations
  goal             SAMLearningGoal @relation(fields: [goalId], references: [id], onDelete: Cascade)
  steps            SAMPlanStep[]

  @@index([goalId, order])
  @@map("sam_sub_goals")
}

model SAMExecutionPlan {
  id              String          @id @default(cuid())
  goalId          String
  userId          String

  // Schedule
  startDate       DateTime?
  targetDate      DateTime?

  // Progress
  currentStepId   String?
  overallProgress Float           @default(0)

  // State
  status          SAMPlanStatus   @default(DRAFT)
  pausedAt        DateTime?

  // Checkpoint data for resumability
  checkpointData  Json?

  // Schedule breakdown (JSON for flexibility)
  schedule        Json?

  // Fallback strategies (JSON array)
  fallbackStrategies Json?

  // Timestamps
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  completedAt     DateTime?

  // Relations
  goal            SAMLearningGoal @relation(fields: [goalId], references: [id], onDelete: Cascade)
  user            User            @relation("SAMExecutionPlans", fields: [userId], references: [id], onDelete: Cascade)
  steps           SAMPlanStep[]
  checkpoints     SAMCheckpoint[]
  state           SAMPlanState?

  @@index([goalId])
  @@index([userId, status])
  @@map("sam_execution_plans")
}

model SAMPlanStep {
  id               String          @id @default(cuid())
  planId           String
  subGoalId        String?

  type             SAMStepType     @default(READ_CONTENT)
  title            String
  description      String?
  order            Int             @default(0)

  // Execution
  status           SAMStepStatus   @default(PENDING)
  startedAt        DateTime?
  completedAt      DateTime?

  // Time tracking
  estimatedMinutes Int             @default(15)
  actualMinutes    Int?

  // Retry handling
  retryCount       Int             @default(0)
  maxRetries       Int             @default(3)
  lastError        String?

  // Input/Output (JSON for flexibility)
  inputs           Json?
  outputs          Json?

  // Execution context
  executionContext Json?

  // Metadata
  metadata         Json?

  // Relations
  plan             SAMExecutionPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  subGoal          SAMSubGoal?     @relation(fields: [subGoalId], references: [id], onDelete: SetNull)

  @@index([planId, order])
  @@index([status])
  @@map("sam_plan_steps")
}

model SAMPlanState {
  id                  String           @id @default(cuid())
  planId              String           @unique
  goalId              String
  userId              String

  // Current position
  currentStepId       String?
  currentStepProgress Float            @default(0)

  // Completed work
  completedSteps      String[]         @default([])
  failedSteps         String[]         @default([])
  skippedSteps        String[]         @default([])

  // Timing
  startedAt           DateTime         @default(now())
  pausedAt            DateTime?
  lastActiveAt        DateTime         @default(now())
  totalActiveTime     Int              @default(0)

  // Context (JSON for flexibility)
  context             Json?

  // Checkpoint data
  checkpointData      Json?

  // Session info
  sessionCount        Int              @default(0)
  currentSessionStart DateTime?

  // Timestamps
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  // Relations
  plan                SAMExecutionPlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@index([userId, lastActiveAt])
  @@map("sam_plan_states")
}

model SAMCheckpoint {
  id          String           @id @default(cuid())
  planId      String
  stepId      String
  name        String
  description String?
  type        SAMCheckpointType @default(PROGRESS)
  targetDate  DateTime?
  achieved    Boolean          @default(false)
  achievedAt  DateTime?

  // Relations
  plan        SAMExecutionPlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@index([planId])
  @@map("sam_checkpoints")
}

// ==========================================
// PROACTIVE INTERVENTION MODELS
// ==========================================

model SAMScheduledCheckIn {
  id               String              @id @default(cuid())
  userId           String
  type             SAMCheckInType      @default(DAILY_REMINDER)
  scheduledTime    DateTime
  status           SAMCheckInStatus    @default(SCHEDULED)

  // Content
  message          String
  questions        Json?
  suggestedActions Json?

  // Channel
  channel          SAMNotificationChannel @default(IN_APP)

  // Context
  planId           String?
  courseId         String?
  priority         SAMCheckInPriority  @default(MEDIUM)
  expiresAt        DateTime?

  // Trigger conditions (JSON array)
  triggerConditions Json?

  // Timestamps
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  // Relations
  user             User                @relation("SAMScheduledCheckIns", fields: [userId], references: [id], onDelete: Cascade)
  responses        SAMCheckInResponse[]

  @@index([userId, status])
  @@index([scheduledTime])
  @@map("sam_scheduled_check_ins")
}

model SAMCheckInResponse {
  id            String              @id @default(cuid())
  checkInId     String
  respondedAt   DateTime            @default(now())
  answers       Json?
  selectedActions String[]          @default([])
  feedback      String?
  emotionalState String?

  // Relations
  checkIn       SAMScheduledCheckIn @relation(fields: [checkInId], references: [id], onDelete: Cascade)

  @@index([checkInId])
  @@map("sam_check_in_responses")
}

model SAMBehaviorEvent {
  id           String               @id @default(cuid())
  userId       String
  sessionId    String
  timestamp    DateTime             @default(now())

  type         SAMBehaviorEventType @default(PAGE_VIEW)
  data         Json

  // Context (JSON for flexibility)
  pageContext  Json?
  emotionalSignals Json?

  // Processing status
  processed    Boolean              @default(false)
  processedAt  DateTime?

  // Relations
  user         User                 @relation("SAMBehaviorEvents", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, timestamp])
  @@index([sessionId])
  @@index([processed])
  @@map("sam_behavior_events")
}

model SAMBehaviorPattern {
  id              String           @id @default(cuid())
  userId          String
  type            SAMPatternType   @default(LEARNING_HABIT)
  name            String
  description     String?

  // Pattern details
  frequency       Float            @default(0)
  duration        Float            @default(0)
  confidence      Float            @default(0)

  // Context (JSON array)
  contexts        Json?

  // Tracking
  firstObservedAt DateTime         @default(now())
  lastObservedAt  DateTime         @default(now())
  occurrences     Int              @default(0)

  // Relations
  user            User             @relation("SAMBehaviorPatterns", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, type])
  @@map("sam_behavior_patterns")
}

model SAMIntervention {
  id              String                @id @default(cuid())
  userId          String
  type            SAMInterventionType   @default(ENCOURAGEMENT)
  priority        SAMInterventionPriority @default(MEDIUM)
  message         String
  suggestedActions Json?

  // Timing (JSON for flexibility)
  timing          Json?

  // Execution
  createdAt       DateTime              @default(now())
  executedAt      DateTime?

  // Result (JSON for flexibility)
  result          Json?

  // Relations
  user            User                  @relation("SAMInterventions", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([type])
  @@map("sam_interventions")
}

// ==========================================
// LEARNING ANALYTICS MODELS
// ==========================================

model SAMTopicProgress {
  id                   String           @id @default(cuid())
  topicId              String
  topicName            String
  userId               String

  masteryLevel         SAMMasteryLevel  @default(NOVICE)
  masteryScore         Float            @default(0)
  completionPercentage Float            @default(0)
  timeSpent            Int              @default(0)
  sessionsCount        Int              @default(0)
  lastAccessedAt       DateTime         @default(now())
  startedAt            DateTime         @default(now())

  // Concepts tracking
  conceptsLearned      String[]         @default([])
  conceptsInProgress   String[]         @default([])
  conceptsNotStarted   String[]         @default([])

  // Trend
  trend                SAMTrendDirection @default(STABLE)
  trendScore           Float            @default(0)

  // Relations
  user                 User             @relation("SAMTopicProgress", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, topicId])
  @@index([userId, masteryLevel])
  @@map("sam_topic_progress")
}

model SAMLearningGap {
  id              String              @id @default(cuid())
  userId          String
  conceptId       String
  conceptName     String
  topicId         String
  severity        SAMGapSeverity      @default(MODERATE)
  detectedAt      DateTime            @default(now())
  evidence        Json?
  suggestedActions String[]           @default([])
  isResolved      Boolean             @default(false)
  resolvedAt      DateTime?

  // Relations
  user            User                @relation("SAMLearningGaps", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isResolved])
  @@index([topicId])
  @@map("sam_learning_gaps")
}

model SAMSkillAssessment {
  id            String             @id @default(cuid())
  userId        String
  skillId       String
  skillName     String
  level         SAMMasteryLevel    @default(NOVICE)
  score         Float              @default(0)
  confidence    Float              @default(0)
  source        SAMAssessmentSource @default(AI_EVALUATION)
  evidence      Json?
  assessedAt    DateTime           @default(now())
  validUntil    DateTime?
  previousLevel SAMMasteryLevel?
  previousScore Float?

  // Relations
  user          User               @relation("SAMSkillAssessments", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, skillId])
  @@index([assessedAt])
  @@map("sam_skill_assessments")
}

model SAMRecommendation {
  id              String                    @id @default(cuid())
  userId          String
  type            SAMRecommendationType     @default(ARTICLE)
  priority        SAMRecommendationPriority @default(MEDIUM)
  reason          SAMRecommendationReason   @default(KNOWLEDGE_GAP)
  title           String
  description     String?
  targetSkillId   String?
  targetConceptId String?
  estimatedDuration Int                     @default(15)
  difficulty      SAMDifficulty             @default(MEDIUM)
  confidence      Float                     @default(0.5)
  resourceUrl     String?
  resourceId      String?
  prerequisites   String[]                  @default([])
  createdAt       DateTime                  @default(now())
  expiresAt       DateTime?
  isViewed        Boolean                   @default(false)
  isCompleted     Boolean                   @default(false)
  userRating      Int?

  // Relations
  user            User                      @relation("SAMRecommendations", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isViewed, isCompleted])
  @@index([priority])
  @@map("sam_recommendations")
}

model SAMAgenticSession {
  id                String   @id @default(cuid())
  userId            String
  topicId           String?
  topicName         String?
  startTime         DateTime @default(now())
  endTime           DateTime?
  duration          Int      @default(0)
  activitiesCompleted Int    @default(0)
  questionsAnswered Int      @default(0)
  correctAnswers    Int      @default(0)
  conceptsCovered   String[] @default([])
  focusScore        Float?

  // Relations
  user              User     @relation("SAMAgenticSessions", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, startTime])
  @@index([topicId])
  @@map("sam_agentic_sessions")
}

// ==========================================
// AGENTIC LEARNING SESSION
// ==========================================

model SAMLearningSession {
  id                  String   @id @default(cuid())
  userId              String
  topicId             String
  startTime           DateTime @default(now())
  endTime             DateTime?
  duration            Int      @default(0)
  activitiesCompleted Int      @default(0)
  questionsAnswered   Int      @default(0)
  correctAnswers      Int      @default(0)
  conceptsCovered     String[] @default([])
  focusScore          Float?

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, topicId])
  @@index([userId, startTime])
  @@map("sam_learning_sessions")
}

// ==========================================
// AGENTIC MEMORY MODELS
// ==========================================

model SAMVectorEmbedding {
  id             String   @id @default(cuid())
  sourceId       String
  sourceType     String   // 'content', 'concept', 'question', 'memory', 'conversation'
  userId         String?
  courseId       String?
  chapterId      String?
  sectionId      String?
  contentHash    String
  contentText    String?  @db.Text  // Original text for reference
  tags           String[] @default([])
  language       String?
  customMetadata Json?

  // Embedding stored as JSON array (compatible with standard PostgreSQL)
  // When pgvector is available, use embedding_vector column for native search
  embedding      Json?
  dimensions     Int      @default(1536)

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user           User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  course         Course?  @relation(fields: [courseId], references: [id], onDelete: Cascade)
  chapter        Chapter? @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  section        Section? @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  @@index([userId, sourceType])
  @@index([courseId])
  @@index([contentHash])
  @@map("sam_vector_embeddings")
}

// Long-term memory entries with semantic search capability
model SAMLongTermMemory {
  id             String   @id @default(cuid())
  userId         String

  // Memory content
  type           SAMMemoryType @default(INTERACTION)
  title          String
  content        String   @db.Text
  summary        String?  @db.Text

  // Context
  courseId       String?
  chapterId      String?
  sectionId      String?
  topicIds       String[] @default([])

  // Importance & Retention
  importance     SAMMemoryImportance @default(MEDIUM)
  emotionalValence Float?  // -1 to 1 (negative to positive)
  accessCount    Int      @default(0)
  lastAccessedAt DateTime?

  // Decay & Consolidation (for memory management)
  decayFactor    Float    @default(1.0)  // 0 = forgotten, 1 = fresh
  isConsolidated Boolean  @default(false)
  consolidatedAt DateTime?

  // Embedding stored as JSON array (compatible with standard PostgreSQL)
  embedding      Json?
  embeddingModel String?  @default("text-embedding-ada-002")

  // Metadata
  tags           String[] @default([])
  metadata       Json?

  // Timestamps
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  expiresAt      DateTime?

  // Relations
  user           User     @relation("SAMLongTermMemories", fields: [userId], references: [id], onDelete: Cascade)
  course         Course?  @relation("SAMLongTermMemoryCourses", fields: [courseId], references: [id], onDelete: SetNull)

  @@index([userId, type])
  @@index([userId, importance])
  @@index([courseId])
  @@index([createdAt])
  @@map("sam_long_term_memories")
}

// Conversation memory for multi-turn context
model SAMConversationMemory {
  id             String   @id @default(cuid())
  userId         String
  sessionId      String

  // Message content
  role           SAMMessageRole @default(USER)
  content        String   @db.Text

  // Context window management
  turnNumber     Int
  tokenCount     Int      @default(0)

  // Embedding stored as JSON array (compatible with standard PostgreSQL)
  embedding      Json?

  // Extracted entities & intents
  entities       Json?    // [{type, value, confidence}]
  intent         String?
  sentiment      Float?   // -1 to 1

  // Metadata
  metadata       Json?

  // Timestamps
  createdAt      DateTime @default(now())

  // Relations
  user           User     @relation("SAMConversationMemories", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, sessionId])
  @@index([sessionId, turnNumber])
  @@index([createdAt])
  @@map("sam_conversation_memories")
}

model SAMKnowledgeNode {
  id            String   @id @default(cuid())
  type          String
  name          String
  description   String?
  properties    Json?
  embeddings    String[] @default([])

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  outgoingEdges SAMKnowledgeEdge[] @relation("SAMKnowledgeEdgeFrom")
  incomingEdges SAMKnowledgeEdge[] @relation("SAMKnowledgeEdgeTo")

  @@index([type, name])
  @@map("sam_knowledge_nodes")
}

model SAMKnowledgeEdge {
  id         String   @id @default(cuid())
  type       String
  sourceId   String
  targetId   String
  weight     Float    @default(1)
  properties Json?
  createdAt  DateTime @default(now())

  source     SAMKnowledgeNode @relation("SAMKnowledgeEdgeFrom", fields: [sourceId], references: [id], onDelete: Cascade)
  target     SAMKnowledgeNode @relation("SAMKnowledgeEdgeTo", fields: [targetId], references: [id], onDelete: Cascade)

  @@index([sourceId])
  @@index([targetId])
  @@map("sam_knowledge_edges")
}

model SAMSessionContext {
  id           String   @id @default(cuid())
  userId       String
  courseId     String?
  lastActiveAt DateTime @default(now())
  currentState Json
  history      Json?
  preferences  Json
  insights     Json

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  course       Course?  @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([userId, courseId])
  @@map("sam_session_contexts")
}

// ==========================================
// AGENTIC TOOLING MODELS
// ==========================================

model AgentTool {
  id                  String   @id
  name                String
  description         String
  category            String
  version             String
  inputSchema         String   @db.Text
  outputSchema        String?  @db.Text
  requiredPermissions String[] @default([])
  confirmationType    String
  timeoutMs           Int?
  maxRetries          Int?
  rateLimit           String?  @db.Text
  tags                String[] @default([])
  examples            String?  @db.Text
  metadata            String?  @db.Text
  enabled             Boolean  @default(true)
  deprecated          Boolean  @default(false)
  deprecationMessage  String?

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  invocations         AgentToolInvocation[]
  confirmations       AgentConfirmation[]
  permissions         AgentPermission[]
  auditLogs           AgentAuditLog[]

  @@index([category])
  @@index([enabled])
  @@map("agent_tools")
}

model AgentToolInvocation {
  id                  String   @id @default(cuid())
  toolId              String
  userId              String
  sessionId           String
  input               String?  @db.Text
  validatedInput      String?  @db.Text
  status              String
  confirmationType    String
  confirmationPrompt  String?
  userConfirmed       Boolean?
  confirmedAt         DateTime?
  startedAt           DateTime?
  completedAt         DateTime?
  duration            Int?
  result              String?  @db.Text
  metadata            String?  @db.Text

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  tool                AgentTool @relation(fields: [toolId], references: [id], onDelete: Cascade)
  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  confirmations       AgentConfirmation[]
  auditLogs           AgentAuditLog[]

  @@index([userId, createdAt])
  @@index([toolId, status])
  @@map("agent_tool_invocations")
}

model AgentAuditLog {
  id           String   @id @default(cuid())
  timestamp    DateTime @default(now())
  level        String
  action       String
  userId       String
  sessionId    String
  toolId       String?
  invocationId String?
  input        String?  @db.Text
  output       String?  @db.Text
  error        String?  @db.Text
  ipAddress    String?
  userAgent    String?
  requestId    String?
  metadata     String?  @db.Text

  user         User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  tool         AgentTool?        @relation(fields: [toolId], references: [id], onDelete: SetNull)
  invocation   AgentToolInvocation? @relation(fields: [invocationId], references: [id], onDelete: SetNull)

  @@index([userId, timestamp])
  @@index([toolId])
  @@map("agent_audit_logs")
}

model AgentPermission {
  id         String   @id @default(cuid())
  userId     String
  toolId     String?
  category   String?
  levels     String[] @default([])
  grantedBy  String?
  grantedAt  DateTime @default(now())
  expiresAt  DateTime?
  conditions String?  @db.Text

  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tool       AgentTool? @relation(fields: [toolId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([toolId])
  @@map("agent_permissions")
}

model AgentConfirmation {
  id           String   @id @default(cuid())
  invocationId String
  toolId       String
  toolName     String
  userId       String
  title        String
  message      String
  details      String?  @db.Text
  type         String
  severity     String
  confirmText  String?
  cancelText   String?
  timeout      Int?
  status       String
  respondedAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  expiresAt    DateTime?

  invocation   AgentToolInvocation @relation(fields: [invocationId], references: [id], onDelete: Cascade)
  tool         AgentTool           @relation(fields: [toolId], references: [id], onDelete: Cascade)
  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([invocationId])
  @@map("agent_confirmations")
}
