// Integrity Check - Academic integrity verification
model SAMIntegrityCheck {
  id                 String    @id @default(cuid())
  userId             String
  assignmentId       String?

  // Content
  contentHash        String    // Hash of the checked content
  contentLength      Int       @default(0)

  // Check types performed
  checkTypes         String[]  @default([]) // ['plagiarism', 'ai-detection', 'consistency']

  // Plagiarism detection
  plagiarismScore    Float?    // 0-100 (0 = original, 100 = fully plagiarized)
  plagiarismMatches  Json?     // Array of {source, matchPercentage, matchedText}

  // AI content detection
  aiDetectionScore   Float?    // 0-100 (0 = human, 100 = AI-generated)
  aiIndicators       Json?     // {perplexity, burstiness, repetition, etc.}

  // Writing consistency
  consistencyScore   Float?    // 0-100 (comparison with previous work)
  consistencyAnalysis Json?    // {styleMetrics, anomalies}

  // Overall verdict
  overallVerdict     SAMIntegrityVerdict @default(PENDING)
  riskLevel          SAMIntegrityRisk    @default(LOW)

  // Details
  details            Json?     // Full analysis details
  recommendations    String[]  @default([])

  // Timestamps
  checkedAt          DateTime  @default(now())
  createdAt          DateTime  @default(now())

  // Relations
  user               User      @relation("SAMIntegrityChecks", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, checkedAt])
  @@index([assignmentId])
  @@index([contentHash])
  @@index([overallVerdict])
  @@map("sam_integrity_checks")
}

enum SAMIntegrityVerdict {
  PENDING
  PASSED
  REVIEW_NEEDED
  FLAGGED
  FAILED
}

enum SAMIntegrityRisk {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

// Multimodal Input - Processing various input types
model SAMMultimodalInput {
  id                 String    @id @default(cuid())
  userId             String

  // Input details
  inputType          SAMInputType @default(TEXT)
  content            String    @db.Text  // Base64 for binary, text for text
  contentSize        Int       @default(0)
  mimeType           String?

  // Context
  courseId           String?
  topicId            String?
  questionId         String?

  // Processing status
  status             SAMProcessingStatus @default(PENDING)
  processedAt        DateTime?

  // Processing results
  extractedText      String?   @db.Text
  analysis           Json?     // Type-specific analysis results
  confidence         Float?    // Processing confidence 0-1

  // Accessibility
  transcription      String?   @db.Text  // For audio/video
  altText            String?   @db.Text  // For images

  // Error handling
  error              String?   @db.Text

  // Metadata
  metadata           Json?

  // Timestamps
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  // Relations
  user               User      @relation("SAMMultimodalInputs", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, inputType])
  @@index([status])
  @@index([courseId])
  @@map("sam_multimodal_inputs")
}

enum SAMInputType {
  TEXT
  VOICE
  IMAGE
  VIDEO
  DRAWING
  DOCUMENT
  CODE
}

enum SAMProcessingStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

// ==========================================
// USER DEVICE TOKEN FOR PUSH NOTIFICATIONS
// ==========================================

enum DevicePlatform {
  IOS
  ANDROID
  WEB
}

model UserDeviceToken {
  id          String         @id @default(cuid())
  userId      String
  token       String         @unique
  platform    DevicePlatform @default(WEB)
  deviceName  String?
  isActive    Boolean        @default(true)

  // Metadata
  userAgent   String?
  lastUsedAt  DateTime       @default(now())

  // Timestamps
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  // Relations
  user        User           @relation("UserDeviceTokens", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isActive])
  @@index([token])
  @@map("user_device_tokens")
}
