  // Phase 5: Market Integration - Portfolio Projects (added January 2026)
  samPortfolioProjects     SAMPortfolioProject[]   @relation("SAMPortfolioProjectCourses")

  // Phase 7: 10,000 Hour Practice Tracking Relations
  practiceSessions         PracticeSession[]       @relation("CoursePracticeSessions")

  // Phase 3: Enterprise Payment System - Payment Transaction Relations
  paymentTransactions      PaymentTransaction[]    @relation("CoursePaymentTransactions")

  @@index([categoryId])
  @@index([organizationId])
}

// Course-Skill Mapping (Phase 3 SAM Fixes - January 2026)
// Links courses to skills with difficulty level and order
model CourseSkill {
  id          String           @id @default(cuid())
  courseId    String
  skillId     String
  level       CourseSkillLevel @default(BEGINNER)
  order       Int              @default(0)
  isCoreSkill Boolean          @default(false)
  createdAt   DateTime         @default(now())

  course      Course           @relation("CourseCourseSkills", fields: [courseId], references: [id], onDelete: Cascade)
  skill       Skill            @relation("SkillCourseSkills", fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([courseId, skillId])
  @@index([courseId])
  @@index([skillId])
}

model Attachment {
  id              String   @id @default(uuid())
  name            String
  url             String
  courseId         String
  fileId           String?
  fileSize         Int?
  mimeType         String?
  storageProvider  String   @default("google-drive")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  course          Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([courseId])
}

