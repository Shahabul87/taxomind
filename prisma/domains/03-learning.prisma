  updatedAt                    DateTime                       @updatedAt
  whatYouWillLearn             String[]                       @default([])
  slug                         String?
  subtitle                     String?
  isFeatured                   Boolean                        @default(false)
  organizationId               String?
  // Phase 2 Week 5 - Additional course metadata
  prerequisites                String?                        @db.Text
  difficulty                   String?
  totalDuration                Int?
  originalPrice                Float?
  dealEndDate                  DateTime?
  averageRating                Float?
  // Phase 3 - Enterprise Payment System
  isFree                       Boolean?                       @default(false)
  priceType                    String?                        @default("ONE_TIME")
  AIGeneratedContent           AIGeneratedContent[]
  attachments                  Attachment[]
  BloomsPerformanceMetric      BloomsPerformanceMetric[]
  certifications               Certification[]
  chapters                     Chapter[]
  category                     Category?                      @relation(fields: [categoryId], references: [id])
  subcategoryId                String?
  subcategory                  Category?                      @relation("SubcategoryCourses", fields: [subcategoryId], references: [id])
  organization                 Organization?                  @relation("OrganizationCourses", fields: [organizationId], references: [id])
  user                         User                           @relation(fields: [userId], references: [id], onDelete: Cascade)
  CourseBloomsAnalysis         CourseBloomsAnalysis?
  CourseCompetitor             CourseCompetitor[]
  CourseGuideAnalysis          CourseGuideAnalysis?
  CourseMarketAnalysis         CourseMarketAnalysis?
  CourseOptimizationSuggestion CourseOptimizationSuggestion[]
  reviews                      CourseReview[]
  Enrollment                   Enrollment[]
  Group                        Group[]
  MultiMediaAnalysis           MultiMediaAnalysis[]
  MultiModalAnalysis           MultiModalAnalysis[]
  PredictiveLearningAnalysis   PredictiveLearningAnalysis[]
  PricingExperiment            PricingExperiment[]
  Purchase                     Purchase[]
  QuestionBank                 QuestionBank[]
  StudentBloomsProgress        StudentBloomsProgress[]
  TeacherInsights              TeacherInsights[]
  learning_metrics             learning_metrics[]
  learning_sessions            learning_sessions[]
  progress_alerts              progress_alerts[]
  realtime_activities          realtime_activities[]
  samAnalytics                 SAMAnalytics[]                 @relation("SAMCourseAnalytics")
  samBadges                    SAMBadge[]                     @relation("SAMCourseBadges")
  samConversations             SAMConversation[]              @relation("SAMCourseSessions")
  samInteractions              SAMInteraction[]               @relation("SAMCourseInteractions")
  samPoints                    SAMPoints[]                    @relation("SAMCoursePoints")

  // SAM Agentic AI Relations (added January 2026)
  samLearningGoals             SAMLearningGoal[]              @relation("SAMGoalCourses")
  samLongTermMemories          SAMLongTermMemory[]            @relation("SAMLongTermMemoryCourses")
  samSessionContexts           SAMSessionContext[]
  samVectorEmbeddings          SAMVectorEmbedding[]

  // SAM Knowledge Graph Engine Relations (added January 2026)
  samKnowledgeConcepts         SAMKnowledgeConcept[]          @relation("SAMKnowledgeConcepts")
  samKnowledgeGraph            SAMKnowledgeGraph?             @relation("SAMKnowledgeGraph")

  study_streaks                study_streaks[]
  user_achievements            user_achievements[]
  user_progress                user_progress[]

  // User Progress relations
  userCourseEnrollments UserCourseEnrollment[]

  // New relations for missing models
  courseCompletionAnalytics CourseCompletionAnalytics?

  // Phase 2: Q&A System relations
