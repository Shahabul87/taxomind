  @@index([sectionId])
  @@index([userId])
}

model Exam {
  id                String             @id @default(uuid())
  title             String
  description       String?
  isPublished       Boolean            @default(false)
  sectionId         String
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  attempts          Int                @default(1)
  endDate           DateTime?
  instructions      String?
  isActive          Boolean            @default(true)
  passingScore      Float              @default(70)
  showResults       Boolean            @default(true)
  shuffleQuestions  Boolean            @default(false)
  startDate         DateTime?
  timeLimit         Int?
  section           Section            @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  ExamBloomsProfile ExamBloomsProfile?
  ExamQuestion      ExamQuestion[]
  UserExamAttempt   UserExamAttempt[]

  // Exam & Evaluation System - Enhanced Questions
  enhancedQuestions EnhancedQuestion[] @relation("ExamEnhancedQuestions")

  // Advanced Exam Evaluation System Relations (added December 2024)
  integrityReports            IntegrityReport[]
  proctorSessions             ProctorSession[]
