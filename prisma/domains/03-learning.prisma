  @@index([sectionId])
  @@index([isPublished, isActive])
}

model VideoBookmark {
  id        String   @id @default(cuid())
  userId    String
  sectionId String
  timestamp Int      // Seconds into video
  note      String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  section Section @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  @@unique([userId, sectionId, timestamp])
  @@index([userId, sectionId])
  @@index([createdAt])
}

model Question {
  id        String   @id @default(uuid())
  text      String
  sectionId String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  Answer    Answer[]
  Section   Section? @relation(fields: [sectionId], references: [id], onDelete: Cascade)
}

model CourseReview {
  id        String   @id @default(uuid())
  rating    Int      @default(0)
  comment   String
  courseId  String
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  helpfulVotes CourseReviewHelpfulVote[]

  @@index([courseId])
  @@index([userId])
}

model CourseReviewHelpfulVote {
  id        String       @id @default(uuid())
  reviewId  String
  userId    String
  createdAt DateTime     @default(now())

  review CourseReview @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  user   User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([reviewId, userId])
  @@index([reviewId])
  @@index([userId])
}

model Answer {
  id         String   @id
  text       String
  isCorrect  Boolean  @default(false)
  questionId String
  createdAt  DateTime @default(now())
  updatedAt  DateTime
  Question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
}

model Enrollment {
  id                    String   @id
  userId                String
  courseId              String
  createdAt             DateTime @default(now())
  updatedAt             DateTime
  // Phase 3 - Enterprise Payment System
  status                String?  @default("ACTIVE")
  enrollmentType        String?  @default("FREE")
  paymentTransactionId  String?
  Course                Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  User                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@index([courseId])
  @@index([userId])
  @@index([status])
  @@index([paymentTransactionId])
}

model ExamQuestion {
  id            String             @id
  question      String
  options       Json?
  points        Float              @default(1)
  examId        String
  createdAt     DateTime           @default(now())
  updatedAt     DateTime
  explanation   String?
  imageUrl      String?
  order         Int
  videoUrl      String?
  correctAnswer Json
  questionType  QuestionType       @default(MULTIPLE_CHOICE)
  bloomsLevel   BloomsLevel?
  difficulty    QuestionDifficulty @default(MEDIUM)
  Exam          Exam               @relation(fields: [examId], references: [id], onDelete: Cascade)
  UserAnswer    UserAnswer[]

  @@index([examId, order])
}

