// ==========================================
// Exam & Evaluation System Models
// ==========================================
// Enhanced models for cognitive skill development
// and AI-powered evaluation system

// Learning Objective Model (link questions to objectives)
model LearningObjectiveItem {
  id          String      @id @default(cuid())
  sectionId   String
  objective   String      @db.Text
  bloomsLevel BloomsLevel
  order       Int         @default(0)

  // Relations
  section   Section            @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  questions EnhancedQuestion[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([sectionId])
  @@index([bloomsLevel])
}

// Enhanced Question Model for cognitive assessment
model EnhancedQuestion {
  id             String  @id @default(cuid())
  examId         String?
  questionBankId String?

  // Basic Info
  question     String       @db.Text
  questionType QuestionType
  points       Int          @default(1)
  order        Int          @default(0)

  // Answer Configuration
  options              Json? // For MCQ, matching, etc.
  correctAnswer        String   @db.Text
  acceptableVariations Json? // Alternative correct answers
  rubric               Json? // For essay/short answer evaluation

  // Bloom's Taxonomy
  bloomsLevel         BloomsLevel
  cognitiveSkills     String[] // Tags like "critical-thinking", "problem-solving"
  learningObjectiveId String? // Link to section learning objective

  // Hints & Explanations
  hint                 String? @db.Text
  explanation          String  @db.Text
  commonMisconceptions Json? // Array of misconceptions

  // Metadata
  difficulty       QuestionDifficulty @default(MEDIUM)
  estimatedTime    Int? // seconds
  prerequisites    String[] // Concept prerequisites
  relatedConcepts  String[] // Related topics
  generationMode   QuestionGenerationMode @default(MANUAL)

  // Analytics
  totalAttempts       Int    @default(0)
  correctAttempts     Int    @default(0)
  avgTimeSpent        Float? // seconds
  discriminationIndex Float? // Statistical measure

  // Relations
  exam              Exam?                 @relation("ExamEnhancedQuestions", fields: [examId], references: [id], onDelete: Cascade)
  learningObjective LearningObjectiveItem? @relation(fields: [learningObjectiveId], references: [id])
  answers           EnhancedAnswer[]
  aiEvaluations     AIEvaluationRecord[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([examId])
  @@index([bloomsLevel])
  @@index([difficulty])
  @@index([questionType])
  @@index([learningObjectiveId])
}

// Enhanced Answer Model for detailed tracking
model EnhancedAnswer {
  id         String  @id @default(cuid())
  attemptId  String
  questionId String

  // Answer content
  answer       String  @db.Text
  isCorrect    Boolean?
  pointsEarned Float   @default(0)
  timeSpent    Int? // seconds

  // Evaluation type tracking
  evaluationType EvaluationType @default(AUTO_GRADED)

  // Relations
  attempt       UserExamAttempt    @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  question      EnhancedQuestion   @relation(fields: [questionId], references: [id], onDelete: Cascade)
  aiEvaluations AIEvaluationRecord[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([attemptId, questionId])
  @@index([attemptId])
  @@index([questionId])
}

// Cognitive Skill Progress (per student per concept)
model CognitiveSkillProgress {
  id        String @id @default(cuid())
  userId    String
  conceptId String // Could be sectionId or custom concept

  // Bloom's Level Mastery (0-100)
  rememberMastery   Float @default(0)
  understandMastery Float @default(0)
  applyMastery      Float @default(0)
  analyzeMastery    Float @default(0)
  evaluateMastery   Float @default(0)
  createMastery     Float @default(0)

  // Overall
  overallMastery     Float       @default(0)
  currentBloomsLevel BloomsLevel @default(REMEMBER)
  masteryLevel       MasteryLevel @default(NOT_STARTED)

  // Tracking
  totalAttempts   Int       @default(0)
  lastAttemptDate DateTime?

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, conceptId])
  @@index([userId])
  @@index([conceptId])
  @@index([currentBloomsLevel])
}

// Spaced Repetition Schedule (SM-2 Algorithm)
model SpacedRepetitionSchedule {
  id        String @id @default(cuid())
  userId    String
  conceptId String

  // Scheduling (SM-2 Algorithm)
  nextReviewDate DateTime
  easeFactor     Float    @default(2.5) // SM-2 ease factor
  interval       Int      @default(1) // days
  repetitions    Int      @default(0)

  // Performance
  lastScore         Float?
  retentionEstimate Float @default(100)

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, conceptId])
  @@index([userId, nextReviewDate])
}

// AI Evaluation Record for subjective questions
model AIEvaluationRecord {
  id       String @id @default(cuid())
  answerId String

  // Evaluation Details
  score    Float
  maxScore Float

  // Bloom's Analysis
  targetBloomsLevel BloomsLevel
  demonstratedLevel BloomsLevel
  bloomsEvidence    Json? // Evidence for level determination

  // Content Analysis (0-100)
  accuracy     Float
  completeness Float
  relevance    Float
  depth        Float

  // Insights
  conceptsUnderstood Json? // Array of strings
  misconceptions     Json? // Array of identified misconceptions
  knowledgeGaps      Json? // Array of gaps

  // Feedback
  feedback     String @db.Text
  strengths    Json?
  improvements Json?
  nextSteps    Json?

  // Metadata
  evaluationModel  String // Which AI model was used
  confidence       Float // 0-100
  flaggedForReview Boolean @default(false)

  // Relations
  answer           EnhancedAnswer?   @relation(fields: [answerId], references: [id], onDelete: Cascade)
  enhancedQuestion EnhancedQuestion? @relation(fields: [enhancedQuestionId], references: [id])
  enhancedQuestionId String?

  createdAt DateTime @default(now())

  @@index([answerId])
  @@index([flaggedForReview])
}

// Study Guide Model (personalized study materials)
model StudyGuide {
  id        String  @id @default(cuid())
  userId    String
  examId    String?
  sectionId String?

  // Content
  title   String
  content String @db.Text

  // Structure
  focusAreas        Json // Array of focus areas
  practiceQuestions Json // Array of practice question IDs
  resources         Json // Array of resource links

  // Personalization
  basedOnPerformance Json? // Performance data used to generate
  targetBloomsLevels Json // Levels to focus on

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([examId])
  @@index([sectionId])
}

// Learning Activity Log (for pathway tracking)
model LearningActivityLog {
  id        String               @id @default(cuid())
  userId    String
  sectionId String?
  courseId  String?

  // Activity Details
  activityType LearningActivityType
  bloomsLevel  BloomsLevel?
  duration     Int? // seconds
  score        Float?

  // Context
  contentId   String? // ID of the content engaged with
  contentType String? // Type of content

  // Metadata
  metadata Json?

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([sectionId])
  @@index([courseId])
  @@index([activityType])
  @@index([createdAt])
}

// Progress Intervention (alerts and recommendations)
model ProgressIntervention {
  id     String @id @default(cuid())
  userId String

  // Intervention Details
  interventionType InterventionType
  title            String
  message          String  @db.Text
  priority         String  @default("MEDIUM") // HIGH, MEDIUM, LOW

  // Context
  courseId  String?
  sectionId String?
  conceptId String?

  // Status
  isRead      Boolean   @default(false)
  isActedUpon Boolean   @default(false)
  readAt      DateTime?
  actedAt     DateTime?

  // Recommendations
  suggestedActions Json? // Array of suggested actions

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  expiresAt DateTime?

  @@index([userId])
  @@index([isRead])
  @@index([interventionType])
  @@index([createdAt])
}

// ==========================================
// Enhanced Depth Analysis - Content Ingestion Pipeline
// Added: January 2026
// ==========================================

enum ContentSourceType {
  VIDEO_TRANSCRIPT
  PDF_DOCUMENT
  SLIDE_DECK
  TEXT_BLOCK
  ATTACHMENT
  QUIZ_CONTENT
  ASSIGNMENT_CONTENT
}

enum ContentProcessingStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  SKIPPED
}

// Normalized content sources for depth analysis
model ContentSource {
  id            String                  @id @default(cuid())
  sectionId     String
  section       Section                 @relation("SectionContentSources", fields: [sectionId], references: [id], onDelete: Cascade)

  sourceType    ContentSourceType
  originalUrl   String?                 // For attachments/external content
  fileName      String?                 // Original filename if applicable
  mimeType      String?                 // MIME type of the source
  fileSize      Int?                    // Size in bytes

  // Extracted content
  extractedText String?                 @db.Text
  wordCount     Int                     @default(0)
  pageCount     Int?                    // For PDFs
  slideCount    Int?                    // For presentations
  duration      Int?                    // For video/audio in seconds

  // Structured metadata (type-specific)
  metadata      Json?                   // { sections: [], headings: [], etc. }

  // Processing status
  status        ContentProcessingStatus @default(PENDING)
  processedAt   DateTime?
  errorMessage  String?
  retryCount    Int                     @default(0)

  // Analysis cache (populated after deep content analysis)
  bloomsAnalysis    Json?               // Sentence-level analysis cache
  dokAnalysis       Json?               // DOK analysis cache
  analysisVersion   String?             // Version of analyzer used
  analyzedAt        DateTime?

  createdAt     DateTime                @default(now())
  updatedAt     DateTime                @updatedAt

  @@index([sectionId])
  @@index([sourceType])
  @@index([status])
  @@index([createdAt])
}

// Alignment Matrix - Maps objectives to sections to assessments
model AlignmentMatrix {
  id            String   @id @default(cuid())
  courseId      String   @unique
  course        Course   @relation("CourseAlignmentMatrix", fields: [courseId], references: [id], onDelete: Cascade)

  // Matrix data (JSON for flexibility)
  objectiveAlignments  Json    // ObjectiveAlignment[]
  sectionAlignments    Json    // SectionAlignment[]
  assessmentAlignments Json    // AssessmentAlignment[]

  // Scores
  coverageScore        Float   @default(0)  // % of objectives with assessment coverage
  redundancyScore      Float   @default(0)  // Overlap/duplication indicator (lower is better)
  alignmentScore       Float   @default(0)  // Overall alignment quality

  // Gap tracking
  gaps                 Json?   // AlignmentGap[]
  gapCount             Int     @default(0)
  criticalGapCount     Int     @default(0)

  // Summary stats
  totalObjectives          Int @default(0)
  fullyCoveredObjectives   Int @default(0)
  partialObjectives        Int @default(0)
  uncoveredObjectives      Int @default(0)

  // Metadata
  analysisVersion      String
  analyzedAt           DateTime @default(now())

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([courseId])
  @@index([alignmentScore])
}

// Analysis Evidence - Stores sentence-level triggers for classifications
model AnalysisEvidence {
  id            String   @id @default(cuid())
  analysisId    String   // Links to CourseBloomsAnalysis.id

  // Source identification
  sourceType    String   // 'section_content' | 'objective' | 'assessment' | 'transcript'
  sourceId      String   // The specific source (sectionId, questionId, etc.)

  // Classification result
  classification    String      // REMEMBER, UNDERSTAND, APPLY, ANALYZE, EVALUATE, CREATE
  confidence        Float       // 0-1

  // Evidence details
  triggerPatterns   String[]    // Matched patterns/keywords
  highlightedText   String?     @db.Text  // The sentence/phrase that triggered classification
  textPosition      Json?       // { start: number, end: number, paragraph: number }

  // Context
  context           String?     // 'instructional' | 'assessment' | 'activity' | etc.

  createdAt     DateTime @default(now())

  @@index([analysisId])
  @@index([sourceType, sourceId])
  @@index([classification])
  @@index([confidence])
}
