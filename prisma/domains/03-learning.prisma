model UserAnswer {
  id              String          @id
  answer          Json
  isCorrect       Boolean?
  pointsEarned    Float           @default(0)
  timeSpent       Int?
  attemptId       String
  questionId      String
  createdAt       DateTime        @default(now())
  updatedAt       DateTime
  UserExamAttempt UserExamAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  ExamQuestion    ExamQuestion    @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([attemptId, questionId])
  @@index([attemptId])
  @@index([questionId])
}

model UserExamAttempt {
  id              String          @id
  attemptNumber   Int
  status          AttemptStatus   @default(IN_PROGRESS)
  startedAt       DateTime        @default(now())
  submittedAt     DateTime?
  timeSpent       Int?
  totalQuestions  Int
  correctAnswers  Int             @default(0)
  scorePercentage Float?
  isPassed        Boolean?
  userId          String
  examId          String
  createdAt       DateTime        @default(now())
  updatedAt       DateTime
  ExamAnalytics   ExamAnalytics[]
  UserAnswer      UserAnswer[]
  Exam            Exam            @relation(fields: [examId], references: [id], onDelete: Cascade)
  User            User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Exam & Evaluation System - Enhanced Answers
  enhancedAnswers EnhancedAnswer[]

  @@unique([userId, examId, attemptNumber])
  @@index([status])
  @@index([userId, examId])
}

model CourseBloomsAnalysis {
  id                 String   @id @default(uuid())
  courseId           String   @unique
  bloomsDistribution Json
  cognitiveDepth     Float
  learningPathway    Json
  skillsMatrix       Json
  gapAnalysis        Json
  recommendations    Json
  contentHash        String?
  analyzedAt         DateTime @default(now())
  course             Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([courseId])
  @@index([contentHash])
}

model SectionBloomsMapping {
  id                 String      @id @default(uuid())
  sectionId          String      @unique
  bloomsLevel        BloomsLevel
  primaryLevel       BloomsLevel
  secondaryLevels    Json
  activities         Json
  assessments        Json
  learningObjectives Json
  section            Section     @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  @@index([sectionId])
  @@index([bloomsLevel])
}

// Chapter-level Bloom's analysis (Task 6 - January 2025)
model ChapterBloomsAnalysis {
  id                 String      @id @default(uuid())
  chapterId          String      @unique
  primaryLevel       BloomsLevel
  distribution       Json        // { REMEMBER: 0.1, UNDERSTAND: 0.3, ... }
  confidence         Float       @default(0.5)
  sectionCount       Int         @default(0)
  recommendations    Json?       // Array of improvement recommendations
  analyzedAt         DateTime    @default(now())
  updatedAt          DateTime    @updatedAt
  chapter            Chapter     @relation(fields: [chapterId], references: [id], onDelete: Cascade)

  @@index([chapterId])
  @@index([primaryLevel])
}

model ExamBloomsProfile {
  id                 String   @id @default(uuid())
  examId             String   @unique
  targetDistribution Json
  actualDistribution Json
  difficultyMatrix   Json
  skillsAssessed     Json
  coverageMap        Json
  createdAt          DateTime @default(now())
  exam               Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)

  @@index([examId])
}

model QuestionBank {
  id            String             @id @default(uuid())
  courseId      String?
  subject       String
  topic         String
  subtopic      String?
  question      String
  questionType  QuestionType
  bloomsLevel   BloomsLevel
  difficulty    QuestionDifficulty
  options       Json?
  correctAnswer Json
  explanation   String
  hints         Json?
  tags          String[]
  usageCount    Int                @default(0)
  successRate   Float?
  avgTimeSpent  Float?
  metadata      Json?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  course        Course?            @relation(fields: [courseId], references: [id])

  @@index([courseId, subject, topic])
  @@index([bloomsLevel, difficulty])
  @@index([questionType])
}

model StudentBloomsProgress {
  id              String   @id @default(uuid())
  userId          String
  courseId        String?
  bloomsScores    Json
  strengthAreas   Json
  weaknessAreas   Json
  progressHistory Json
  lastAssessedAt  DateTime
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  course          Course?  @relation(fields: [courseId], references: [id])
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@index([userId])
  @@index([courseId])
}

model BloomsPerformanceMetric {
  id                 String      @id @default(uuid())
  userId             String
  courseId           String?
  bloomsLevel        BloomsLevel
  accuracy           Float
  avgResponseTime    Float
  totalAttempts      Int
  successfulAttempts Int
  improvementRate    Float
  challengeAreas     Json
  recordedAt         DateTime    @default(now())
  course             Course?     @relation(fields: [courseId], references: [id])
  user               User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, courseId])
  @@index([bloomsLevel])
}

model PersonalizedResourceRecommendation {
  id                String   @id @default(uuid())
  userId            String
  recommendations   Json
  topRecommendation String
  avgMatchScore     Float
