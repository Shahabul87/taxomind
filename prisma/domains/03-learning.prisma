model Video {
  id          String   @id @default(uuid())
  title       String
  description String?
  youtubeUrl  String?
  url         String?
  duration    Int?
  rating      Int?
  position    Int
  isPublished Boolean  @default(false)
  sectionId   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  thumbnail   String?
  platform    String?
  embedUrl    String?
  author      String?
  userId      String
  section     Section  @relation(fields: [sectionId], references: [id], onDelete: Cascade)
