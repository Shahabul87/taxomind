  title                        String
  description                  String?
  cleanDescription             String?
  imageUrl                     String?
  price                        Float?
  isPublished                  Boolean                        @default(false)
  courseGoals                  String?
  categoryId                   String?
  courseRatings                String?
  activeLearners               Int?
