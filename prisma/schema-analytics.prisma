// Analytics and Tracking Models

model StudentInteraction {
  id              String    @id @default(cuid())
  studentId       String?
  student         User?     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  courseId        String?
  course          Course?   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  chapterId       String?
  chapter         Chapter?  @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  sectionId       String?
  section         Section?  @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  sessionId       String
  interactionType String    // click, view, scroll, video, quiz, interaction, custom
  eventName       String
  metadata        Json      @default("{}")
  timestamp       DateTime  @default(now())
  processed       Boolean   @default(false)

  @@index([studentId])
  @@index([courseId])
  @@index([timestamp])
  @@index([interactionType, eventName])
  @@index([sessionId])
}

model LearningMetric {
  id                String   @id @default(cuid())
  studentId         String
  student           User     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  courseId          String
  course            Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  date              DateTime @db.Date
  totalTimeSpent    Int      @default(0)
  totalInteractions Int      @default(0)
  videoWatchTime    Int      @default(0)
  quizAttempts      Int      @default(0)
  engagementScore   Float?
  learningVelocity  Float?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([studentId, courseId, date])
  @@index([studentId])
  @@index([courseId])
  @@index([date])
}

model ContentFlag {
  id          String   @id @default(cuid())
  contentType String   // video, quiz, section, chapter
  contentId   String
  flagType    String   // struggle_point, confusion, error, improvement
  metadata    Json     @default("{}")
  count       Int      @default(1)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([contentType, contentId, flagType])
  @@index([contentType, contentId])
}

model LearningPattern {
  id                  String   @id @default(cuid())
  studentId           String   @unique
  student             User     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  preferredStudyTime  Json     @default("[]") // Array of preferred hours
  averageSessionLength Int     @default(0)
  contentPreferences  Json     @default("{}") // {video: %, text: %, interactive: %}
  learningVelocity    Float    @default(0)
  strugglingTopics    Json     @default("[]")
  strongTopics        Json     @default("[]")
  lastUpdated         DateTime @updatedAt
  createdAt           DateTime @default(now())

  @@index([studentId])
}

