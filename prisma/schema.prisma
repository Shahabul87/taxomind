model LearningEvent {
  id            String   @id @default(uuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  eventType     String // "page_view", "video_watch", "quiz_attempt", "discussion_post"
  eventCategory String // "learning", "social", "assessment", "navigation"
  contentType   String? // "course", "chapter", "section", "video", "quiz"
  contentId     String?
  sessionId     String?
  duration      Int? // in seconds
  engagement    Float? // engagement score 0-100
  metadata      Json?
  ipAddress     String?
  userAgent     String?
  referrer      String?
  timestamp     DateTime @default(now())

  @@index([userId])
  @@index([eventType])
  @@index([eventCategory])
  @@index([contentType])
  @@index([sessionId])
  @@index([timestamp])
}

model GroupEvent {
  id                                String               @id
  title                             String
  description                       String?
  date                              DateTime
  startTime                         String?
  endTime                           String?
  location                          String?
  isOnline                          Boolean              @default(false)
  meetingUrl                        String?
  maxAttendees                      Int?
  status                            String               @default("upcoming")
  createdAt                         DateTime             @default(now())
  updatedAt                         DateTime
  creatorId                         String?
  organizerId                       String?
  groupId                           String
  User_GroupEvent_creatorIdToUser   User?                @relation("GroupEvent_creatorIdToUser", fields: [creatorId], references: [id])
  Group                             Group                @relation(fields: [groupId], references: [id], onDelete: Cascade)
  User_GroupEvent_organizerIdToUser User?                @relation("GroupEvent_organizerIdToUser", fields: [organizerId], references: [id])
  GroupEventAttendee                GroupEventAttendee[]

  @@index([creatorId])
  @@index([groupId])
  @@index([organizerId])
}

model GroupEventAttendee {
  id         String     @id
  status     String     @default("attending")
  eventId    String
  userId     String
  createdAt  DateTime   @default(now())
  updatedAt  DateTime
  GroupEvent GroupEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  User       User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
  @@index([eventId])
  @@index([userId])
}

model BadgeEvent {
  id        String          @id @default(uuid())
  badgeId   String
  badge     BadgeDefinition @relation(fields: [badgeId], references: [id])
  userId    String?
  user      User?           @relation(fields: [userId], references: [id])
  eventType String // "EARNED", "PROGRESS_UPDATED", "VIEWED"
  eventData Json?
  metadata  Json?
  createdAt DateTime        @default(now())

  @@index([badgeId])
  @@index([userId])
  @@index([eventType])
}

model CalendarEvent {
  id                  String          @id
  title               String
  description         String?
  startDate           DateTime
  endDate             DateTime
  location            String?
  userId              String
  createdAt           DateTime        @default(now())
  updatedAt           DateTime
  recurringEndDate    DateTime?
  parentEventId       String?
  externalId          String?
  source              String?
  lastSync            DateTime?
  allDay              Boolean         @default(false)
  category            String
  color               String?
  recurringType       String?
  taskId              String?
  CalendarEvent       CalendarEvent?  @relation("CalendarEventToCalendarEvent", fields: [parentEventId], references: [id])
  other_CalendarEvent CalendarEvent[] @relation("CalendarEventToCalendarEvent")
  User                User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([externalId, source])
  @@index([parentEventId])
  @@index([startDate])
  @@index([userId])
}

model UserCalendarSettings {
  id                  String   @id
  userId              String   @unique
  defaultView         String   @default("month")
  firstDayOfWeek      Int      @default(0)
  showWeekNumbers     Boolean  @default(false)
  enableNotifications Boolean  @default(true)
  notificationTime    Int      @default(30)
  timeZone            String   @default("UTC")
  workingHoursStart   String   @default("09:00")
  workingHoursEnd     String   @default("17:00")
  createdAt           DateTime @default(now())
  updatedAt           DateTime
  User                User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Certification {
  id               String                    @id @default(uuid())
  userId           String
  courseId         String
  templateId       String?
  verificationCode String                    @unique
  issuedAt         DateTime                  @default(now())
  expiresAt        DateTime?
  isRevoked        Boolean                   @default(false)
  revokedAt        DateTime?
  revokedReason    String?
  metadata         Json?
  createdAt        DateTime                  @default(now())
  updatedAt        DateTime                  @updatedAt
  verifications    CertificateVerification[]
  course           Course                    @relation(fields: [courseId], references: [id], onDelete: Cascade)
  template         CertificateTemplate?      @relation(fields: [templateId], references: [id])
  user             User                      @relation(fields: [userId], references: [id], onDelete: Cascade)

  // New relations for missing models
  certificateEvents    CertificateEvent[]
  certificateAnalytics CertificateAnalytics?

  @@index([userId])
  @@index([courseId])
  @@index([verificationCode])
}

model CertificateTemplate {
  id           String          @id @default(uuid())
  name         String
  templateType String
  content      Json
  isActive     Boolean         @default(true)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  certificates Certification[]

  @@index([templateType])
}

model CertificateVerification {
  id               String         @id @default(uuid())
  certificateId    String?
  badgeId          String?
  verificationCode String
  verifierIp       String
  verifierInfo     Json?
  isValid          Boolean        @default(true)
  verifiedAt       DateTime       @default(now())
  createdAt        DateTime       @default(now())
  userBadge        UserBadge?     @relation(fields: [badgeId], references: [id], onDelete: Cascade)
  certificate      Certification? @relation(fields: [certificateId], references: [id], onDelete: Cascade)

  @@index([certificateId])
  @@index([badgeId])
  @@index([verificationCode])
  @@index([verifiedAt])
}

model CertificateEvent {
  id            String        @id @default(uuid())
  certificateId String
  certificate   Certification @relation(fields: [certificateId], references: [id])
  eventType     String // "GENERATED", "VIEWED", "VERIFIED", "REVOKED"
  userId        String?
  user          User?         @relation(fields: [userId], references: [id])
  ipAddress     String?
  userAgent     String?
  metadata      Json?
  createdAt     DateTime      @default(now())

  @@index([certificateId])
  @@index([eventType])
  @@index([userId])
  @@index([createdAt])
}

