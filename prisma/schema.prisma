// ==========================================
// Learning Activity - Scheduled activities
// ==========================================

model LearningActivity {
  id                String                 @id @default(cuid())
  userId            String
  user              User                   @relation("UserLearningActivities", fields: [userId], references: [id], onDelete: Cascade)

  // Activity details
  type              ScheduledActivityType
  title             String
  description       String?                @db.Text

  // Course/Content association
  courseId          String?
  course            Course?                @relation("CourseLearningActivities", fields: [courseId], references: [id], onDelete: SetNull)
  chapterId         String?
  chapter           Chapter?               @relation("ChapterLearningActivities", fields: [chapterId], references: [id], onDelete: SetNull)
  sectionId         String?

  // Time scheduling
  scheduledDate     DateTime
  startTime         String?                // Format: "HH:mm" (e.g., "09:00")
  endTime           String?                // Format: "HH:mm" (e.g., "10:30")
  estimatedDuration Int                    @default(30) // minutes

  // Actual tracking
  actualDuration    Int?                   // minutes
  actualStartTime   DateTime?
  actualEndTime     DateTime?

  // Status and progress
  status            ScheduledActivityStatus @default(NOT_STARTED)
  progress          Int                    @default(0) // 0-100

  // Priority and categorization
  priority          Priority               @default(MEDIUM)
  tags              String[]               @default([])

  // Recurrence
  isRecurring       Boolean                @default(false)
  recurrenceRule    String?                // iCal RRULE format
  parentActivityId  String?
  parentActivity    LearningActivity?      @relation("RecurringActivities", fields: [parentActivityId], references: [id], onDelete: SetNull)
  childActivities   LearningActivity[]     @relation("RecurringActivities")

  // Google Calendar sync
  googleEventId     String?                @unique
  calendarSynced    Boolean                @default(false)
  lastSyncedAt      DateTime?

  // Metadata
  notes             String?                @db.Text
  completedAt       DateTime?

  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt

  @@index([userId, scheduledDate])
  @@index([userId, status])
  @@index([courseId])
  @@index([chapterId])
  @@map("learning_activities")
}

// ==========================================
// Daily Learning Log - Planned vs Actual
// ==========================================

model DailyLearningLog {
  id                String    @id @default(cuid())
  userId            String
  user              User      @relation("UserDailyLearningLogs", fields: [userId], references: [id], onDelete: Cascade)

  // Date for this log entry
  date              DateTime  @db.Date

  // Planned metrics (set at start of day or previous night)
  plannedMinutes    Int       @default(0)
  plannedActivities Int       @default(0)
  plannedTasks      Int       @default(0)

  // Actual metrics (updated throughout the day)
  actualMinutes     Int       @default(0)
  completedActivities Int     @default(0)
  completedTasks    Int       @default(0)
  skippedActivities Int       @default(0)

  // Focus and productivity
  focusScore        Int?                   // 0-100, calculated from session quality
  productivityScore Int?                   // 0-100, calculated from completion rate

  // Study patterns
  peakHour          String?                // Best performing hour of the day
  totalBreaks       Int       @default(0)
  longestSession    Int?                   // minutes

  // Mood and energy (optional self-reporting)
  energyLevel       Int?                   // 1-5
  moodRating        Int?                   // 1-5

  // Notes
  dailyNotes        String?   @db.Text
  aiSummary         String?   @db.Text     // AI-generated daily summary

  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@unique([userId, date])
  @@index([userId, date])
