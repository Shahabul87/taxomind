model User {
  id                                      String                               @id @default(cuid())
  name                                    String?
  email                                   String?                              @unique
  emailVerified                           DateTime?
  image                                   String?
  password                                String?
  // SECURITY FIX: confirmPassword removed - should never be persisted in database
  // Password confirmation is only for frontend validation
  role                                    UserRole                             @default(USER)
  isTwoFactorEnabled                      Boolean                              @default(false)
  totpSecret                              String? // Encrypted TOTP secret
  totpEnabled                             Boolean                              @default(false)
  totpVerified                            Boolean                              @default(false)
  recoveryCodes                           String[]                             @default([])
  phone                                   String?
  bio                                     String?
  location                                String?
  website                                 String?
  createdAt                               DateTime                             @default(now())
  isAccountLocked                         Boolean                              @default(false)
  lockReason                              String?
  lastLoginAt                             DateTime?
  lastLoginIp                             String?
  failedLoginAttempts                     Int                                  @default(0)
  passwordChangedAt                       DateTime?
  stripeAccountId                         String?
  paypalAccountId                         String?
  walletBalance                           Decimal                              @default(0)
  totalCoursesCreated                     Int                                  @default(0)
  totalCoursesSold                        Int                                  @default(0)
  totalRevenue                            Decimal                              @default(0)
  instructorRating                        Decimal?
  learningStyle                           LearningStyle?
  bloomsProgress                          Json?
  samTotalPoints                          Int                                  @default(0)
  samLevel                                Int                                  @default(1)
  samActiveChallenges                     Json?
  samCompletedChallenges                  Json?
  samChallengeStartDate                   DateTime?
  affiliateActivatedAt                    DateTime?
  affiliateCode                           String?                              @unique
  affiliateEarnings                       Decimal                              @default(0)
  isAffiliate                             Boolean                              @default(false)
