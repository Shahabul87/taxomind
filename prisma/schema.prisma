// ==========================================
// Enhanced Gamification System (Phase 6)
// ==========================================
// XP System, Achievement Engine, Leaderboards
// Implements the full gamification from dashboard enhancement plan
//
// Total Models: 6
// Priority: 10
//
// Created: January 2025
// ==========================================

// ==========================================
// Enums for Enhanced Gamification
// ==========================================

enum AchievementCategory {
  STREAK           // Consecutive days of learning
  COMPLETION       // Completing courses, chapters, lessons
  MASTERY          // High quiz scores, perfect completions
  ENGAGEMENT       // Discussion participation, notes, bookmarks
  SPEED            // Fast completions, early finishes
  DEDICATION       // Study time milestones
  SOCIAL           // Helping others, group activities
  SPECIAL          // Limited time, seasonal, hidden
}

enum AchievementRarity {
  COMMON           // Easy to get (gray border)
  UNCOMMON         // Moderate effort (green border)
  RARE             // Significant effort (blue border)
  EPIC             // Major milestone (purple border)
  LEGENDARY        // Exceptional achievement (gold border)
}

enum XPSource {
  ACHIEVEMENT      // From unlocking achievements
  LESSON           // Completing lessons
  QUIZ             // Taking quizzes (bonus for high scores)
  COURSE           // Course milestones and completion
  STREAK           // Daily streak bonuses
  BONUS            // Special events, promotions
  ADMIN            // Manual adjustment by admin
  CHALLENGE        // From completing challenges
  REFERRAL         // From referral program
}

enum LeaderboardPeriod {
  WEEKLY
  MONTHLY
  ALL_TIME
}

// ==========================================
// Achievement Definition Model
// ==========================================

model GamificationAchievement {
  id                String              @id @default(cuid())

  // Basic Info
  name              String
  slug              String              @unique
  description       String
  icon              String              // Emoji or Lucide icon name

  // Classification
  category          AchievementCategory
  rarity            AchievementRarity

  // Unlock Criteria (JSON for flexibility)
  // Structure: { type: 'COUNT' | 'STREAK' | 'PERCENTAGE' | 'TIME' | 'COMPOUND',
  //              target: number, metric: string, conditions?: [...] }
  criteria          Json

