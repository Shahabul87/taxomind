// ==========================================
// NEW MODELS FOR SAM ENHANCED ENGINES
// ==========================================

// 1. Market-focused Course Evaluation Engine Models
model CourseMarketAnalysis {
  id                  String    @id @default(uuid())
  courseId            String    @unique
  marketValue         Float
  demandScore         Float
  competitorAnalysis  Json
  pricingAnalysis     Json
  trendAnalysis       Json
  brandingScore       Float
  targetAudienceMatch Float
  recommendedPrice    Float
  marketPosition      String
  opportunities       Json
  threats             Json
  lastAnalyzedAt      DateTime
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  course              Course    @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([courseId])
}

model CourseCompetitor {
  id             String   @id @default(uuid())
  courseId       String
  competitorName String
  competitorUrl  String?
  price          Float
  rating         Float?
  enrollments    Int?
  features       Json
  strengths      Json
  weaknesses     Json
  analyzedAt     DateTime @default(now())
  course         Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([courseId])
}

// 2. Bloom's Taxonomy Course Evaluation Models
model CourseBloomsAnalysis {
  id                 String   @id @default(uuid())
  courseId           String   @unique
  bloomsDistribution Json     // { remember: %, understand: %, apply: %, analyze: %, evaluate: %, create: % }
  cognitiveDepth     Float
  learningPathway    Json
  skillsMatrix       Json
  gapAnalysis        Json
  recommendations    Json
  contentHash        String?  // Hash of course content to detect changes
  analyzedAt         DateTime @default(now())
  course             Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([courseId])
  @@index([contentHash])
}

model SectionBloomsMapping {
  id                 String        @id @default(uuid())
  sectionId          String        @unique
  bloomsLevel        BloomsLevel
  primaryLevel       BloomsLevel
  secondaryLevels    Json          // Array of secondary Bloom's levels
  activities         Json
  assessments        Json
  learningObjectives Json
  section            Section       @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  @@index([sectionId])
  @@index([bloomsLevel])
}

// 3. Enhanced Exam/Quiz Engine Models
model ExamBloomsProfile {
  id                 String   @id @default(uuid())
  examId             String   @unique
  targetDistribution Json     // Target Bloom's distribution
  actualDistribution Json     // Actual distribution after creation
  difficultyMatrix   Json     // Difficulty per Bloom's level
  skillsAssessed     Json
  coverageMap        Json     // Topic coverage analysis
  createdAt          DateTime @default(now())
  exam               Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)

  @@index([examId])
}

model QuestionBank {
  id            String              @id @default(uuid())
  courseId      String?
  subject       String
  topic         String
  subtopic      String?
  question      String
  questionType  QuestionType
  bloomsLevel   BloomsLevel
  difficulty    QuestionDifficulty
  options       Json?
  correctAnswer Json
  explanation   String
  hints         Json?
  tags          String[]
  usageCount    Int                 @default(0)
  successRate   Float?
  avgTimeSpent  Float?
  metadata      Json?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  course        Course?             @relation(fields: [courseId], references: [id], onDelete: SetNull)
  
  @@index([courseId, subject, topic])
  @@index([bloomsLevel, difficulty])
  @@index([questionType])
}

model StudentBloomsProgress {
  id              String   @id @default(uuid())
  userId          String
  courseId        String?
  bloomsScores    Json     // Scores per Bloom's level
  strengthAreas   Json
  weaknessAreas   Json
  progressHistory Json
  lastAssessedAt  DateTime
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  course          Course?  @relation(fields: [courseId], references: [id], onDelete: SetNull)
  
  @@unique([userId, courseId])
  @@index([userId])
  @@index([courseId])
}

// 4. Student Learning Dashboard Models
model StudentCognitiveProfile {
  id                   String   @id @default(uuid())
  userId               String   @unique
  overallCognitiveLevel Float
  bloomsMastery        Json     // Mastery scores for each Bloom's level
  learningTrajectory   Json     // Historical cognitive growth data
  skillsInventory      Json     // Detailed skills mapping
  performancePatterns  Json
  optimalLearningStyle String
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model BloomsPerformanceMetric {
  id               String      @id @default(uuid())
  userId           String
  courseId         String?
  bloomsLevel      BloomsLevel
  accuracy         Float
  avgResponseTime  Float
  totalAttempts    Int
  successfulAttempts Int
  improvementRate  Float
  challengeAreas   Json
  recordedAt       DateTime    @default(now())
  user             User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  course           Course?     @relation(fields: [courseId], references: [id], onDelete: SetNull)

  @@index([userId, courseId])
  @@index([bloomsLevel])
}

// 5. Course Guide Engine Models
model CourseGuideAnalysis {
  id                String   @id @default(uuid())
  courseId          String   @unique
  depthScore        Float
  engagementMetrics Json
  marketAcceptance  Json
  studentOutcomes   Json
  contentQuality    Json
  improvementAreas  Json
  competitiveEdge   Json
  lastAnalyzedAt    DateTime
  createdAt         DateTime @default(now())
  course            Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([courseId])
}

model TeacherInsights {
  id              String   @id @default(uuid())
  teacherId       String
  courseId        String
  insightType     String   // 'engagement', 'performance', 'content', 'market'
  data            Json
  recommendations Json
  priority        Int
  actionable      Boolean  @default(true)
  createdAt       DateTime @default(now())
  teacher         User     @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  course          Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  
  @@index([teacherId, courseId])
  @@index([insightType])
}

model CourseOptimizationSuggestion {
  id                String   @id @default(uuid())
  courseId          String
  suggestionType    String   // 'content', 'structure', 'assessment', 'engagement'
  description       String
  impact            String   // 'high', 'medium', 'low'
  implementation    Json     // Step-by-step implementation guide
  estimatedEffort   String   // 'minimal', 'moderate', 'significant'
  expectedOutcome   Json
  status            String   @default("pending") // 'pending', 'in_progress', 'completed', 'dismissed'
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  course            Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([courseId, status])
  @@index([suggestionType])
}

// ==========================================
// MULTI-MODAL CONTENT INTELLIGENCE ENGINE
