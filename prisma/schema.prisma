  @@index([organizationId, cohortMonth])
  @@unique([organizationId, cohortMonth])
}

// Real-Time Collaboration Analytics Models
// Note: CollaborationSession already exists above
model CollaborationContribution {
  id               String   @id @default(uuid())
  sessionId        String
  userId           String
  contributionType String   // message, question, answer, resource, edit, reaction
  content          Json     // Contribution content
  impact           Float    @default(0) // 0-1 impact score
  timestamp        DateTime @default(now())
  session          CollaborationSession @relation(fields: [sessionId], references: [sessionId], onDelete: Cascade)
  reactions        CollaborationReaction[]
  
  @@index([sessionId, userId])
  @@index([contributionType])
}

model CollaborationReaction {
  id             String   @id @default(uuid())
  contributionId String
  userId         String
  reactionType   String   // like, helpful, insightful, question
  sessionId      String
  createdAt      DateTime @default(now())
  contribution   CollaborationContribution @relation(fields: [contributionId], references: [id], onDelete: Cascade)
  session        CollaborationSession @relation(fields: [sessionId], references: [sessionId], onDelete: Cascade)
  
  @@index([contributionId])
  @@index([userId])
  @@unique([contributionId, userId, reactionType])
}

model CollaborationAnalytics {
  id                   String   @id @default(uuid())
  sessionId            String   @unique
  sessionAnalytics     Json     // Overall session metrics
  participantAnalytics Json     // Participant-level analytics
  contentAnalytics     Json     // Content and topic analytics
  networkAnalytics     Json     // Collaboration network analysis
  generatedAt          DateTime @default(now())
  session              CollaborationSession @relation(fields: [sessionId], references: [sessionId], onDelete: Cascade)
  
  @@index([sessionId])
}

// Innovation Features Models
// Cognitive Fitness
model CognitiveFitnessAssessment {
  id               String   @id @default(uuid())
  userId           String
  overallScore     Float
  dimensions       Json     // Cognitive dimensions (memory, attention, etc.)
  exercises        Json     // Recommended exercises
  progress         Json     // Fitness progress tracking
  recommendations  Json     // Personalized recommendations
  createdAt        DateTime @default(now())
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId, createdAt])
}

model FitnessSession {
  id          String   @id @default(uuid())
  userId      String
  exerciseId  String
  startTime   DateTime
  endTime     DateTime?
  duration    Float?   // Duration in minutes
  performance Json?    // Performance metrics
  status      String   // in_progress, completed, abandoned
  createdAt   DateTime @default(now())
  
  @@index([userId, exerciseId])
  @@index([status])
}

model FitnessMilestone {
  id           String   @id @default(uuid())
  userId       String
  name         String
  dimension    String   // Which cognitive dimension
  improvement  Float    // Improvement percentage
  achievedAt   DateTime @default(now())
  
  @@index([userId, dimension])
}

// Learning DNA
model LearningDNA {
  id          String   @id @default(uuid())
  userId      String
  dnaSequence Json     // DNA sequence with segments
  traits      Json     // Learning traits
  heritage    Json     // Learning heritage and evolution
  mutations   Json     // DNA mutations over time
  phenotype   Json     // Expressed characteristics
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId, createdAt])
}

// Study Buddy
model StudyBuddy {
  id           String   @id @default(uuid())
  buddyId      String   @unique
  userId       String
  name         String
  personality  Json     // Buddy personality configuration
  avatar       Json     // Avatar configuration
  relationship Json     // Relationship metrics
  capabilities Json     // Buddy capabilities
  effectiveness Json?   // Effectiveness metrics
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  interactions BuddyInteraction[]
  adjustments  BuddyAdjustment[]
  
  @@index([userId, isActive])
  @@index([buddyId])
}

model BuddyInteraction {
  id               String   @id @default(uuid())
  buddyId          String
  userId           String
  interactionType  String   // conversation, quiz, encouragement, challenge, celebration
  content          Json     // Interaction content
  userResponse     String?  // User's response
  effectiveness    Float    @default(0) // 0-1 effectiveness score
  createdAt        DateTime @default(now())
  buddy            StudyBuddy @relation(fields: [buddyId], references: [buddyId], onDelete: Cascade)
  
  @@index([buddyId, userId])
  @@index([interactionType])
}

model BuddyAdjustment {
  id              String   @id @default(uuid())
  buddyId         String
  adjustmentType  String   // personality, communication, strictness
  parameters      Json     // What was adjusted
  reason          String   // Why it was adjusted
  impact          Float?   // Measured impact
  createdAt       DateTime @default(now())
  buddy           StudyBuddy @relation(fields: [buddyId], references: [buddyId], onDelete: Cascade)
  
  @@index([buddyId])
}

// Quantum Learning Paths
model QuantumLearningPath {
  id               String   @id @default(uuid())
  pathId           String   @unique
  userId           String
  learningGoal     String
  superposition    Json     // Possible path states
  entanglements    Json     // Path entanglements
  probability      Json     // Success probabilities
  coherenceLevel   Float    @default(1.0)
  collapsed        Boolean  @default(false)
  collapse         Json?    // Final collapsed state
  finalStateId     String?  // ID of final quantum state
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  observations     QuantumObservation[]
  
  @@index([userId, isActive])
  @@index([pathId])
}

model QuantumObservation {
  id              String   @id @default(uuid())
  pathId          String
  observationId   String   @unique
  observationType String   // progress_check, assessment, interaction
  observer        String   // userId or system
  impact          Json     // Observation impact on path
  createdAt       DateTime @default(now())
  path            QuantumLearningPath @relation(fields: [pathId], references: [pathId], onDelete: Cascade)
  
  @@index([pathId])
  @@index([observationId])
}

// GDPR Compliance Models
model UserConsent {
  id           String    @id @default(cuid())
  userId       String
  consentType  String    // MARKETING, ANALYTICS, PERSONALIZATION, etc.
  granted      Boolean
  purpose      String?   // Purpose of data processing
  grantedAt    DateTime? // When consent was granted
  withdrawnAt  DateTime? // When consent was withdrawn
  expiresAt    DateTime? // When consent expires
  ipAddress    String?   // IP address when consent was given
  version      String    // Version of consent terms
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, consentType])
  @@index([granted])
  @@map("user_consents")
}

model GDPRRequest {
  id             String    @id @default(cuid())
  userId         String
  requestType    String    // DATA_ACCESS, DATA_PORTABILITY, DATA_DELETION, etc.
  status         String    // PENDING, IN_PROGRESS, COMPLETED, REJECTED
  requestedAt    DateTime  @default(now())
  completedAt    DateTime?
  reason         String?   // Reason for request
  responseData   Json?     // Response data for access requests
  verificationToken String? // Token for email verification
  processedBy    String?   // Admin who processed the request
  notes          String?   // Admin notes
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([requestType, status])
  @@map("gdpr_requests")
}

model DataProcessingActivity {
  id                String   @id @default(cuid())
  name              String   // Name of processing activity
  purpose           String   // Purpose of processing
  legalBasis        String   // Legal basis (consent, contract, legitimate interest, etc.)
  dataCategories    String[] // Categories of data processed
  dataSubjects      String[] // Categories of data subjects
  recipients        String[] // Recipients or categories of recipients
  retentionPeriod   String   // Data retention period
  securityMeasures  String   // Technical and organizational measures
  thirdCountryTransfers Boolean @default(false)
  transferSafeguards String? // Safeguards for third country transfers
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@map("data_processing_activities")
}

model PrivacyPolicy {
  id          String   @id @default(cuid())
  version     String   @unique
  content     String   @db.Text
  effectiveDate DateTime
  isActive    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isActive, effectiveDate])
  @@map("privacy_policies")
}

model DataBreach {
  id               String    @id @default(cuid())
  incidentDate     DateTime
  discoveryDate    DateTime
  reportedDate     DateTime?
  severity         String    // LOW, MEDIUM, HIGH, CRITICAL
  affectedUsers    Int
  dataTypes        String[]  // Types of data affected
  description      String    @db.Text
  cause            String    // Human error, system failure, malicious attack, etc.
  measures         String    @db.Text // Measures taken
  notifications    Json?     // Notification details
  status           String    // DETECTED, CONTAINED, RESOLVED
  reportedToAuthority Boolean @default(false)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@map("data_breaches")
}
