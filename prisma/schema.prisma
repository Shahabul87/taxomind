model Category {
  id            String         @id @default(uuid())
  name          String         @unique
  parentId      String?
  parent        Category?      @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children      Category[]     @relation("CategoryHierarchy")
  courses       Course[]
  Group         Group[]
  learningPaths LearningPath[]
  subcategoryCourses Course[]  @relation("SubcategoryCourses")

  @@index([parentId])
}

model Course {
  id                           String                         @id @default(uuid())
  title                        String
  description                  String?
  cleanDescription             String?
  imageUrl                     String?
  price                        Float?
  isPublished                  Boolean                        @default(false)
  courseGoals                  String?
  categoryId                   String?
  courseRatings                String?
  activeLearners               Int?
  userId                       String
  createdAt                    DateTime                       @default(now())
  updatedAt                    DateTime                       @updatedAt
  whatYouWillLearn             String[]                       @default([])
  slug                         String?
  subtitle                     String?
  isFeatured                   Boolean                        @default(false)
  organizationId               String?
  // Phase 2 Week 5 - Additional course metadata
  prerequisites                String?                        @db.Text
  difficulty                   String?
  totalDuration                Int?
  originalPrice                Float?
  dealEndDate                  DateTime?
  averageRating                Float?
  // Phase 3 - Enterprise Payment System
  isFree                       Boolean?                       @default(false)
  priceType                    String?                        @default("ONE_TIME")
  AIGeneratedContent           AIGeneratedContent[]
  attachments                  Attachment[]
  BloomsPerformanceMetric      BloomsPerformanceMetric[]
  certifications               Certification[]
  chapters                     Chapter[]
  category                     Category?                      @relation(fields: [categoryId], references: [id])
  subcategoryId                String?
  subcategory                  Category?                      @relation("SubcategoryCourses", fields: [subcategoryId], references: [id])
  organization                 Organization?                  @relation("OrganizationCourses", fields: [organizationId], references: [id])
  user                         User                           @relation(fields: [userId], references: [id], onDelete: Cascade)
  CourseBloomsAnalysis         CourseBloomsAnalysis?
  CourseCompetitor             CourseCompetitor[]
  CourseGuideAnalysis          CourseGuideAnalysis?
  CourseMarketAnalysis         CourseMarketAnalysis?
  CourseOptimizationSuggestion CourseOptimizationSuggestion[]
  reviews                      CourseReview[]
  Enrollment                   Enrollment[]
  Group                        Group[]
  MultiMediaAnalysis           MultiMediaAnalysis[]
  MultiModalAnalysis           MultiModalAnalysis[]
  PredictiveLearningAnalysis   PredictiveLearningAnalysis[]
  PricingExperiment            PricingExperiment[]
  Purchase                     Purchase[]
  QuestionBank                 QuestionBank[]
  StudentBloomsProgress        StudentBloomsProgress[]
  TeacherInsights              TeacherInsights[]
  learning_metrics             learning_metrics[]
  learning_sessions            learning_sessions[]
  progress_alerts              progress_alerts[]
  realtime_activities          realtime_activities[]
  samAnalytics                 SAMAnalytics[]                 @relation("SAMCourseAnalytics")
  samBadges                    SAMBadge[]                     @relation("SAMCourseBadges")
  samConversations             SAMConversation[]              @relation("SAMCourseSessions")
  samInteractions              SAMInteraction[]               @relation("SAMCourseInteractions")
  samPoints                    SAMPoints[]                    @relation("SAMCoursePoints")

  // SAM Agentic AI Relations (added January 2026)
  samLearningGoals             SAMLearningGoal[]              @relation("SAMGoalCourses")
  samLongTermMemories          SAMLongTermMemory[]            @relation("SAMLongTermMemoryCourses")
  samSessionContexts           SAMSessionContext[]
  samVectorEmbeddings          SAMVectorEmbedding[]

  study_streaks                study_streaks[]
  user_achievements            user_achievements[]
  user_progress                user_progress[]

  // User Progress relations
  userCourseEnrollments UserCourseEnrollment[]

  // New relations for missing models
  courseCompletionAnalytics CourseCompletionAnalytics?

  // Phase 2: Q&A System relations
  courseQuestions CourseQuestion[]

  // Phase 2: Course Enhancements (from 13-course-enhancements.prisma)
  wishlists                      Wishlist[]
  learningPathCourses            LearningPathCourse[]
  currentPathEnrollments         LearningPathEnrollment[]
  comparedInComparisons          CourseComparison[]         @relation("ComparedCourses")
  recommendationsReceived        CourseRecommendation[]     @relation("RecommendedCourse")
  recommendationsAsSource        CourseRecommendation[]     @relation("RecommendationSource")

  // Dashboard Relations (added 2025-01-09)
  dashboardActivities      DashboardActivity[]     @relation("CourseDashboardActivities")
  dashboardStudySessions   DashboardStudySession[] @relation("CourseStudySessions")
  dashboardStudyPlans      DashboardStudyPlan[]    @relation("CourseStudyPlans")
  dashboardCoursePlans     DashboardCoursePlan[]   @relation("CourseCoursePlans")
  dashboardTodos           DashboardTodo[]         @relation("CourseTodos")
  dashboardGoals           DashboardGoal[]         @relation("CourseGoals")
  dashboardNotes           DashboardNote[]         @relation("CourseNotes")

  // Course Analysis History (for SAM AI Depth Analyzer)
  analysisHistory          CourseAnalysisHistory[] @relation("CourseAnalysisSnapshots")

  // SAM Real-Time Presence Tracking (Phase I)
  samUserPresence          SAMUserPresence[]       @relation("SAMPresenceCourses")

  // Learning Command Center Relations (added January 2026)
  learningActivities       LearningActivity[]      @relation("CourseLearningActivities")
  learningGoals            LearningGoal[]          @relation("CourseLearningGoals")

  // Course Skill Mapping (Phase 3 SAM Fixes)
  courseSkills             CourseSkill[]           @relation("CourseCourseSkills")

  @@index([categoryId])
  @@index([organizationId])
}

// Course-Skill Mapping (Phase 3 SAM Fixes - January 2026)
// Links courses to skills with difficulty level and order
model CourseSkill {
  id          String           @id @default(cuid())
  courseId    String
  skillId     String
  level       CourseSkillLevel @default(BEGINNER)
  order       Int              @default(0)
  isCoreSkill Boolean          @default(false)
  createdAt   DateTime         @default(now())

  course      Course           @relation("CourseCourseSkills", fields: [courseId], references: [id], onDelete: Cascade)
  skill       Skill            @relation("SkillCourseSkills", fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([courseId, skillId])
  @@index([courseId])
  @@index([skillId])
}

