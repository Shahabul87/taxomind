// ==========================================
// Google Calendar Integration
// ==========================================

enum CalendarSyncDirection {
  TAXOMIND_TO_GOOGLE       // One-way: Taxomind → Google
  GOOGLE_TO_TAXOMIND       // One-way: Google → Taxomind
  TWO_WAY                  // Bidirectional sync
}

enum CalendarSyncStatus {
  CONNECTED
  DISCONNECTED
  SYNCING
  ERROR
  EXPIRED
}

enum CalendarEventType {
  STUDY_SESSION
  QUIZ_EXAM
  ASSIGNMENT
  GOAL_MILESTONE
  LIVE_CLASS
  DAILY_TODO
}

model GoogleCalendarIntegration {
  id                    String                @id @default(cuid())
  userId                String                @unique
  user                  User                  @relation("UserGoogleCalendarIntegration", fields: [userId], references: [id], onDelete: Cascade)

  // OAuth tokens (encrypted in production)
  accessToken           String                @db.Text
  refreshToken          String                @db.Text
  tokenExpiresAt        DateTime
  scope                 String                @default("https://www.googleapis.com/auth/calendar")

  // Google account info
  googleEmail           String
  googleAccountId       String?

  // Selected calendar
  selectedCalendarId    String?               // null = primary calendar
  selectedCalendarName  String?
  createDedicatedCalendar Boolean             @default(false)

  // Connection status
  status                CalendarSyncStatus    @default(CONNECTED)
  lastSyncAt            DateTime?
  lastSyncError         String?
  syncErrorCount        Int                   @default(0)

  // Sync settings
  syncDirection         CalendarSyncDirection @default(TAXOMIND_TO_GOOGLE)
  autoSyncEnabled       Boolean               @default(true)
  autoSyncIntervalMinutes Int                 @default(15)

  // What to sync
  syncStudySessions     Boolean               @default(true)
  syncQuizzes           Boolean               @default(true)
  syncAssignments       Boolean               @default(true)
  syncGoalMilestones    Boolean               @default(true)
  syncLiveClasses       Boolean               @default(true)
  syncDailyTodos        Boolean               @default(false)

  // Event colors (Google Calendar color IDs: 1-11)
  studySessionColor     String                @default("1")  // Blue
  quizColor             String                @default("11") // Red
  assignmentColor       String                @default("5")  // Yellow
  goalColor             String                @default("10") // Green
  liveClassColor        String                @default("3")  // Purple

  // Event preferences
  defaultReminderMinutes Int                  @default(15)
  includeDescription    Boolean               @default(true)
  includeCourseLink     Boolean               @default(true)

  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt

  // Related sync logs
  syncLogs              CalendarSyncLog[]

  @@map("google_calendar_integrations")
}

model CalendarSyncLog {
  id                    String                @id @default(cuid())
  integrationId         String
  integration           GoogleCalendarIntegration @relation(fields: [integrationId], references: [id], onDelete: Cascade)

  // Sync details
  syncType              String                // "full", "incremental", "manual"
  direction             CalendarSyncDirection
  status                String                // "success", "partial", "failed"

  // Statistics
  eventsCreated         Int                   @default(0)
  eventsUpdated         Int                   @default(0)
  eventsDeleted         Int                   @default(0)
  eventsFailed          Int                   @default(0)

  // Timing
  startedAt             DateTime
  completedAt           DateTime?
  durationMs            Int?

  // Error details
  errorMessage          String?               @db.Text
  errorDetails          Json?

  createdAt             DateTime              @default(now())

  @@index([integrationId, createdAt])
  @@map("calendar_sync_logs")
}

model CalendarEventMapping {
  id                    String                @id @default(cuid())
  userId                String
  user                  User                  @relation("UserCalendarMappings", fields: [userId], references: [id], onDelete: Cascade)

  // Taxomind entity reference
  entityType            CalendarEventType
  entityId              String                // ID of the activity, goal, etc.

  // Google Calendar reference
  googleEventId         String
  googleCalendarId      String

  // Sync metadata
  lastSyncedAt          DateTime
  googleEtag            String?               // For conflict detection
  taxomindVersion       Int                   @default(1) // For optimistic locking

  // Status
  isDeleted             Boolean               @default(false)
  deleteReason          String?

  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt

  @@unique([userId, entityType, entityId])
  @@unique([userId, googleEventId])
  @@index([userId, entityType])
  @@index([googleEventId])
  @@map("calendar_event_mappings")
}

