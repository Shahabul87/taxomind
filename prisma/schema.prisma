model MultiModalAnalysis {
  id         String   @id @default(uuid())
  courseId   String
  insights   Json     // Comprehensive multi-modal insights
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  course     Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([courseId])
}

// ==========================================
// PREDICTIVE LEARNING INTELLIGENCE ENGINE
// ==========================================

model PredictiveLearningAnalysis {
  id             String   @id @default(uuid())
  userId         String?
  courseId       String?
  predictionType String   // 'OUTCOME', 'RISK_ANALYSIS', 'INTERVENTION_PLAN', 'VELOCITY_OPTIMIZATION', 'SUCCESS_PROBABILITY'
  predictionData Json     // Complete prediction results
  confidence     Float    // Confidence score for the prediction
  accuracy       Float?   // Actual accuracy (updated after validation)
  validated      Boolean  @default(false)
  validatedAt    DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  user           User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  course         Course?  @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([userId, predictionType])
  @@index([courseId, predictionType])
  @@index([createdAt])
}

