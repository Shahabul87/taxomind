model AuditLog {
  id             String        @id @default(cuid())
  organizationId String?
  userId         String?
  action         AuditAction
  eventType      String?       // SOC2 event type classification
  entityType     String
  entityId       String
  entityName     String?
  changes        Json?
  context        Json?
  ipAddress      String?
  userAgent      String?
  sessionId      String?       // Session tracking for SOC2
  requestId      String?       // Request correlation ID
  userEmail      String?       // User email for audit trail
  userRole       String?       // User role at time of event
  resourceType   String?       // Resource type accessed
  resourceId     String?       // Resource ID accessed
  metadata       String?       // Encrypted sensitive metadata
  riskScore      Int?          // Risk score (0-100)
  severity       AuditSeverity @default(INFO)
  message        String?       // Human-readable audit message
  tags           String[]      @default([])
  timestamp      DateTime      @default(now())
  createdAt      DateTime      @default(now())
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User?         @relation("AuditLogUser", fields: [userId], references: [id])

  @@index([organizationId, userId, createdAt])
  @@index([action, entityType, createdAt])
  @@index([severity, createdAt])
  @@index([eventType, timestamp])
  @@index([riskScore, timestamp])
  @@index([sessionId])
  @@index([requestId])
  @@map("audit_logs")
}

model CollaborationSession {
  id                 String        @id @default(cuid())
  organizationId     String?
  sessionId          String        @unique
  contentId          String
  contentType        ContentType
