// ==========================================
// Learning Goal (enhanced)
// ==========================================

model LearningGoal {
  id                String             @id @default(cuid())
  userId            String
  user              User               @relation("UserLearningGoals", fields: [userId], references: [id], onDelete: Cascade)

  // Goal details
  title             String
  description       String?            @db.Text
