  // New fields for enhanced collaboration analytics
  courseId           String?
  chapterId          String?
  initiatorId        String?
  sessionType        String?       // discussion, co-creation, peer-review, etc.
  activities         Json?         // Array of collaboration activities
  metrics            Json?         // Session metrics
  insights           Json?         // Generated insights
  contributions      CollaborationContribution[]
  reactions          CollaborationReaction[]
  analytics          CollaborationAnalytics?

  @@index([organizationId, contentId, isActive])
  @@index([sessionId, isActive])
  @@index([courseId, isActive])
  @@index([initiatorId])
  @@map("collaboration_sessions")
}

