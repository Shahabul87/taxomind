  // Statistics
  totalActiveDays   Int       @default(0)
  totalMinutesAllTime Int     @default(0)
  averageDailyMinutes Float   @default(0)

  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

