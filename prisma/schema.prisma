}

model SAMKnowledgeNode {
  id            String   @id @default(cuid())
  type          String
  name          String
  description   String?
  properties    Json?
  embeddings    String[] @default([])

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  outgoingEdges SAMKnowledgeEdge[] @relation("SAMKnowledgeEdgeFrom")
  incomingEdges SAMKnowledgeEdge[] @relation("SAMKnowledgeEdgeTo")

  @@index([type, name])
  @@map("sam_knowledge_nodes")
}

model SAMKnowledgeEdge {
  id         String   @id @default(cuid())
  type       String
  sourceId   String
  targetId   String
  weight     Float    @default(1)
  properties Json?
  createdAt  DateTime @default(now())

  source     SAMKnowledgeNode @relation("SAMKnowledgeEdgeFrom", fields: [sourceId], references: [id], onDelete: Cascade)
  target     SAMKnowledgeNode @relation("SAMKnowledgeEdgeTo", fields: [targetId], references: [id], onDelete: Cascade)

  @@index([sourceId])
  @@index([targetId])
  @@map("sam_knowledge_edges")
}

model SAMSessionContext {
  id           String   @id @default(cuid())
  userId       String
  courseId     String?
  lastActiveAt DateTime @default(now())
  currentState Json
  history      Json?
  preferences  Json
  insights     Json

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  course       Course?  @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([userId, courseId])
  @@map("sam_session_contexts")
}

// ==========================================
// AGENTIC TOOLING MODELS
// ==========================================

model AgentTool {
  id                  String   @id
  name                String
  description         String
  category            String
  version             String
  inputSchema         String   @db.Text
  outputSchema        String?  @db.Text
  requiredPermissions String[] @default([])
  confirmationType    String
  timeoutMs           Int?
  maxRetries          Int?
  rateLimit           String?  @db.Text
  tags                String[] @default([])
  examples            String?  @db.Text
  metadata            String?  @db.Text
  enabled             Boolean  @default(true)
  deprecated          Boolean  @default(false)
  deprecationMessage  String?

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  invocations         AgentToolInvocation[]
  confirmations       AgentConfirmation[]
  permissions         AgentPermission[]
  auditLogs           AgentAuditLog[]

  // Observability (Phase J)
  samToolExecutions   SAMToolExecution[]   @relation("SAMToolExecutionTools")

  @@index([category])
  @@index([enabled])
  @@map("agent_tools")
}

model AgentToolInvocation {
  id                  String   @id @default(cuid())
  toolId              String
  userId              String
  sessionId           String
  input               String?  @db.Text
  validatedInput      String?  @db.Text
  status              String
  confirmationType    String
  confirmationPrompt  String?
  userConfirmed       Boolean?
  confirmedAt         DateTime?
  startedAt           DateTime?
  completedAt         DateTime?
  duration            Int?
  result              String?  @db.Text
  metadata            String?  @db.Text

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  tool                AgentTool @relation(fields: [toolId], references: [id], onDelete: Cascade)
  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  confirmations       AgentConfirmation[]
  auditLogs           AgentAuditLog[]

  @@index([userId, createdAt])
  @@index([toolId, status])
  @@map("agent_tool_invocations")
}

model AgentAuditLog {
  id           String   @id @default(cuid())
  timestamp    DateTime @default(now())
  level        String
  action       String
  userId       String
  sessionId    String
  toolId       String?
  invocationId String?
  input        String?  @db.Text
  output       String?  @db.Text
  error        String?  @db.Text
  ipAddress    String?
  userAgent    String?
  requestId    String?
  metadata     String?  @db.Text

  user         User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  tool         AgentTool?        @relation(fields: [toolId], references: [id], onDelete: SetNull)
  invocation   AgentToolInvocation? @relation(fields: [invocationId], references: [id], onDelete: SetNull)

  @@index([userId, timestamp])
  @@index([toolId])
  @@map("agent_audit_logs")
}

model AgentPermission {
  id         String   @id @default(cuid())
  userId     String
  toolId     String?
  category   String?
  levels     String[] @default([])
  grantedBy  String?
  grantedAt  DateTime @default(now())
  expiresAt  DateTime?
  conditions String?  @db.Text

  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tool       AgentTool? @relation(fields: [toolId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([toolId])
  @@map("agent_permissions")
}

model AgentConfirmation {
  id           String   @id @default(cuid())
  invocationId String
  toolId       String
  toolName     String
  userId       String
  title        String
  message      String
  details      String?  @db.Text
  type         String
  severity     String
  confirmText  String?
  cancelText   String?
  timeout      Int?
  status       String
  respondedAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  expiresAt    DateTime?

  invocation   AgentToolInvocation @relation(fields: [invocationId], references: [id], onDelete: Cascade)
  tool         AgentTool           @relation(fields: [toolId], references: [id], onDelete: Cascade)
  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([invocationId])
  @@map("agent_confirmations")
}

// ==========================================
// SAM OBSERVABILITY MODELS
// ==========================================

// Generic metrics storage
model SAMMetric {
  id        String   @id @default(cuid())
  name      String   // Metric name (e.g., "tool.execution.count", "memory.search.latency")
  value     Float    // Numeric value
  labels    Json     @default("{}") // Key-value labels for filtering
  timestamp DateTime @default(now())
  userId    String?
  sessionId String?

  // Relations
  user      User?    @relation("SAMMetrics", fields: [userId], references: [id], onDelete: Cascade)

  @@index([name, timestamp])
  @@index([userId, timestamp])
  @@map("sam_metrics")
}

// Tool execution telemetry
model SAMToolExecution {
  id                  String                 @id @default(cuid())
  toolId              String                 // Reference to AgentTool
  toolName            String                 // Tool name for quick access
  userId              String
  sessionId           String?
  planId              String?                // Reference to SAMExecutionPlan
  stepId              String?                // Reference to SAMPlanStep

  // Execution details
  status              SAMToolExecutionStatus @default(PENDING)
  startedAt           DateTime?
  completedAt         DateTime?
  durationMs          Int?

  // Confirmation tracking
  confirmationRequired Boolean              @default(false)
  confirmationGiven    Boolean?

  // Input/Output summaries (for debugging without full payloads)
  inputSummary        String?               @db.Text
  outputSummary       String?               @db.Text

  // Error details
  errorCode           String?
  errorMessage        String?               @db.Text
  errorRetryable      Boolean?

  // Tags for filtering
  tags                Json                  @default("{}")

  createdAt           DateTime              @default(now())

  // Relations
  user                User                  @relation("SAMToolExecutions", fields: [userId], references: [id], onDelete: Cascade)
  tool                AgentTool?            @relation("SAMToolExecutionTools", fields: [toolId], references: [id], onDelete: SetNull)
  plan                SAMExecutionPlan?     @relation("SAMToolExecutionPlans", fields: [planId], references: [id], onDelete: SetNull)

  @@index([toolId, createdAt])
  @@index([userId, createdAt])
  @@index([status, createdAt])
  @@map("sam_tool_executions")
}

// Confidence calibration scores
model SAMConfidenceScore {
  id                  String                     @id @default(cuid())
  userId              String
  sessionId           String?
  responseId          String                     // ID of the response being scored
  responseType        SAMConfidenceResponseType

  // Prediction
  predictedConfidence Float                      // 0-1 predicted confidence
  factors             Json                       @default("[]") // Array of contributing factors
  predictedAt         DateTime                   @default(now())

  // Outcome (filled in after verification)
  accurate            Boolean?                   // Was the response accurate?
  userVerified        Boolean?                   // Did user verify?
  verificationMethod  SAMVerificationMethod?
  qualityScore        Float?                     // Quality rating 0-1
  outcomeRecordedAt   DateTime?
  outcomeNotes        String?                    @db.Text

  // Metadata
  metadata            Json?

  // Relations
  user                User                       @relation("SAMConfidenceScores", fields: [userId], references: [id], onDelete: Cascade)

  @@index([responseType, predictedAt])
  @@index([userId, predictedAt])
  @@index([accurate, predictedAt])
  @@map("sam_confidence_scores")
}

// Memory retrieval telemetry
model SAMMemoryRetrieval {
  id                 String              @id @default(cuid())
  userId             String
  sessionId          String?

  // Query details
  query              String              @db.Text
  source             SAMMemorySourceType

  // Results
  resultCount        Int                 @default(0)
  topRelevanceScore  Float               @default(0)
  avgRelevanceScore  Float               @default(0)

  // Performance
  cacheHit           Boolean             @default(false)
  latencyMs          Int

  // User feedback (optional)
  feedbackHelpful    Boolean?
  feedbackRating     Int?                // 1-5 rating
  feedbackComment    String?             @db.Text
  feedbackProvidedAt DateTime?

  // Metadata
  metadata           Json?
  timestamp          DateTime            @default(now())

  // Relations
  user               User                @relation("SAMMemoryRetrievals", fields: [userId], references: [id], onDelete: Cascade)

  @@index([source, timestamp])
  @@index([userId, timestamp])
  @@index([cacheHit, timestamp])
  @@map("sam_memory_retrievals")
}

// Plan lifecycle events for tracking
model SAMPlanLifecycleEvent {
  id            String           @id @default(cuid())
  planId        String
  userId        String
  eventType     SAMPlanEventType
  stepId        String?
  previousState String?
  newState      String?
  metadata      Json?
  timestamp     DateTime         @default(now())

  // Relations
  user          User             @relation("SAMPlanLifecycleEvents", fields: [userId], references: [id], onDelete: Cascade)
  plan          SAMExecutionPlan @relation("SAMPlanLifecycleEvents", fields: [planId], references: [id], onDelete: Cascade)

  @@index([planId, timestamp])
  @@index([userId, timestamp])
  @@index([eventType, timestamp])
  @@map("sam_plan_lifecycle_events")
}

// Aggregated metrics for dashboards
model SAMAggregatedMetrics {
  id          String   @id @default(cuid())
  metricType  String   // e.g., "tool_success_rate", "memory_quality", "confidence_calibration"
  period      String   // "hourly", "daily", "weekly"
  periodStart DateTime
  periodEnd   DateTime
  data        Json     // Aggregated metric data
  createdAt   DateTime @default(now())

  @@unique([metricType, period, periodStart])
  @@index([metricType, periodStart])
  @@map("sam_aggregated_metrics")
}

// ==========================================
// REAL-TIME PRESENCE MODELS
// ==========================================

// User presence tracking for real-time features
model SAMUserPresence {
  id              String              @id @default(cuid())
  userId          String              @unique
  connectionId    String              @unique
  status          SAMPresenceStatus   @default(OFFLINE)
  
  // Timestamps
  lastActivityAt  DateTime            @default(now())
  connectedAt     DateTime            @default(now())
  disconnectedAt  DateTime?
  
  // Device/Browser metadata
  deviceType      String?             // "desktop", "mobile", "tablet"
  browser         String?
  os              String?
  
  // Location context
  courseId        String?
  chapterId       String?
  sectionId       String?
  pageUrl         String?
  
  // Session context
  planId          String?
  stepId          String?
  goalId          String?
  
  // Subscriptions (stored as JSON array of channel names)
  subscriptions   String[]            @default([])
  
  // Additional metadata
  metadata        Json?
  
  // Timestamps
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  
  // Relations
  user            User                @relation("SAMUserPresence", fields: [userId], references: [id], onDelete: Cascade)
  course          Course?             @relation("SAMPresenceCourses", fields: [courseId], references: [id], onDelete: SetNull)
  chapter         Chapter?            @relation("SAMPresenceChapters", fields: [chapterId], references: [id], onDelete: SetNull)
  section         Section?            @relation("SAMPresenceSections", fields: [sectionId], references: [id], onDelete: SetNull)
  
  @@index([status])
  @@index([connectionId])
  @@index([lastActivityAt])
  @@index([courseId])
  @@map("sam_user_presence")
}

// Presence change history for analytics
model SAMPresenceHistory {
  id              String                    @id @default(cuid())
  userId          String
  previousStatus  SAMPresenceStatus
  newStatus       SAMPresenceStatus
  reason          SAMPresenceChangeReason
  changedAt       DateTime                  @default(now())

  // Context at time of change
  courseId        String?
  pageUrl         String?
  sessionDuration Int?                      // seconds since connected

  // Relations
  user            User                      @relation("SAMPresenceHistory", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, changedAt])
  @@index([newStatus, changedAt])
  @@map("sam_presence_history")
}

// ============================================================================
// SAM FEEDBACK
// User feedback on SAM responses for quality improvement
// ============================================================================

enum SAMFeedbackRating {
  HELPFUL
  NOT_HELPFUL
}

model SAMFeedback {
  id          String            @id @default(cuid())
  userId      String
  messageId   String            // ID of the SAM message being rated
  sessionId   String            // SAM session ID
  rating      SAMFeedbackRating
  comment     String?           @db.Text

  // Context at time of feedback
  pageUrl     String?
  courseId    String?
  topicId     String?

  // Timestamps
  createdAt   DateTime          @default(now())

  // Relations
  user        User              @relation("SAMFeedback", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([messageId])
  @@index([sessionId])
  @@index([rating, createdAt])
  @@map("sam_feedback")
}

// ==========================================
// Source: 18-dashboard.prisma
// ==========================================

// ==========================================
// Dashboard & Activity Stream
// ==========================================
// Models for the new Canvas LMS-inspired dashboard
// including activities, study plans, todos, goals
// Created: 2025-11-09
// ==========================================

// Note: Enums ActivityType, SessionStatus, GoalStatus, NotificationType
// are already defined in 01-enums.prisma - using those instead

enum DashboardActivityStatus {
  NOT_STARTED
  IN_PROGRESS
  SUBMITTED
  GRADED
  OVERDUE
  CANCELLED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum PlanStatus {
  ACTIVE
  PAUSED
  COMPLETED
  ARCHIVED
}

enum DashboardGoalType {
  COURSE_COMPLETION
  SKILL_MASTERY
  TIME_MILESTONE
  GRADE_TARGET
  CERTIFICATION
  CUSTOM
}

enum DifficultyLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum CourseType {
  VIDEO
  READING
  PRACTICE
  MIXED
}

enum PostFrequency {
  DAILY
  WEEKLY
  BIWEEKLY
  MONTHLY
}

enum ContentGoal {
  TRAFFIC
  PORTFOLIO
  MONETIZATION
  KNOWLEDGE_SHARING
}

enum NotificationCategory {
  DONE
  MISSED
  UPCOMING
  ACHIEVEMENT
}

enum ReminderChannel {
  EMAIL
  PUSH
  IN_APP
  SMS
}

enum ViewMode {
  GRID
  LIST
}

enum Density {
  COMPACT
  COMFORTABLE
  SPACIOUS
}

enum GroupBy {
  DATE
  COURSE
  TYPE
  PRIORITY
}

enum SortBy {
  DUE_DATE
  CREATED_DATE
  PRIORITY
  POINTS
}

enum DashboardActivityType {
  ASSIGNMENT
  QUIZ
  EXAM
  READING
  VIDEO
  DISCUSSION
  STUDY_SESSION
  PROJECT
  PRESENTATION
  CUSTOM
}

// ==========================================
// Activity Stream
// ==========================================

model DashboardActivity {
  id              String         @id @default(cuid())
  userId          String
  user            User           @relation("UserDashboardActivities", fields: [userId], references: [id], onDelete: Cascade)

  type            DashboardActivityType
  title           String
  description     String?

  courseId        String?
  course          Course?        @relation("CourseDashboardActivities", fields: [courseId], references: [id], onDelete: SetNull)

  dueDate         DateTime?
  completedAt     DateTime?
  status          DashboardActivityStatus @default(NOT_STARTED)

  points          Int            @default(0)
  priority        Priority       @default(MEDIUM)

  // Google Calendar Integration
  googleEventId   String?        @unique
  calendarSynced  Boolean        @default(false)
  lastSyncedAt    DateTime?

  // Metadata
  estimatedMinutes Int?
  actualMinutes   Int?
  tags            String[]

  // Relations
  reminders       DashboardReminder[]
  notes           DashboardNote[]
  todos           DashboardTodo[]

  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([userId, dueDate])
  @@index([userId, status])
  @@index([courseId])
  @@map("dashboard_activities")
}

// ==========================================
// Study Plan
// ==========================================

model DashboardStudyPlan {
  id              String         @id @default(cuid())
  userId          String
  user            User           @relation("UserStudyPlans", fields: [userId], references: [id], onDelete: Cascade)

  // Plan type: "enrolled" or "new"
  planType        String         @default("enrolled")

  // For enrolled courses
  enrolledCourseId String?
  enrolledCourse   Course?        @relation("CourseStudyPlans", fields: [enrolledCourseId], references: [id], onDelete: SetNull)

  // For new courses to enroll
  newCourseTitle       String?
  newCourseDescription String?
  newCourseUrl         String?
  newCoursePlatform    String?

  // Common fields
  title           String
  description     String?

  startDate       DateTime
  endDate         DateTime
  weeklyHoursGoal Int            @default(10)
  dailyStudyTime  Int?
  studyDaysPerWeek Int?

  status          PlanStatus     @default(ACTIVE)

  // AI Generated
  aiGenerated     Boolean        @default(false)
  aiPrompt        String?

  sessions        DashboardStudySession[]

  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([userId, status])
  @@index([enrolledCourseId])
  @@map("dashboard_study_plans")
}

model DashboardStudySession {
  id              String         @id @default(cuid())

  studyPlanId     String?
  studyPlan       DashboardStudyPlan? @relation(fields: [studyPlanId], references: [id], onDelete: SetNull)

  userId          String
  user            User           @relation("UserStudySessions", fields: [userId], references: [id], onDelete: Cascade)

  courseId        String?
  course          Course?        @relation("CourseStudySessions", fields: [courseId], references: [id], onDelete: SetNull)

  title           String
  startTime       DateTime
  duration        Int            @default(60) // minutes

  actualStartTime DateTime?
  actualEndTime   DateTime?

  status          SessionStatus  @default(ACTIVE)

  // Google Calendar
  syncToGoogleCalendar Boolean   @default(false)
  googleEventId   String?        @unique
  calendarSynced  Boolean        @default(false)

  notes           String?
  productivity    Int?           @default(0) // 0-100 rating

  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([userId, startTime])
  @@index([courseId])
  @@map("dashboard_study_sessions")
}

// ==========================================
// Course Plan
// ==========================================

model DashboardCoursePlan {
  id                    String          @id @default(cuid())
  userId                String
  user                  User            @relation("UserCoursePlans", fields: [userId], references: [id], onDelete: Cascade)

  title                 String
  description           String?         @db.Text

  startDate             DateTime
  targetCompletionDate  DateTime?

  daysPerWeek           Int             @default(3)
  timePerSession        Int             @default(60) // minutes

  difficultyLevel       DifficultyLevel @default(BEGINNER)
  courseType            CourseType      @default(MIXED)

  learningGoals         String?         @db.Text

  // Notifications
  studyReminders        Boolean         @default(true)
  progressCheckins      Boolean         @default(true)
  milestoneAlerts       Boolean         @default(true)

  // Google Calendar
  syncToGoogleCalendar  Boolean         @default(false)
  googleCalendarIds     String[]        // Array of event IDs created

  status                PlanStatus      @default(ACTIVE)

  courseId              String?
  course                Course?         @relation("CourseCoursePlans", fields: [courseId], references: [id], onDelete: SetNull)

  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt

  @@index([userId, status])
  @@index([userId, startDate])
  @@map("dashboard_course_plans")
}

// ==========================================
// Blog Plan
// ==========================================

model DashboardBlogPlan {
  id                    String          @id @default(cuid())
  userId                String
  user                  User            @relation("UserBlogPlans", fields: [userId], references: [id], onDelete: Cascade)

  title                 String
  description           String?         @db.Text
  topics                String[]

  startPublishingDate   DateTime
  postFrequency         PostFrequency   @default(WEEKLY)
  specificDays          String?         // e.g., "Monday, Thursday"

  platform              String?
  targetAudience        String?         @db.Text
  contentGoal           ContentGoal     @default(KNOWLEDGE_SHARING)

  // Notifications
  writingReminders      Boolean         @default(true)
  publishingReminders   Boolean         @default(true)
  deadlineAlerts        Boolean         @default(true)

  // Google Calendar
  syncToGoogleCalendar  Boolean         @default(false)
  googleCalendarIds     String[]        // Array of event IDs for writing/publishing

  status                PlanStatus      @default(ACTIVE)

  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt

  @@index([userId, status])
  @@index([userId, startPublishingDate])
  @@map("dashboard_blog_plans")
}

// ==========================================
// Todos
// ==========================================

model DashboardTodo {
  id              String         @id @default(cuid())
  userId          String
  user            User           @relation("UserTodos", fields: [userId], references: [id], onDelete: Cascade)

  title           String
  description     String?

  completed       Boolean        @default(false)
  completedAt     DateTime?

  dueDate         DateTime?
  priority        Priority       @default(MEDIUM)

  courseId        String?
  course          Course?        @relation("CourseTodos", fields: [courseId], references: [id], onDelete: SetNull)

  activityId      String?        @unique
  activity        DashboardActivity? @relation(fields: [activityId], references: [id], onDelete: SetNull)

  estimatedMinutes Int?
  tags            String[]

  position        Int            @default(0) // For ordering

  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([userId, completed])
  @@index([userId, dueDate])
  @@map("dashboard_todos")
}

// ==========================================
// Goals
// ==========================================

model DashboardGoal {
  id              String         @id @default(cuid())
  userId          String
  user            User           @relation("UserGoals", fields: [userId], references: [id], onDelete: Cascade)

  title           String
  description     String?

  type            DashboardGoalType
  targetDate      DateTime

  status          GoalStatus     @default(ACTIVE)
  progress        Int            @default(0) // 0-100

  courseId        String?
  course          Course?        @relation("CourseGoals", fields: [courseId], references: [id], onDelete: SetNull)

  milestones      DashboardMilestone[]

  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([userId, status])
  @@map("dashboard_goals")
}

model DashboardMilestone {
  id              String         @id @default(cuid())

  goalId          String
  goal            DashboardGoal  @relation(fields: [goalId], references: [id], onDelete: Cascade)

  title           String
  targetDate      DateTime

  completed       Boolean        @default(false)
  completedAt     DateTime?

  position        Int            @default(0)

  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([goalId, position])
  @@map("dashboard_milestones")
}

// ==========================================
// Notifications
// ==========================================

model DashboardNotification {
  id              String         @id @default(cuid())
  userId          String
  user            User           @relation("UserNotifications", fields: [userId], references: [id], onDelete: Cascade)

  type            NotificationType
  category        NotificationCategory

  title           String
  description     String?

  read            Boolean        @default(false)
  readAt          DateTime?

  actionable      Boolean        @default(false)
  actionUrl       String?
  actionLabel     String?

  metadata        Json?          // Extra data (courseId, points, etc.)

  expiresAt       DateTime?

  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([userId, read])
  @@index([userId, category])
  @@map("dashboard_notifications")
}

// ==========================================
// Reminders
// ==========================================

model DashboardReminder {
  id              String         @id @default(cuid())
  userId          String
  user            User           @relation("UserReminders", fields: [userId], references: [id], onDelete: Cascade)

  activityId      String?
  activity        DashboardActivity? @relation(fields: [activityId], references: [id], onDelete: Cascade)

  title           String
  description     String?

  remindAt        DateTime
  reminded        Boolean        @default(false)
  remindedAt      DateTime?

  recurring       Boolean        @default(false)
  recurringPattern String?       // cron-like pattern

  channels        ReminderChannel[]

  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([userId, remindAt])
  @@index([remindAt, reminded])
  @@map("dashboard_reminders")
}

