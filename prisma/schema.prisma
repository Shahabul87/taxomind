generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                                      String                   @id @default(cuid())
  name                                    String?
  email                                   String?                  @unique
  emailVerified                           DateTime?
  image                                   String?
  password                                String?
  confirmPassword                         String?
  role                                    UserRole                 @default(USER)
  isTwoFactorEnabled                      Boolean                  @default(false)
  phone                                   String?
  createdAt                               DateTime                 @default(now())
  AIContentGeneration                     AIContentGeneration[]
  AIContentTemplate                       AIContentTemplate[]
  AIGeneratedContent                      AIGeneratedContent[]
  AIUsageMetrics                          AIUsageMetrics[]
  accounts                                Account[]
  ActiveSession                           ActiveSession[]
  Activity                                Activity[]
  Article                                 Article[]
  AuthAudit                               AuthAudit[]
  BackupCode                              BackupCode[]
  Bill                                    Bill[]
  Blog                                    Blog[]
  CalendarEvent                           CalendarEvent[]
  Comment                                 Comment[]
  ContentCollection                       ContentCollection[]
  ContentItem                             ContentItem[]
  courses                                 Course[]
  courseReviews                           CourseReview[]
  CustomTab                               CustomTab[]
  Enrollment                              Enrollment[]
  FavoriteArticle                         FavoriteArticle[]
  FavoriteAudio                           FavoriteAudio[]
  FavoriteBlog                            FavoriteBlog[]
  FavoriteImage                           FavoriteImage[]
  FavoriteVideo                           FavoriteVideo[]
  Goal                                    Goal[]
  Group                                   Group[]
  GroupDiscussion                         GroupDiscussion[]
  GroupDiscussionComment                  GroupDiscussionComment[]
  GroupDiscussionLike                     GroupDiscussionLike[]
  GroupEvent_GroupEvent_creatorIdToUser   GroupEvent[]             @relation("GroupEvent_creatorIdToUser")
  GroupEvent_GroupEvent_organizerIdToUser GroupEvent[]             @relation("GroupEvent_organizerIdToUser")
  GroupEventAttendee                      GroupEventAttendee[]
  GroupMember                             GroupMember[]
  GroupNotification                       GroupNotification[]
  GroupResource                           GroupResource[]
  Idea_Idea_userIdToUser                  Idea[]                   @relation("Idea_userIdToUser")
  IdeaComment                             IdeaComment[]
  IdeaLike                                IdeaLike[]
  LearningPath                            LearningPath[]
  Message_Message_recipientIdToUser       Message[]                @relation("Message_recipientIdToUser")
  Message_Message_senderIdToUser          Message[]                @relation("Message_senderIdToUser")
  Mind_Mind_userIdToUser                  Mind[]                   @relation("Mind_userIdToUser")
  MindLike                                MindLike[]
  Note                                    Note[]
  Notification                            Notification[]
  PathEnrollment                          PathEnrollment[]
  PathRecommendation                      PathRecommendation[]
  Post                                    Post[]
  profileLinks                            ProfileLink[]
  reactions                               Reaction[]
  Reply                                   Reply[]
  SocialMediaAccount                      SocialMediaAccount[]
  Subscription                            Subscription[]
  SupportTicket                           SupportTicket[]
  TOTPSecret                              TOTPSecret?
  Task                                    Task[]
  twoFactorConfirmation                   TwoFactorConfirmation?
  UserAIPreferences                       UserAIPreferences?
  UserAnalytics                           UserAnalytics[]
  UserCalendarSettings                    UserCalendarSettings?
  UserExamAttempt                         UserExamAttempt[]
  UserSubscription                        UserSubscription[]
  Video                                   Video[]
  learning_metrics                        learning_metrics[]
  learning_sessions                       learning_sessions[]
  performance_metrics                     performance_metrics[]
  progress_alerts                         progress_alerts[]
  realtime_activities                     realtime_activities[]
  study_streaks                           study_streaks[]
  user_achievements                       user_achievements[]
  user_progress                           user_progress[]
  Idea_IdeaCollaborators                  Idea[]                   @relation("IdeaCollaborators")
  Mind_MindCollaborators                  Mind[]                   @relation("MindCollaborators")
  
  // Enterprise Relations
  organizationMemberships                 OrganizationUser[]       @relation("OrganizationUsers")
  authoredContentVersions                 ContentVersion[]         @relation("ContentVersionAuthor")
  approvedContentVersions                 ContentVersion[]         @relation("ContentVersionApprover")
  auditLogs                               AuditLog[]               @relation("AuditLogUser")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model VerificationToken {
  id      String   @id @default(cuid())
  email   String
  token   String   @unique
  expires DateTime

  @@unique([email, token])
}

model PasswordResetToken {
  id      String   @id @default(cuid())
  email   String
  token   String   @unique
  expires DateTime

  @@unique([email, token])
}

model TwoFactorToken {
  id      String   @id @default(cuid())
  email   String
  token   String   @unique
  expires DateTime

  @@unique([email, token])
}

model TwoFactorConfirmation {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Category {
  id      String   @id @default(uuid())
  name    String   @unique
  courses Course[]
  Group   Group[]
}

model Course {
  id                  String                @id @default(uuid())
  title               String
  description         String?
  cleanDescription    String?
  imageUrl            String?
  price               Float?
  isPublished         Boolean               @default(false)
  courseGoals         String?
  categoryId          String?
  courseRatings       String?
  activeLearners      Int?
  userId              String
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
  whatYouWillLearn    String[]              @default([])
  slug                String?
  subtitle            String?
  isFeatured          Boolean               @default(false)
  AIGeneratedContent  AIGeneratedContent[]
  attachments         Attachment[]
  chapters            Chapter[]
  category            Category?             @relation(fields: [categoryId], references: [id])
  user                User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  reviews             CourseReview[]
  Enrollment          Enrollment[]
  Group               Group[]
  Purchase            Purchase[]
  learning_metrics    learning_metrics[]
  learning_sessions   learning_sessions[]
  progress_alerts     progress_alerts[]
  realtime_activities realtime_activities[]
  study_streaks       study_streaks[]
  user_achievements   user_achievements[]
  user_progress       user_progress[]

  // Enterprise Relations
  organizationId      String?
  organization        Organization?         @relation("OrganizationCourses", fields: [organizationId], references: [id])

  @@index([categoryId])
  @@index([organizationId])
}

model Attachment {
  id        String   @id @default(uuid())
  name      String
  url       String
  courseId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([courseId])
}

model Chapter {
  id                  String                @id @default(uuid())
  title               String
  description         String?
  courseGoals         String?
  learningOutcomes    String?
  position            Int
  isPublished         Boolean               @default(false)
  isFree              Boolean               @default(false)
  sectionCount        Int?
  totalDuration       Int?
  courseId            String
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
  estimatedTime       String?
  difficulty          String?
  prerequisites       String?
  resources           String?
  status              String?
  AIGeneratedContent  AIGeneratedContent[]
  course              Course                @relation(fields: [courseId], references: [id], onDelete: Cascade)
  sections            Section[]
  learning_sessions   learning_sessions[]
  progress_alerts     progress_alerts[]
  realtime_activities realtime_activities[]
  user_progress       user_progress[]

  @@index([courseId])
}

model Section {
  id                  String                @id @default(uuid())
  title               String
  videoUrl            String?
  position            Int
  isPublished         Boolean               @default(false)
  isFree              Boolean               @default(false)
  duration            Int?
  chapterId           String
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
  type                String?
  isPreview           Boolean?
  completionStatus    String?
  resourceUrls        String?
  AIGeneratedContent  AIGeneratedContent[]
  articles            Article[]
  blogs               Blog[]
  codeExplanations    CodeExplanation[]
  exams               Exam[]
  mathExplanations    MathExplanation[]
  notes               Note[]
  Question            Question[]
  chapter             Chapter               @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  videos              Video[]
  realtime_activities realtime_activities[]
  user_progress       user_progress[]

  @@index([chapterId])
}

model Video {
  id          String   @id @default(uuid())
  title       String
  description String?
  youtubeUrl  String?
  url         String?
  duration    Int?
  rating      Int?
  position    Int
  isPublished Boolean  @default(false)
  sectionId   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  thumbnail   String?
  platform    String?
  embedUrl    String?
  author      String?
  userId      String
  section     Section  @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  User        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([sectionId])
  @@index([userId])
}

model Blog {
  id          String    @id @default(uuid())
  title       String
  url         String    @db.VarChar(255)
  author      String?
  description String?
  rating      Int?
  publishedAt DateTime?
  position    Int?
  sectionId   String?
  userId      String
  category    String?
  isPublished Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  section     Section?  @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  User        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Article {
  id          String    @id @default(uuid())
  title       String
  content     String
  url         String    @db.VarChar(255)
  source      String?
  summary     String?
  publishedAt DateTime?
  sectionId   String?
  userId      String
  category    String?
  isPublished Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  section     Section?  @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  User        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Note {
  id          String   @id @default(uuid())
  title       String
  content     String
  isImportant Boolean  @default(false)
  position    Int
  sectionId   String?
  userId      String
  category    String?
  isPublished Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  section     Section? @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  User        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CodeExplanation {
  id          String   @id @default(uuid())
  heading     String?
  code        String?
  explanation String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  sectionId   String?
  language    String?  @default("typescript")
  order       Int?     @default(0)
  section     Section? @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  @@index([sectionId])
}

model MathExplanation {
  id          String   @id @default(uuid())
  title       String
  content     String
  latex       String?
  isPublished Boolean  @default(false)
  sectionId   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  equation    String?
  imageUrl    String?
  mode        String?
  section     Section  @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  @@index([sectionId])
}

model Purchase {
  id        String   @id @default(uuid())
  userId    String
  courseId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  Course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@index([courseId])
}

model StripeCustomer {
  id               String   @id @default(uuid())
  userId           String   @unique
  stripeCustomerId String   @unique
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Post {
  id                 String               @id @default(cuid())
  userId             String
  title              String
  description        String?
  imageUrl           String?
  published          Boolean?
  category           String?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  views              Int                  @default(0)
  body               String               @default("")
  isArchived         Boolean              @default(false)
  authorId           String?
  comments           Comment[]
  User               User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  PostChapterSection PostChapterSection[]
  PostImageSection   PostImageSection[]
  Reply              Reply[]
  Tag                Tag[]

  @@index([userId])
}

model Comment {
  id        String     @id @default(cuid())
  userId    String
  postId    String
  createdAt DateTime   @default(now())
  content   String
  updatedAt DateTime   @updatedAt
  post      Post       @relation(fields: [postId], references: [id], onDelete: Cascade)
  User      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  reactions Reaction[]
  replies   Reply[]

  @@index([postId])
  @@index([userId])
}

model Reply {
  id            String     @id @default(cuid())
  content       String
  userId        String
  postId        String
  commentId     String
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  parentReplyId String?
  depth         Int        @default(0)
  path          String?
  Reaction      Reaction[]
  comment       Comment    @relation(fields: [commentId], references: [id], onDelete: Cascade)
  Reply         Reply?     @relation("ReplyToReply", fields: [parentReplyId], references: [id])
  other_Reply   Reply[]    @relation("ReplyToReply")
  Post          Post       @relation(fields: [postId], references: [id], onDelete: Cascade)
  User          User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([commentId])
  @@index([parentReplyId])
  @@index([path])
  @@index([postId])
  @@index([userId])
}

model Reaction {
  id        String   @id @default(cuid())
  type      String
  userId    String
  commentId String?
  replyId   String?
  createdAt DateTime @default(now())
  updatedAt DateTime
  comment   Comment? @relation(fields: [commentId], references: [id], onDelete: Cascade)
  Reply     Reply?   @relation(fields: [replyId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([commentId])
  @@index([replyId])
  @@index([userId])
}

model ProfileLink {
  id        String   @id @default(cuid())
  userId    String
  platform  String
  url       String
  position  Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  metadata  Json?
  user      User     @relation(fields: [userId], references: [id])
}

model Exam {
  id               String            @id @default(uuid())
  title            String
  description      String?
  isPublished      Boolean           @default(false)
  sectionId        String
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  attempts         Int               @default(1)
  endDate          DateTime?
  instructions     String?
  isActive         Boolean           @default(true)
  passingScore     Float             @default(70)
  showResults      Boolean           @default(true)
  shuffleQuestions Boolean           @default(false)
  startDate        DateTime?
  timeLimit        Int?
  section          Section           @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  ExamQuestion     ExamQuestion[]
  UserExamAttempt  UserExamAttempt[]

  @@index([sectionId])
  @@index([isPublished, isActive])
}

model Question {
  id        String   @id @default(uuid())
  text      String
  sectionId String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  Answer    Answer[]
  Section   Section? @relation(fields: [sectionId], references: [id], onDelete: Cascade)
}

model CourseReview {
  id        String   @id @default(uuid())
  rating    Int      @default(0)
  comment   String
  courseId  String
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([courseId])
  @@index([userId])
}

model Group {
  id                String              @id @default(uuid())
  name              String
  description       String?
  imageUrl          String?
  privacy           String?
  rules             String[]            @default([])
  tags              String[]            @default([])
  isPrivate         Boolean             @default(false)
  category          String?
  categoryId        String?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  creatorId         String
  courseId          String?
  Category          Category?           @relation(fields: [categoryId], references: [id])
  Course            Course?             @relation(fields: [courseId], references: [id])
  User              User                @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  GroupDiscussion   GroupDiscussion[]
  GroupEvent        GroupEvent[]
  GroupMember       GroupMember[]
  GroupNotification GroupNotification[]
  GroupResource     GroupResource[]

  @@index([categoryId])
  @@index([courseId])
  @@index([creatorId])
}

model AIContentGeneration {
  id                String              @id
  requestType       AIGenerationRequest
  status            GenerationStatus    @default(PENDING)
  input             Json
  parameters        Json?
  output            Json?
  errorMessage      String?
  tokensUsed        Int?
  generationTime    Int?
  cost              Float?
  userId            String
  templateId        String?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime
  AIContentTemplate AIContentTemplate?  @relation(fields: [templateId], references: [id])
  User              User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([requestType])
  @@index([status])
  @@index([userId])
}

model AIContentTemplate {
  id                  String                @id
  name                String
  description         String?
  templateType        AITemplateType
  category            String?
  promptTemplate      String
  contentStructure    Json?
  parameters          Json?
  usageCount          Int                   @default(0)
  averageRating       Float?
  isActive            Boolean               @default(true)
  isPublic            Boolean               @default(false)
  creatorId           String?
  createdAt           DateTime              @default(now())
  updatedAt           DateTime
  AIContentGeneration AIContentGeneration[]
  User                User?                 @relation(fields: [creatorId], references: [id])
  AIGeneratedContent  AIGeneratedContent[]

  @@index([creatorId])
  @@index([templateType])
}

model AIGeneratedContent {
  id                String             @id
  contentType       AIContentType
  title             String
  content           String
  metadata          Json?
  promptUsed        String
  model             String             @default("claude-3-5-sonnet-20241022")
  tokensUsed        Int?
  generationTime    Int?
  rating            Float?
  isApproved        Boolean            @default(false)
  usageCount        Int                @default(0)
  templateId        String?
  creatorId         String
  courseId          String?
  chapterId         String?
  sectionId         String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime
  Chapter           Chapter?           @relation(fields: [chapterId], references: [id])
  Course            Course?            @relation(fields: [courseId], references: [id])
  User              User               @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  Section           Section?           @relation(fields: [sectionId], references: [id])
  AIContentTemplate AIContentTemplate? @relation(fields: [templateId], references: [id])

  @@index([chapterId])
  @@index([contentType])
  @@index([courseId])
  @@index([creatorId])
  @@index([sectionId])
}

model AIUsageMetrics {
  id                  String        @id
  userId              String
  date                DateTime      @db.Date
  period              MetricsPeriod @default(DAILY)
  totalGenerations    Int           @default(0)
  totalTokens         Int           @default(0)
  totalCost           Float         @default(0)
  courseGenerations   Int           @default(0)
  chapterGenerations  Int           @default(0)
  lessonGenerations   Int           @default(0)
  examGenerations     Int           @default(0)
  exerciseGenerations Int           @default(0)
  averageRating       Float?
  approvalRate        Float?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime
  User                User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date, period])
  @@index([date])
  @@index([userId])
}

model ActiveSession {
  id           String   @id
  userId       String
  sessionToken String   @unique
  ipAddress    String
  userAgent    String?
  browser      String?
  os           String?
  deviceType   String?
  lastActiveAt DateTime @default(now())
  expiresAt    DateTime
  isRevoked    Boolean  @default(false)
  User         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([expiresAt])
  @@index([sessionToken])
  @@index([userId])
}

model Activity {
  id            String    @id
  title         String
  description   String?
  type          String
  status        String
  priority      String
  createdAt     DateTime  @default(now())
  updatedAt     DateTime
  dueDate       DateTime?
  completedDate DateTime?
  progress      Int       @default(0)
  userId        String
  parentId      String?
  tags          String[]  @default([])
  metadata      Json?
  User          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([dueDate])
  @@index([status])
  @@index([type])
  @@index([userId])
}

model Answer {
  id         String   @id
  text       String
  isCorrect  Boolean  @default(false)
  questionId String
  createdAt  DateTime @default(now())
  updatedAt  DateTime
  Question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
}

model AuthAudit {
  id          String   @id
  userId      String?
  email       String?
  action      String
  ipAddress   String
  userAgent   String?
  browser     String?
  os          String?
  deviceType  String?
  countryCode String?
  city        String?
  status      String
  details     String?
  createdAt   DateTime @default(now())
  User        User?    @relation(fields: [userId], references: [id])

  @@index([action])
  @@index([createdAt])
  @@index([ipAddress])
  @@index([userId])
}

model BackupCode {
  id        String   @id
  userId    String
  code      String
  isUsed    Boolean  @default(false)
  createdAt DateTime @default(now())
  User      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, code])
  @@index([userId])
}

model Bill {
  id              String           @id
  title           String
  description     String?
  category        BillCategory
  amount          Float
  currency        String           @default("USD")
  startDate       DateTime
  dueDate         DateTime
  status          BillStatus       @default(UNPAID)
  recurringType   RecurringType?
  recurringPeriod Int?
  notifyBefore    Int              @default(3)
  notifyEmail     Boolean          @default(true)
  notifySMS       Boolean          @default(false)
  lastPaidAmount  Float?
  lastPaidDate    DateTime?
  autoPayEnabled  Boolean          @default(false)
  paymentMethod   String?
  accountNumber   String?
  provider        String?
  accountId       String?
  website         String?
  supportContact  String?
  notes           String?
  userId          String
  createdAt       DateTime         @default(now())
  updatedAt       DateTime
  User            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  BillAttachment  BillAttachment[]
  BillPayment     BillPayment[]

  @@index([dueDate])
  @@index([userId])
}

model BillAttachment {
  id        String   @id
  name      String
  url       String
  type      String
  size      Int
  billId    String
  createdAt DateTime @default(now())
  Bill      Bill     @relation(fields: [billId], references: [id], onDelete: Cascade)

  @@index([billId])
}

model BillPayment {
  id          String   @id
  amount      Float
  paymentDate DateTime
  method      String
  status      String
  reference   String?
  billId      String
  createdAt   DateTime @default(now())
  Bill        Bill     @relation(fields: [billId], references: [id], onDelete: Cascade)

  @@index([billId])
}

model CalendarEvent {
  id                  String          @id
  title               String
  description         String?
  startDate           DateTime
  endDate             DateTime
  location            String?
  userId              String
  createdAt           DateTime        @default(now())
  updatedAt           DateTime
  recurringEndDate    DateTime?
  parentEventId       String?
  externalId          String?
  source              String?
  lastSync            DateTime?
  allDay              Boolean         @default(false)
  category            String
  color               String?
  recurringType       String?
  taskId              String?
  CalendarEvent       CalendarEvent?  @relation("CalendarEventToCalendarEvent", fields: [parentEventId], references: [id])
  other_CalendarEvent CalendarEvent[] @relation("CalendarEventToCalendarEvent")
  User                User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([externalId, source])
