model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId]) // PERFORMANCE FIX: Index for getAccountByUserId query
}

model VerificationToken {
  id      String   @id @default(cuid())
  email   String
  token   String   @unique
  expires DateTime

  @@unique([email, token])
}

model PasswordResetToken {
  id      String   @id @default(cuid())
  email   String
  token   String   @unique
  expires DateTime

  @@unique([email, token])
}

model TwoFactorToken {
  id      String   @id @default(cuid())
  email   String
  token   String   @unique
  expires DateTime

  @@unique([email, token])
}

model TwoFactorConfirmation {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ActiveSession {
  id           String   @id
  userId       String
  sessionToken String   @unique
  ipAddress    String
  userAgent    String?
  browser      String?
  os           String?
  deviceType   String?
  deviceName   String?  // Added for settings page
  location     String?  // Added for settings page
  lastActive   DateTime @default(now())  // Changed from lastActiveAt to match usage
  createdAt    DateTime @default(now())  // Added for settings page
  expiresAt    DateTime
  isRevoked    Boolean  @default(false)
  User         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([expiresAt])
  @@index([sessionToken])
  @@index([userId])
}

model AuthAudit {
  id          String   @id
  userId      String?
  email       String?
  action      String
  ipAddress   String
  userAgent   String?
  browser     String?
  os          String?
  deviceType  String?
  countryCode String?
  city        String?
  status      String
  details     String?
  createdAt   DateTime @default(now())
  User        User?    @relation(fields: [userId], references: [id])

  @@index([action])
  @@index([createdAt])
  @@index([ipAddress])
  @@index([userId])
}

model BackupCode {
  id        String   @id
  userId    String
  code      String
  isUsed    Boolean  @default(false)
  createdAt DateTime @default(now())
  User      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, code])
  @@index([userId])
}

model LoginAttempt {
  id        String   @id
  email     String
  ipAddress String
  userAgent String?
  success   Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([email, ipAddress])
  @@index([ipAddress])
}

model TOTPSecret {
  id        String   @id
  userId    String   @unique
  secret    String
  createdAt DateTime @default(now())
  updatedAt DateTime
  User      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model AuthSession {
  id                    String    @id @default(cuid())
  userId                String
  token                 String    @unique
  userAgent             String?
  ipAddress             String?
  deviceInfo            Json?
  // Session fingerprinting fields
  fingerprintHash       String?
  fingerprintData       Json? // Stores the full fingerprint for analysis
  deviceId              String? // Unique device identifier
  deviceName            String? // Human-readable device name
  isTrustedDevice       Boolean   @default(false)
  trustEstablishedAt    DateTime?
  lastFingerprintCheck  DateTime?
  fingerprintMismatches Int       @default(0)
  riskLevel             String    @default("LOW") // LOW, MEDIUM, HIGH, CRITICAL
  // Session management
  createdAt             DateTime  @default(now())
  expiresAt             DateTime
  lastActivity          DateTime  @default(now())
  isActive              Boolean   @default(true)
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@index([expiresAt])
  @@index([fingerprintHash])
  @@index([deviceId])
  @@index([userId, isTrustedDevice])
  @@map("auth_sessions")
}

model Permission {
  id              String           @id @default(cuid())
  name            String           @unique
  description     String?
  category        String
  createdAt       DateTime         @default(now())
  roles           RolePermission[]
  userPermissions UserPermission[]

  @@index([category])
  @@map("permissions")
}

model RolePermission {
  id           String     @id @default(cuid())
  role         UserRole
  permissionId String
  createdAt    DateTime   @default(now())
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([role, permissionId])
  @@index([role])
  @@map("role_permissions")
}

model UserPermission {
  id           String     @id @default(cuid())
  userId       String
  permissionId String
  granted      Boolean    @default(true)
  expiresAt    DateTime?
  createdAt    DateTime   @default(now())
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, permissionId])
  @@index([userId])
  @@map("user_permissions")
}

model PasswordHistory {
  id             String   @id @default(cuid())
  userId         String
  hashedPassword String
  createdAt      DateTime @default(now())
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("password_histories")
}

model PermissionRule {
  id          String   @id @default(cuid())
  contentType String
  contentId   String
  userId      String?
  userRole    String?
  permissions String[]
  conditions  Json?    @default("{}")
  isActive    Boolean  @default(true)
  createdBy   String
  createdAt   DateTime @default(now())
  creator     User     @relation(fields: [createdBy], references: [id], onDelete: Cascade)

  @@index([contentType, contentId])
  @@index([isActive])
  @@map("permission_rules")
}

model PermissionActivity {
  id           String   @id @default(cuid())
  actorId      String
  targetUserId String
  contentType  String
  contentId    String
  activityType String
  metadata     Json     @default("{}")
  timestamp    DateTime @default(now())
  actor        User     @relation("PermissionActor", fields: [actorId], references: [id], onDelete: Cascade)
  targetUser   User     @relation("PermissionTarget", fields: [targetUserId], references: [id], onDelete: Cascade)

  @@index([actorId])
  @@index([targetUserId])
  @@index([contentType, contentId])
  @@index([timestamp])
  @@map("permission_activities")
}

model UserCapability {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  capability   String // "STUDENT", "TEACHER", "AFFILIATE", "MODERATOR", "CONTENT_CREATOR"
  grantedAt    DateTime  @default(now())
  grantedBy    String? // User ID who granted this capability
  expiresAt    DateTime? // Optional expiration for temporary capabilities
  isActive     Boolean   @default(true)
  metadata     Json? // Additional capability-specific data
  requirements Json? // Requirements met to earn this capability
  revokedAt    DateTime?
  revokedBy    String?
  revokeReason String?

  @@unique([userId, capability])
  @@index([userId])
  @@index([capability])
  @@index([isActive])
  @@index([expiresAt])
}

model AdminAccount {
  id                String       @id @default(cuid())

  // Admin User Profile Fields
  name              String?
  email             String       @unique
  emailVerified     DateTime?
  password          String?
  image             String?
  role              AdminRole    @default(ADMIN)
  phone             String?
  department        String?
  bio               String?      @db.Text

  // Two-Factor Authentication
  isTwoFactorEnabled Boolean     @default(false)
  totpEnabled       Boolean      @default(false)
  totpVerified      Boolean      @default(false)
  totpSecret        String?
  recoveryCodes     String[]     @default([])

  // OAuth Fields (for admin SSO if needed)
  adminId           String?
  type              String?
  provider          String?
  providerAccountId String?
  refresh_token     String?      @db.Text
  access_token      String?      @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?      @db.Text
  session_state     String?

  // Relation to User (optional, for linking to existing user if needed)
  admin             User?        @relation("AdminAccounts", fields: [adminId], references: [id], onDelete: Cascade)

  // Audit logs relation
  auditLogs         AdminAuditLog[]

  // Active sessions relation
  activeSessions    AdminActiveSession[] @relation("AdminAccountSessions")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([provider, providerAccountId])
  @@index([adminId])
  @@index([provider])
  @@index([email])
  @@index([role])
}

model AdminActiveSession {
  id              String   @id @default(cuid())
  adminId         String
  adminAccountId  String?
  sessionToken    String   @unique
  ipAddress       String
  userAgent       String?
  browser         String?
  os              String?
  deviceType      String?
  deviceInfo      String?
  location        String?
  expiresAt       DateTime
  isActive        Boolean  @default(true)
  lastActiveAt    DateTime @default(now())

  admin           User          @relation("AdminActiveSessions", fields: [adminId], references: [id], onDelete: Cascade)
  adminAccount    AdminAccount? @relation("AdminAccountSessions", fields: [adminAccountId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([adminId])
  @@index([adminAccountId])
  @@index([sessionToken])
  @@index([expiresAt])
  @@index([isActive])
}

