# Production Environment Variables Template
# Copy this file to .env.production and fill in your actual values

# Application Configuration
NODE_ENV=production
APP_NAME=Alam LMS
APP_VERSION=1.0.0
PORT=3000
HOST=0.0.0.0
BASE_URL=https://your-domain.com
TIMEZONE=UTC

# Database Configuration
DATABASE_URL=postgresql://username:password@localhost:5432/alam_lms_prod
DB_POOL_SIZE=20
DB_TIMEOUT=30000
DB_MAX_RETRIES=3
DB_RETRY_DELAY=1000

# Redis Configuration
REDIS_URL=redis://localhost:6379
REDIS_MAX_RETRIES=3
REDIS_RETRY_DELAY=1000
REDIS_CONNECT_TIMEOUT=10000
REDIS_COMMAND_TIMEOUT=5000
REDIS_MAX_MEMORY_POLICY=allkeys-lru

# Kafka Configuration
KAFKA_BROKERS=localhost:9092
KAFKA_GROUP_ID=lms-consumer-group
KAFKA_CLIENT_ID=alam-lms-client
KAFKA_CONNECTION_TIMEOUT=3000
KAFKA_REQUEST_TIMEOUT=30000
KAFKA_SSL_ENABLED=false
# KAFKA_SASL_MECHANISM=plain
# KAFKA_SASL_USERNAME=
# KAFKA_SASL_PASSWORD=

# ML/AI Configuration
ML_MODEL_PATH=./models
ML_BATCH_SIZE=32
ML_INFERENCE_TIMEOUT=5000
ML_MAX_CONCURRENT=10
ML_UPDATE_INTERVAL=86400000
TF_ENABLE_GPU=false
TF_MEMORY_GROWTH=true

# Analytics Configuration
ANALYTICS_RETENTION_DAYS=90
ANALYTICS_AGGREGATION_INTERVAL=3600000
ANALYTICS_BATCH_SIZE=1000
ANALYTICS_BUFFER_SIZE=100
ANALYTICS_EXPORT_FORMATS=json,csv,xlsx

# Security Configuration
JWT_SECRET=your-super-secret-jwt-key-here
JWT_EXPIRES_IN=7d
BCRYPT_ROUNDS=12
CORS_ORIGINS=https://your-domain.com,https://app.your-domain.com
SESSION_SECRET=your-session-secret-here
SESSION_MAX_AGE=2592000000

# Rate Limiting
RATE_LIMIT_WINDOW=900000
RATE_LIMIT_MAX=100

# File Storage Configuration
STORAGE_PROVIDER=s3
MAX_FILE_SIZE=10485760
LOCAL_UPLOAD_DIR=./uploads

# S3 Configuration (if using S3)
S3_BUCKET=your-s3-bucket-name
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=your-access-key
S3_SECRET_ACCESS_KEY=your-secret-key

# External Integrations
ZOOM_API_KEY=your-zoom-api-key
ZOOM_API_SECRET=your-zoom-api-secret
ZOOM_WEBHOOK_SECRET=your-zoom-webhook-secret

GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=https://your-domain.com/auth/google/callback

SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
SLACK_SIGNING_SECRET=your-slack-signing-secret

GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
GITHUB_WEBHOOK_SECRET=your-github-webhook-secret

# Monitoring and Logging
ENABLE_METRICS=true
METRICS_PORT=9090
LOG_LEVEL=info
LOG_FORMAT=json
HEALTH_CHECK_INTERVAL=30000

# Alerting Configuration
ALERT_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK
ALERT_SLACK_CHANNEL=#alerts
ALERT_EMAIL_RECIPIENTS=admin@your-domain.com,ops@your-domain.com

# Performance Configuration
ENABLE_COMPRESSION=true
COMPRESSION_LEVEL=6
ENABLE_CACHING=true
CACHE_MAX_AGE=3600
ENABLE_CDN=true
CDN_URL=https://cdn.your-domain.com

# Job Market Configuration
JOB_MARKET_UPDATE_INTERVAL=86400000
LINKEDIN_API_ENDPOINT=https://api.linkedin.com/v2
INDEED_API_ENDPOINT=https://api.indeed.com/ads/apisearch
GLASSDOOR_API_ENDPOINT=https://api.glassdoor.com/api/api.htm

LINKEDIN_API_KEY=your-linkedin-api-key
INDEED_API_KEY=your-indeed-api-key
GLASSDOOR_API_KEY=your-glassdoor-api-key

JOB_MARKET_CACHE_DURATION=3600000

# Email Configuration
EMAIL_PROVIDER=smtp
SMTP_HOST=smtp.your-email-provider.com
SMTP_PORT=587
SMTP_SECURE=true
SMTP_USER=your-email@your-domain.com
SMTP_PASS=your-email-password
EMAIL_FROM=noreply@your-domain.com
EMAIL_TEMPLATES_PATH=./templates/emails

# Backup Configuration
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30
BACKUP_DESTINATION=s3
BACKUP_ENCRYPTION=true

# Feature Flags
FEATURE_JOB_MARKET_MAPPING=true
FEATURE_EMOTION_DETECTION=true
FEATURE_SPACED_REPETITION=true
FEATURE_MICROLEARNING=true
FEATURE_REAL_TIME_ANALYTICS=true
FEATURE_EXTERNAL_INTEGRATIONS=true

# NextAuth Configuration (if using NextAuth)
NEXTAUTH_URL=https://your-domain.com
NEXTAUTH_SECRET=your-nextauth-secret

# Additional Security
CSP_REPORT_URI=https://your-domain.com/csp-report
SECURITY_HEADERS_ENABLED=true

# Third-party Service Keys
OPENAI_API_KEY=your-openai-api-key
ANTHROPIC_API_KEY=your-anthropic-api-key
HUGGINGFACE_API_KEY=your-huggingface-api-key