# .env.example (TEMPLATE FILE FOR DOCUMENTATION)
NODE_ENV=development
DATABASE_URL="postgresql://user:password@localhost:5432/database_name"
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000
AUTH_SECRET=your_auth_secret_here
NEXTAUTH_SECRET=your_auth_secret_here
RESEND_API_KEY=your_resend_api_key
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
DISABLE_REDIS=true

# AI Services
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Railway Deployment (automatically detected)
# RAILWAY_ENVIRONMENT=production
# RAILWAY_PUBLIC_DOMAIN=your-app.railway.app
# RAILWAY_PROJECT_ID=automatically_set_by_railway

# News Services (Optional - for real news fetching)
# Real news is automatically enabled on Railway/Production
USE_REAL_NEWS=false
# Get free API key from https://newsapi.org
NEWS_API_KEY=your_newsapi_key_here
# Get API key from https://www.microsoft.com/en-us/bing/apis/bing-news-search-api
BING_API_KEY=your_bing_api_key_here
# Get API key from https://developers.google.com/custom-search/v1/overview
GOOGLE_SEARCH_API_KEY=your_google_search_api_key_here
GOOGLE_SEARCH_ENGINE_ID=your_google_search_engine_id_here

# Observability & Monitoring
# OpenTelemetry Configuration
OTEL_SERVICE_NAME=taxomind-lms
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318/v1/traces
OTEL_EXPORTER_OTLP_HEADERS={}
ENABLE_OTEL=true

# Sentry Error Tracking
SENTRY_DSN=your_sentry_dsn_here
NEXT_PUBLIC_SENTRY_DSN=your_sentry_public_dsn_here
SENTRY_ORG=your_sentry_org
SENTRY_PROJECT=taxomind-lms
SENTRY_AUTH_TOKEN=your_sentry_auth_token

# Prometheus Metrics
METRICS_AUTH_TOKEN=your_metrics_auth_token_here

# Redis (for caching and metrics)
UPSTASH_REDIS_REST_URL=your_upstash_redis_url
UPSTASH_REDIS_REST_TOKEN=your_upstash_redis_token