# =============================================================================
# TAXOMIND ENTERPRISE ARCHITECTURE - ENVIRONMENT CONFIGURATION TEMPLATE
# =============================================================================
# 
# This template provides comprehensive environment configuration for the 
# enterprise architecture systems including API Gateway, Circuit Breakers,
# BullMQ Job Queues, Database Read Replicas, and Message Queue System.
#
# Copy this file to .env.local and update the values according to your environment
# =============================================================================

# =============================================================================
# CORE APPLICATION SETTINGS
# =============================================================================
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
PORT=3000

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
# Primary Database (Write Operations)
DATABASE_URL="postgresql://username:password@localhost:5432/taxomind_main?schema=public"

# Read Replica Databases (Read Operations)
# Configure multiple read replicas for load distribution
DATABASE_READ_REPLICA_1="postgresql://username:password@replica1.example.com:5432/taxomind_main?schema=public"
DATABASE_READ_REPLICA_2="postgresql://username:password@replica2.example.com:5432/taxomind_main?schema=public"
DATABASE_READ_REPLICA_3="postgresql://username:password@replica3.example.com:5432/taxomind_main?schema=public"

# Database Connection Pool Settings
DB_POOL_MIN=5
DB_POOL_MAX=20
DB_POOL_IDLE_TIMEOUT=30000
DB_POOL_CONNECTION_TIMEOUT=5000

# Database Monitoring
DB_MONITORING_ENABLED=true
DB_SLOW_QUERY_THRESHOLD=1000
DB_ERROR_RATE_THRESHOLD=5
DB_CONNECTION_UTILIZATION_THRESHOLD=80

# =============================================================================
# REDIS CONFIGURATION (Used by multiple systems)
# =============================================================================
# Primary Redis Instance
REDIS_URL="redis://localhost:6379"
REDIS_PASSWORD=""
REDIS_DB=0

# Redis Cluster Configuration (if using Redis Cluster)
REDIS_CLUSTER_ENABLED=false
REDIS_CLUSTER_NODES="redis://localhost:7000,redis://localhost:7001,redis://localhost:7002"

# Redis Connection Settings
REDIS_MAX_RETRIES=3
REDIS_RETRY_DELAY=1000
REDIS_CONNECTION_TIMEOUT=5000
REDIS_COMMAND_TIMEOUT=3000

# =============================================================================
# API GATEWAY CONFIGURATION
# =============================================================================
# Gateway Settings
API_GATEWAY_ENABLED=true
API_GATEWAY_PORT=3000
API_GATEWAY_HEALTH_CHECK_INTERVAL=30000

# Rate Limiting (using Redis)
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW=60000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_SKIP_FAILED_REQUESTS=true
RATE_LIMIT_SKIP_SUCCESSFUL_REQUESTS=false

# API Key for Gateway Management
API_GATEWAY_ADMIN_KEY="your-secure-admin-key-here"

# Load Balancing Strategy
LOAD_BALANCING_STRATEGY=round-robin  # Options: round-robin, weighted, least-connections

# =============================================================================
# CIRCUIT BREAKER CONFIGURATION
# =============================================================================
# Circuit Breaker Global Settings
CIRCUIT_BREAKER_ENABLED=true

# Database Circuit Breaker
DB_CIRCUIT_BREAKER_TIMEOUT=3000
DB_CIRCUIT_BREAKER_ERROR_THRESHOLD_PERCENTAGE=50
DB_CIRCUIT_BREAKER_RESET_TIMEOUT=30000
DB_CIRCUIT_BREAKER_MIN_REQUESTS=10

# External API Circuit Breaker
API_CIRCUIT_BREAKER_TIMEOUT=5000
API_CIRCUIT_BREAKER_ERROR_THRESHOLD_PERCENTAGE=60
API_CIRCUIT_BREAKER_RESET_TIMEOUT=60000
API_CIRCUIT_BREAKER_MIN_REQUESTS=5

# AI Service Circuit Breaker
AI_CIRCUIT_BREAKER_TIMEOUT=30000
AI_CIRCUIT_BREAKER_ERROR_THRESHOLD_PERCENTAGE=40
AI_CIRCUIT_BREAKER_RESET_TIMEOUT=120000
AI_CIRCUIT_BREAKER_MIN_REQUESTS=3

# =============================================================================
# BULLMQ JOB QUEUE CONFIGURATION
# =============================================================================
# Queue Settings
QUEUE_ENABLED=true
QUEUE_REDIS_HOST=localhost
QUEUE_REDIS_PORT=6379
QUEUE_REDIS_PASSWORD=""
QUEUE_REDIS_DB=1

# Queue Concurrency Settings
EMAIL_QUEUE_CONCURRENCY=5
ANALYTICS_QUEUE_CONCURRENCY=10
AI_GENERATION_QUEUE_CONCURRENCY=3

# Job Settings
JOB_ATTEMPTS=3
JOB_BACKOFF_TYPE=exponential
JOB_BACKOFF_DELAY=2000
JOB_REMOVE_ON_COMPLETE=100
JOB_REMOVE_ON_FAIL=50

# Queue Monitoring
QUEUE_DASHBOARD_ENABLED=true
QUEUE_DASHBOARD_PORT=3001
QUEUE_METRICS_ENABLED=true

# =============================================================================
# MESSAGE QUEUE / EVENT BUS CONFIGURATION
# =============================================================================
# Event Bus Settings
EVENT_BUS_ENABLED=true
EVENT_BUS_REDIS_DB=2
EVENT_BUS_MAX_HISTORY_SIZE=10000

# Event Processing
EVENT_HANDLER_TIMEOUT=30000
EVENT_RETRY_ATTEMPTS=3
EVENT_DEAD_LETTER_QUEUE_ENABLED=true

# Event Persistence
EVENT_PERSISTENCE_ENABLED=true
EVENT_HISTORY_RETENTION_DAYS=30

# =============================================================================
# AUTHENTICATION & SECURITY
# =============================================================================
# NextAuth Configuration
NEXTAUTH_SECRET="your-nextauth-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# JWT Settings
JWT_SECRET="your-jwt-secret-here"
JWT_EXPIRATION=24h

# OAuth Providers (if using)
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
GITHUB_CLIENT_ID="your-github-client-id"
GITHUB_CLIENT_SECRET="your-github-client-secret"

# =============================================================================
# AI SERVICE CONFIGURATION
# =============================================================================
# OpenAI
OPENAI_API_KEY="your-openai-api-key"
OPENAI_ORGANIZATION="your-openai-org-id"

# Anthropic Claude
ANTHROPIC_API_KEY="your-anthropic-api-key"

# AI Service Rate Limiting
AI_RATE_LIMIT_ENABLED=true
AI_RATE_LIMIT_REQUESTS_PER_MINUTE=50

# =============================================================================
# EMAIL SERVICE CONFIGURATION
# =============================================================================
# Email Provider (choose one)
EMAIL_PROVIDER=resend  # Options: resend, sendgrid, ses

# Resend Configuration
RESEND_API_KEY="your-resend-api-key"

# Email Settings
EMAIL_FROM="noreply@taxomind.com"
EMAIL_QUEUE_ENABLED=true

# =============================================================================
# MONITORING & OBSERVABILITY
# =============================================================================
# Application Monitoring
MONITORING_ENABLED=true
METRICS_ENABLED=true
HEALTH_CHECK_ENABLED=true

# Logging Configuration
LOG_LEVEL=info  # Options: error, warn, info, debug
LOG_FORMAT=json  # Options: json, text

# Performance Monitoring
PERFORMANCE_MONITORING_ENABLED=true
SLOW_REQUEST_THRESHOLD=1000
ERROR_TRACKING_ENABLED=true

# =============================================================================
# CACHING CONFIGURATION
# =============================================================================
# Application Cache
CACHE_ENABLED=true
CACHE_TTL=300
CACHE_MAX_SIZE=1000

# Redis Cache Settings
REDIS_CACHE_ENABLED=true
REDIS_CACHE_TTL=3600

# =============================================================================
# FILE STORAGE & CDN
# =============================================================================
# Cloudinary Configuration
CLOUDINARY_CLOUD_NAME="your-cloudinary-cloud-name"
CLOUDINARY_API_KEY="your-cloudinary-api-key"
CLOUDINARY_API_SECRET="your-cloudinary-api-secret"

# File Upload Settings
MAX_FILE_SIZE=10485760  # 10MB in bytes
ALLOWED_FILE_TYPES="image/*,application/pdf,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document"

# =============================================================================
# PAYMENT PROCESSING
# =============================================================================
# Stripe Configuration
STRIPE_PUBLISHABLE_KEY="your-stripe-publishable-key"
STRIPE_SECRET_KEY="your-stripe-secret-key"
STRIPE_WEBHOOK_SECRET="your-stripe-webhook-secret"

# =============================================================================
# DEVELOPMENT & TESTING
# =============================================================================
# Development Settings
DEVELOPMENT_MODE=true
DEBUG_ENABLED=false
VERBOSE_LOGGING=false

# Testing Configuration
TEST_DATABASE_URL="postgresql://username:password@localhost:5432/taxomind_test?schema=public"
TEST_REDIS_URL="redis://localhost:6379"
TEST_REDIS_DB=15

# =============================================================================
# ENTERPRISE FEATURES
# =============================================================================
# Enterprise Database Layer
ENTERPRISE_DB_ENABLED=true
STRICT_ENV_MODE=false  # Set to true in production
AUDIT_LOGGING_ENABLED=true

# Backup and Recovery
BACKUP_ENABLED=true
BACKUP_SCHEDULE="0 2 * * *"  # Daily at 2 AM
BACKUP_RETENTION_DAYS=30

# High Availability
HIGH_AVAILABILITY_MODE=false
FAILOVER_ENABLED=false
CLUSTER_MODE=false

# =============================================================================
# PERFORMANCE TUNING
# =============================================================================
# Node.js Performance
NODE_OPTIONS="--max-old-space-size=4096"
UV_THREADPOOL_SIZE=16

# Next.js Performance
NEXT_TELEMETRY_DISABLED=1
NEXT_BUILD_CACHE=true

# Database Performance
DB_STATEMENT_TIMEOUT=30000
DB_QUERY_TIMEOUT=10000
DB_IDLE_IN_TRANSACTION_SESSION_TIMEOUT=60000

# =============================================================================
# SECURITY SETTINGS
# =============================================================================
# CORS Configuration
CORS_ENABLED=true
CORS_ORIGIN="http://localhost:3000,https://your-domain.com"
CORS_CREDENTIALS=true

# CSRF Protection
CSRF_ENABLED=true
CSRF_SECRET="your-csrf-secret"

# Content Security Policy
CSP_ENABLED=true
CSP_REPORT_ONLY=false

# =============================================================================
# FEATURE FLAGS
# =============================================================================
# Feature Toggles
FEATURE_API_GATEWAY=true
FEATURE_CIRCUIT_BREAKERS=true
FEATURE_MESSAGE_QUEUES=true
FEATURE_DB_REPLICAS=true
FEATURE_ADVANCED_ANALYTICS=true
FEATURE_AI_POWERED_INSIGHTS=true
FEATURE_REAL_TIME_COLLABORATION=true

# =============================================================================
# EXTERNAL SERVICES
# =============================================================================
# Analytics Services
ANALYTICS_ENABLED=true
GA_MEASUREMENT_ID="your-ga-measurement-id"

# Error Tracking
SENTRY_DSN="your-sentry-dsn"
SENTRY_ENABLED=true

# Social Media Integration
FACEBOOK_APP_ID="your-facebook-app-id"
TWITTER_BEARER_TOKEN="your-twitter-bearer-token"

# =============================================================================
# CONTAINER & DEPLOYMENT
# =============================================================================
# Docker Configuration
DOCKER_REGISTRY="your-docker-registry"
IMAGE_TAG=latest

# Kubernetes Configuration
NAMESPACE=taxomind
REPLICA_COUNT=3
RESOURCE_LIMITS_CPU=1000m
RESOURCE_LIMITS_MEMORY=2Gi

# =============================================================================
# NOTES & REMINDERS
# =============================================================================
# 
# 1. Update all placeholder values with your actual configuration
# 2. Never commit real credentials to version control
# 3. Use different values for development, staging, and production
# 4. Regularly rotate secrets and API keys
# 5. Monitor resource usage and adjust limits accordingly
# 6. Test all integrations before deploying to production
# 7. Set up proper backup and disaster recovery procedures
# 8. Configure monitoring and alerting for all critical systems
# 9. Review and update security settings regularly
# 10. Document any custom configurations or modifications
#
# =============================================================================