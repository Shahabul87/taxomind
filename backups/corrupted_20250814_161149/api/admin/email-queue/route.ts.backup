import { NextRequest, NextResponse } from "next/server";
import { currentUser } from "@/lib/auth";
import { withAuth, withAdminAuth, withOwnership, withPublicAPI } from '@/lib/api/with-api-auth';
import { 
  emailQueue, 
  emailProcessor, 
  getEmailProcessorStatus,
  getEmailProcessorMetrics 
} from "@/lib/queue/email-queue";
import { 
  emailMonitor, 
  getEmailDashboardData,
  getEmailSLAReport,
  getActiveEmailAlerts 
} from "@/lib/queue/email-monitoring";
import { logger } from "@/lib/logger";

/**
 * GET /api/admin/email-queue
 * Get email queue status and metrics
 */
export async function GET(request: NextRequest) {
  try {
    // Check if user is authenticated and has admin role
    const user = await currentUser();
    
    if (!user || user.role !== "ADMIN") {
      return NextResponse.json(
        { error: "Unauthorized - Admin access required" },
        { status: 401 }
      );
    }

    const { searchParams } = new URL(request.url);
    const action = searchParams.get('action') || 'status';

    switch (action) {
      case 'status':
        return await getQueueStatus();
        
      case 'dashboard':
        return await getDashboard();
        
      case 'sla':
        const period = searchParams.get('period') as 'day' | 'week' | 'month' || 'day';
        return await getSLAReport(period);
        
      case 'alerts':
        return await getAlerts();
        
      case 'processor':
        return await getProcessorInfo();
        
      case 'metrics':
        const timeRange = searchParams.get('timeRange') || '1h';
        return await getMetrics(timeRange);
        
      default:
        return NextResponse.json(
          { error: "Invalid action parameter" },
          { status: 400 }
        );
    }
  } catch (error: any) {
    logger.error("[EMAIL_QUEUE_API] GET error:", error);
    return NextResponse.json(
      { error: "Internal server error", details: error.message },
      { statexport const POST = withAdminAuth(async (request, context) => {
  // Check if user is authenticated and has admin role
    
    
      return NextResponse.json(
}, {
  rateLimit: { requests: 10, window: 60000 },
  auditLog: true
});,
        { status: 401 }
      );
    }

    const { action, data } = await request.json();

    switch (action) {
      case 'reprocess-dlq':
        return await reprocessDLQJobs(data?.limit);
        
      case 'acknowledge-alert':
        return await acknowledgeAlert(data?.alertId);
        
      case 'resolve-alert':
        return await resolveAlert(data?.alertId);
        
      case 'test-email':
        return await sendTestEmail(data);
        
      case 'pause-queue':
        return await pauseQueue();
        
      case 'resume-queue':
        return await resumeQueue();
        
      case 'clear-queue':
        return await clearQueue(data?.queueType);
        
      default:
        return NextResponse.json(
          { error: "Invalid action parameter" },
          { status: 400 }
        );
    }
  } catch (error: any) {
    logger.error("[EMAIL_QUEUE_API] POST error:", error);
    return NextResponse.json(
      { error: "Internal server error", details: error.message },
      { status: 500 }
    );
  }
}

/**
 * Get queue status
 */
async function getQueueStatus() {
  try {
    const queueStats = await emailQueue.getStatistics();
    
    return NextResponse.json({
      success: true,
      data: {
        queue: queueStats,
        timestamp: new Date(),
      }
    });
  } catch (error: any) {
    return NextResponse.json(
      { error: "Failed to get queue status", details: error.message },
      { status: 500 }
    );
  }
}

/**
 * Get dashboard data
 */
async function getDashboard() {
  try {
    const dashboardData = await getEmailDashboardData();
    
    return NextResponse.json({
      success: true,
      data: dashboardData
    });
  } catch (error: any) {
    return NextResponse.json(
      { error: "Failed to get dashboard data", details: error.message },
      { status: 500 }
    );
  }
}

/**
 * Get SLA report
 */
async function getSLAReport(period: 'day' | 'week' | 'month') {
  try {
    const slaReport = await getEmailSLAReport(period);
    
    return NextResponse.json({
      success: true,
      data: slaReport
    });
  } catch (error: any) {
    return NextResponse.json(
      { error: "Failed to get SLA report", details: error.message },
      { status: 500 }
    );
  }
}

/**
 * Get active alerts
 */
async function getAlerts() {
  try {
    const alerts = getActiveEmailAlerts();
    
    return NextResponse.json({
      success: true,
      data: {
        alerts,
        total: alerts.length,
        critical: alerts.filter(a => a.severity === 'critical').length,
        high: alerts.filter(a => a.severity === 'high').length,
        medium: alerts.filter(a => a.severity === 'medium').length,
        low: alerts.filter(a => a.severity === 'low').length,
      }
    });
  } catch (error: any) {
    return NextResponse.json(
      { error: "Failed to get alerts", details: error.message },
      { status: 500 }
    );
  }
}

/**
 * Get processor information
 */
async function getProcessorInfo() {
  try {
    const processorStatus = getEmailProcessorStatus();
    const processorMetrics = await getEmailProcessorMetrics();
    
    return NextResponse.json({
      success: true,
      data: {
        status: processorStatus,
        metrics: processorMetrics,
      }
    });
  } catch (error: any) {
    return NextResponse.json(
      { error: "Failed to get processor info", details: error.message },
      { status: 500 }
    );
  }
}

/**
 * Get metrics for specified time range
 */
async function getMetrics(timeRange: string) {
  try {
    // Parse time range
    const endDate = new Date();
    const startDate = new Date();
    
    switch (timeRange) {
      case '1h':
        startDate.setHours(startDate.getHours() - 1);
        break;
      case '6h':
        startDate.setHours(startDate.getHours() - 6);
        break;
      case '24h':
        startDate.setHours(startDate.getHours() - 24);
        break;
      case '7d':
        startDate.setDate(startDate.getDate() - 7);
        break;
      case '30d':
        startDate.setDate(startDate.getDate() - 30);
        break;
      default:
        startDate.setHours(startDate.getHours() - 1);
    }
    
    // Get historical metrics (placeholder - would be implemented in monitor)
    const historicalMetrics = []; // await emailMonitor.getHistoricalMetrics(startDate, endDate);
    
    return NextResponse.json({
      success: true,
      data: {
        metrics: historicalMetrics,
        timeRange: {
          start: startDate,
          end: endDate,
          range: timeRange,
        },
      }
    });
  } catch (error: any) {
    return NextResponse.json(
      { error: "Failed to get metrics", details: error.message },
      { status: 500 }
    );
  }
}

/**
 * Reprocess jobs from Dead Letter Queue
 */
async function reprocessDLQJobs(limit: number = 10) {
  try {
    const result = await emailQueue.reprocessDLQJobs(limit);
    
    logger.info(`[EMAIL_QUEUE_API] Reprocessed ${result.processed} DLQ jobs`, result);
    
    return NextResponse.json({
      success: true,
      data: {
        processed: result.processed,
        errors: result.errors,
        message: `Successfully reprocessed ${result.processed} jobs from DLQ`
      }
    });
  } catch (error: any) {
    return NextResponse.json(
      { error: "Failed to reprocess DLQ jobs", details: error.message },
      { status: 500 }
    );
  }
}

/**
 * Acknowledge alert
 */
async function acknowledgeAlert(alertId: string) {
  try {
    if (!alertId) {
      return NextResponse.json(
        { error: "Alert ID is required" },
        { status: 400 }
      );
    }
    
    const acknowledged = emailMonitor.acknowledgeAlert(alertId);
    
    if (acknowledged) {
      return NextResponse.json({
        success: true,
        data: { message: "Alert acknowledged successfully" }
      });
    } else {
      return NextResponse.json(
        { error: "Alert not found or already acknowledged" },
        { status: 404 }
      );
    }
  } catch (error: any) {
    return NextResponse.json(
      { error: "Failed to acknowledge alert", details: error.message },
      { status: 500 }
    );
  }
}

/**
 * Resolve alert
 */
async function resolveAlert(alertId: string) {
  try {
    if (!alertId) {
      return NextResponse.json(
        { error: "Alert ID is required" },
        { status: 400 }
      );
    }
    
    const resolved = emailMonitor.resolveAlert(alertId);
    
    if (resolved) {
      return NextResponse.json({
        success: true,
        data: { message: "Alert resolved successfully" }
      });
    } else {
      return NextResponse.json(
        { error: "Alert not found or already resolved" },
        { status: 404 }
      );
    }
  } catch (error: any) {
    return NextResponse.json(
      { error: "Failed to resolve alert", details: error.message },
      { status: 500 }
    );
  }
}

/**
 * Send test email
 */
async function sendTestEmail(data: any) {
  try {
    const { email, type = 'test' } = data;
    
    if (!email || !email.includes('@')) {
      return NextResponse.json(
        { error: "Valid email address is required" },
        { status: 400 }
      );
    }
    
    // Queue a test email
    const job = await emailQueue.addEmailJob('send-notification-email', {
      userEmail: email,
      userName: 'Admin Test',
      subject: 'Email Queue Test - Taxomind LMS',
      template: 'test',
      templateData: {
        message: 'This is a test email sent from the Taxomind LMS email queue system.',
        testTime: new Date().toISOString(),
        queueStatus: 'operational',
      },
      userId: 'admin-test',
      timestamp: new Date(),
      priority: 'high',
    });
    
    const jobId = typeof job === 'string' ? job : job.id;
    
    return NextResponse.json({
      success: true,
      data: {
        message: "Test email queued successfully",
        jobId,
        email,
      }
    });
  } catch (error: any) {
    return NextResponse.json(
      { error: "Failed to send test email", details: error.message },
      { status: 500 }
    );
  }
}

