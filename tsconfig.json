{
  "compilerOptions": {
    "target": "es2020",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "types": [
      "jest",
      "@testing-library/jest-dom"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "tsBuildInfoFile": ".next/.tsbuildinfo",
    "assumeChangesOnlyAffectDirectDependencies": true,
    "disableSourceOfProjectReferenceRedirect": true,
    "disableSolutionSearching": true,
    "disableReferencedProjectLoad": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": [
        "./*"
      ],
      "@sam-ai/core": [
        "./packages/core/src/index.ts"
      ],
      "@sam-ai/core/*": [
        "./packages/core/src/*"
      ],
      "@sam-ai/api": [
        "./packages/api/src/index.ts"
      ],
      "@sam-ai/api/*": [
        "./packages/api/src/*"
      ],
      "@sam-ai/react": [
        "./packages/react/src/index.ts"
      ],
      "@sam-ai/react/*": [
        "./packages/react/src/*"
      ],
      "@sam-ai/educational": [
        "./packages/educational/src/index.ts"
      ],
      "@sam-ai/educational/*": [
        "./packages/educational/src/*"
      ],
      "@sam-ai/adapter-prisma": [
        "./packages/adapter-prisma/src/index.ts"
      ],
      "@sam-ai/adapter-prisma/*": [
        "./packages/adapter-prisma/src/*"
      ],
      "@sam-ai/adapter-taxomind": [
        "./packages/adapter-taxomind/src/index.ts"
      ],
      "@sam-ai/adapter-taxomind/*": [
        "./packages/adapter-taxomind/src/*"
      ],
      "@sam-ai/quality": [
        "./packages/quality/src/index.ts"
      ],
      "@sam-ai/quality/*": [
        "./packages/quality/src/*"
      ],
      "@sam-ai/pedagogy": [
        "./packages/pedagogy/src/index.ts"
      ],
      "@sam-ai/pedagogy/*": [
        "./packages/pedagogy/src/*"
      ],
      "@sam-ai/memory": [
        "./packages/memory/src/index.ts"
      ],
      "@sam-ai/memory/*": [
        "./packages/memory/src/*"
      ],
      "@sam-ai/integration": [
        "./packages/integration/src/index.ts"
      ],
      "@sam-ai/integration/*": [
        "./packages/integration/src/*"
      ],
      "@sam-ai/safety": [
        "./packages/safety/src/index.ts"
      ],
      "@sam-ai/safety/*": [
        "./packages/safety/src/*"
      ],
      "@sam-ai/agentic": [
        "./packages/agentic/src/index.ts"
      ],
      "@sam-ai/agentic/*": [
        "./packages/agentic/src/*"
      ]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "playwright.config.ts",
    "**/vitest.config.ts",
    "**/jest.config.ts",
    "**/jest.config.js",
    "e2e/**",
    "backups/**",
    "data/backups/**",
    ".next/**",
    "coverage/**",
    "dist/**",
    "packages/*/dist/**",
    "__tests__/**",
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/*.spec.ts",
    "**/*.spec.tsx",
    "**/*.e2e.ts",
    "**/test-utils/**",
    "**/mocks/**",
    "scripts/**",
    "SCALABLE_ARCHITECTURE_DOCS/**",
    "**/examples/**"
  ]
}
